{
  "paths": {
    "/coupons": {
      "post": {
        "operationId": "createCoupon",
        "summary": "POST Create Coupon",
        "description": "Create a new discount coupon.",
        "tags": ["Coupons"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCouponRequest"
              },
              "example": {
                "code": "SAVE20",
                "name": "20% Off Discount",
                "type": "percentage",
                "value": 20,
                "status": "active",
                "usage_limit": 50,
                "minimum_amount": 1000,
                "maximum_amount": 10000,
                "valid_from": "2024-01-01T00:00:00Z",
                "valid_until": "2024-12-31T23:59:59Z"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CouponResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateCouponRequest": {
        "type": "object",
        "required": ["code", "name", "type", "value"],
        "properties": {
          "code": {
            "type": "string",
            "description": "Coupon code",
            "example": "SAVE20"
          },
          "name": {
            "type": "string",
            "description": "Coupon name",
            "example": "20% Off Discount"
          },
          "type": {
            "type": "string",
            "enum": ["percentage", "fixed", "free_shipping"],
            "description": "Coupon type",
            "example": "percentage"
          },
          "value": {
            "type": "number",
            "description": "Coupon value (percentage or fixed amount in cents)",
            "example": 20
          },
          "status": {
            "type": "string",
            "description": "Coupon status",
            "required": false,
            "example": "active"
          },
          "usage_limit": {
            "type": "integer",
            "description": "Usage limit",
            "required": false,
            "example": 50
          },
          "minimum_amount": {
            "type": "integer",
            "description": "Minimum amount in cents",
            "required": false,
            "example": 1000
          },
          "maximum_amount": {
            "type": "integer",
            "description": "Maximum amount in cents",
            "required": false,
            "example": 10000
          },
          "valid_from": {
            "type": "string",
            "format": "date-time",
            "description": "Valid from date",
            "required": false
          },
          "valid_until": {
            "type": "string",
            "format": "date-time",
            "description": "Valid until date",
            "required": false
          },
          "applicable_products": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Applicable product IDs",
            "required": false
          },
          "applicable_categories": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Applicable category IDs",
            "required": false
          },
          "customer_restrictions": {
            "type": "object",
            "description": "Customer restrictions",
            "required": false,
            "properties": {
              "new_customers_only": {
                "type": "boolean"
              },
              "customer_ids": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "CouponResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "coupon": {
                "$ref": "#/components/schemas/Coupon"
              }
            }
          }
        }
      },
      "Coupon": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Coupon ID",
            "example": 2
          },
          "code": {
            "type": "string",
            "description": "Coupon code",
            "example": "SAVE20"
          },
          "name": {
            "type": "string",
            "description": "Coupon name",
            "example": "20% Off Discount"
          },
          "type": {
            "type": "string",
            "enum": ["percentage", "fixed", "free_shipping"],
            "description": "Coupon type",
            "example": "percentage"
          },
          "value": {
            "type": "number",
            "description": "Coupon value",
            "example": 20
          },
          "status": {
            "type": "string",
            "description": "Coupon status",
            "example": "active"
          },
          "usage_limit": {
            "type": "integer",
            "description": "Usage limit",
            "example": 50
          },
          "used_count": {
            "type": "integer",
            "description": "Number of times used",
            "example": 0
          },
          "minimum_amount": {
            "type": "integer",
            "description": "Minimum amount in cents",
            "example": 1000
          },
          "maximum_amount": {
            "type": "integer",
            "description": "Maximum amount in cents",
            "example": 10000
          },
          "valid_from": {
            "type": "string",
            "format": "date-time",
            "description": "Valid from date",
            "example": "2024-01-01T00:00:00Z"
          },
          "valid_until": {
            "type": "string",
            "format": "date-time",
            "description": "Valid until date",
            "example": "2024-12-31T23:59:59Z"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2024-01-01T10:00:00Z"
          }
        }
      }
    }
  }
}

