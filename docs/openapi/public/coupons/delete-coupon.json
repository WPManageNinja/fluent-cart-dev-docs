{
  "paths": {
    "/coupons/{id}": {
      "delete": {
        "operationId": "deleteCoupon",
        "summary": "DELETE Delete Coupon",
        "description": "Delete a coupon.",
        "tags": [
          "Coupons"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Coupon ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Coupon deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message",
                      "example": "Coupon successfully deleted."
                    },
                    "data": {
                      "type": "string",
                      "description": "Empty string on success",
                      "example": ""
                    }
                  }
                },
                "example": {
                  "message": "Coupon successfully deleted.",
                  "data": ""
                }
              }
            }
          },
          "400": {
            "description": "Bad request - deletion failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": "rest_invalid_param",
                  "message": "Coupon deletion failed!",
                  "data": {
                    "status": 400
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - invalid coupon ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": "rest_invalid_param",
                  "message": "Please use a valid coupon ID!",
                  "data": {
                    "status": 403
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found - coupon does not exist",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": "rest_invalid_param",
                  "message": "Coupon not found in database, failed to remove.",
                  "data": {
                    "status": 404
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DeleteCouponResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "Coupon successfully deleted."
          },
          "data": {
            "type": "string",
            "description": "Empty string on success",
            "example": ""
          }
        }
      }
    }
  }
}