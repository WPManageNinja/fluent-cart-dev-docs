{
  "paths": {
    "/coupons/{id}": {
      "get": {
        "operationId": "getCoupon",
        "summary": "GET Get Coupon Details",
        "description": "Retrieve detailed information about a specific coupon.",
        "tags": ["Coupons"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Coupon ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CouponDetailResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CouponDetailResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "coupon": {
                "$ref": "#/components/schemas/CouponDetail"
              }
            }
          }
        }
      },
      "CouponDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Coupon ID",
            "example": 1
          },
          "code": {
            "type": "string",
            "description": "Coupon code",
            "example": "SAVE10"
          },
          "name": {
            "type": "string",
            "description": "Coupon name",
            "example": "10% Off Discount"
          },
          "type": {
            "type": "string",
            "enum": ["percentage", "fixed", "free_shipping"],
            "description": "Coupon type",
            "example": "percentage"
          },
          "value": {
            "type": "number",
            "description": "Coupon value",
            "example": 10
          },
          "status": {
            "type": "string",
            "description": "Coupon status",
            "example": "active"
          },
          "usage_limit": {
            "type": "integer",
            "description": "Usage limit",
            "example": 100
          },
          "used_count": {
            "type": "integer",
            "description": "Number of times used",
            "example": 25
          },
          "minimum_amount": {
            "type": "integer",
            "description": "Minimum amount in cents",
            "example": 5000
          },
          "maximum_amount": {
            "type": "integer",
            "description": "Maximum amount in cents",
            "example": 50000
          },
          "valid_from": {
            "type": "string",
            "format": "date-time",
            "description": "Valid from date",
            "example": "2024-01-01T00:00:00Z"
          },
          "valid_until": {
            "type": "string",
            "format": "date-time",
            "description": "Valid until date",
            "example": "2024-12-31T23:59:59Z"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2024-01-01T10:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2024-01-15T14:30:00Z"
          },
          "applicable_products": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "title": {
                  "type": "string"
                }
              }
            },
            "description": "Applicable products"
          },
          "applicable_categories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                }
              }
            },
            "description": "Applicable categories"
          },
          "usage_history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CouponUsage"
            },
            "description": "Usage history"
          }
        }
      },
      "CouponUsage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Usage ID",
            "example": 1
          },
          "order_id": {
            "type": "integer",
            "description": "Order ID",
            "example": 1
          },
          "customer_id": {
            "type": "integer",
            "description": "Customer ID",
            "example": 1
          },
          "discount_amount": {
            "type": "integer",
            "description": "Discount amount in cents",
            "example": 500
          },
          "used_at": {
            "type": "string",
            "format": "date-time",
            "description": "Usage timestamp",
            "example": "2024-01-15T14:30:00Z"
          }
        }
      }
    }
  }
}

