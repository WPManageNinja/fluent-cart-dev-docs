            "type": "integer",
            "description": "Items per page"
          },
          "prev_page_url": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL to previous page"
          },
          "to": {
            "type": "integer",
            "description": "Ending record number"
          },
          "total": {
            "type": "integer",
            "description": "Total number of records"
          }
        }
      },
