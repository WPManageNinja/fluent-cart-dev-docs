        "properties": {
          "current_page": {
            "type": "integer",
            "description": "Current page number",
            "example": 1
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Customer"
            }
          },
          "first_page_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to first page"
          },
          "from": {
            "type": "integer",
