                        "country": null,
                        "city": null,
                        "state": null,
                        "postcode": null,
                        "created_at": "2025-11-13T06:57:28+00:00",
                        "updated_at": "2025-11-13T06:57:28+00:00",
                        "full_name": "Jane Sina",
                        "photo": "https://secure.gravatar.com/avatar/...",
                        "country_name": "",
                        "formatted_address": {
                          "country": "",
