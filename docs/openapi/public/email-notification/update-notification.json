{
  "paths": {
    "/email-notification/{notification}": {
      "put": {
        "operationId": "updateEmailNotification",
        "summary": "PUT Update Notification",
        "description": "Update settings for a specific email notification.",
        "tags": [
          "Email Notification"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "notification",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Notification name/identifier",
            "example": "order_paid_admin"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "settings"
                ],
                "properties": {
                  "settings": {
                    "type": "object",
                    "required": [
                      "subject"
                    ],
                    "properties": {
                      "active": {
                        "type": "string",
                        "enum": [
                          "yes",
                          "no"
                        ],
                        "description": "Whether the notification is active",
                        "example": "yes"
                      },
                      "subject": {
                        "type": "string",
                        "maxLength": 255,
                        "description": "Email subject template (required, may contain smart codes)",
                        "example": "New Sales On {{settings.store_name}}"
                      },
                      "is_default_body": {
                        "type": "string",
                        "enum": [
                          "yes",
                          "no"
                        ],
                        "description": "Whether using default email body",
                        "example": "yes"
                      },
                      "email_body": {
                        "type": "string",
                        "nullable": true,
                        "description": "Custom email body (HTML allowed, required if is_default_body is 'no')",
                        "example": ""
                      }
                    }
                  }
                }
              },
              "example": {
                "settings": {
                  "active": "yes",
                  "subject": "New Sales On {{settings.store_name}}",
                  "is_default_body": "yes",
                  "email_body": ""
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message",
                      "example": "Notification updated successfully"
                    }
                  }
                },
                "example": {
                  "message": "Notification updated successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Error message",
                      "example": "Subject field is required."
                    }
                  }
                },
                "example": {
                  "message": "Subject field is required."
                }
              }
            }
          }
        }
      }
    },
    "/email-notification/save-settings": {
      "post": {
        "operationId": "saveEmailSettings",
        "summary": "POST Save Email Settings",
        "description": "Save global email notification settings (from name, from email, admin email, etc.).",
        "tags": [
          "Email Notification"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "from_name",
                  "from_email",
                  "admin_email"
                ],
                "properties": {
                  "from_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Default from name (required)",
                    "example": "Hello"
                  },
                  "from_email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 255,
                    "description": "Default from email address (required)",
                    "example": "hello@fluentcart.com"
                  },
                  "reply_to_name": {
                    "type": "string",
                    "maxLength": 255,
                    "nullable": true,
                    "description": "Reply-to name",
                    "example": ""
                  },
                  "reply_to_email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 255,
                    "nullable": true,
                    "description": "Reply-to email address",
                    "example": ""
                  },
                  "email_footer": {
                    "type": "string",
                    "nullable": true,
                    "description": "Email footer text (HTML allowed)",
                    "example": ""
                  },
                  "show_email_footer": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "nullable": true,
                    "description": "Whether to show email footer",
                    "example": "yes"
                  },
                  "admin_email": {
                    "type": "string",
                    "description": "Admin email address (required)",
                    "example": "hello@fluentcart.com"
                  }
                }
              },
              "example": {
                "from_name": "Hello",
                "from_email": "hello@fluentcart.com",
                "reply_to_name": "",
                "reply_to_email": "",
                "email_footer": "",
                "show_email_footer": "yes",
                "admin_email": "hello@fluentcart.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings saved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message",
                      "example": "Email settings saved successfully"
                    }
                  }
                },
                "example": {
                  "message": "Email settings saved successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Error message",
                      "example": "Subject field is required."
                    }
                  }
                },
                "example": {
                  "message": "From Name field is required."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UpdateEmailNotificationRequest": {
        "type": "object",
        "required": [
          "settings"
        ],
        "properties": {
          "settings": {
            "type": "object",
            "required": [
              "subject"
            ],
            "properties": {
              "active": {
                "type": "string",
                "enum": [
                  "yes",
                  "no"
                ],
                "description": "Whether the notification is active",
                "example": "yes"
              },
              "subject": {
                "type": "string",
                "maxLength": 255,
                "description": "Email subject template (required, may contain smart codes)",
                "example": "New Sales On {{settings.store_name}}"
              },
              "is_default_body": {
                "type": "string",
                "enum": [
                  "yes",
                  "no"
                ],
                "description": "Whether using default email body",
                "example": "yes"
              },
              "email_body": {
                "type": "string",
                "nullable": true,
                "description": "Custom email body (HTML allowed, required if is_default_body is 'no')",
                "example": ""
              }
            }
          }
        }
      },
      "UpdateEmailNotificationResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "Notification updated successfully"
          }
        }
      },
      "SaveEmailSettingsRequest": {
        "type": "object",
        "required": [
          "from_name",
          "from_email",
          "admin_email"
        ],
        "properties": {
          "from_name": {
            "type": "string",
            "maxLength": 255,
            "description": "Default from name (required)",
            "example": "Hello"
          },
          "from_email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "description": "Default from email address (required)",
            "example": "hello@fluentcart.com"
          },
          "reply_to_name": {
            "type": "string",
            "maxLength": 255,
            "nullable": true,
            "description": "Reply-to name",
            "example": ""
          },
          "reply_to_email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "nullable": true,
            "description": "Reply-to email address",
            "example": ""
          },
          "email_footer": {
            "type": "string",
            "nullable": true,
            "description": "Email footer text (HTML allowed)",
            "example": ""
          },
          "show_email_footer": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ],
            "nullable": true,
            "description": "Whether to show email footer",
            "example": "yes"
          },
          "admin_email": {
            "type": "string",
            "description": "Admin email address (required)",
            "example": "hello@fluentcart.com"
          }
        }
      },
      "SaveEmailSettingsResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "Email settings saved successfully"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message",
            "example": "Subject field is required."
          }
        }
      }
    }
  }
}