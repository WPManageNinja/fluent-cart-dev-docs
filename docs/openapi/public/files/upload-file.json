{
  "paths": {
    "/files/upload": {
      "post": {
        "operationId": "uploadFile",
        "summary": "POST Upload File",
        "description": "Upload a new file to the storage system. The file name will be automatically prefixed with a timestamp to ensure uniqueness.",
        "tags": [
          "Files"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadFileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message",
                      "example": "File Uploaded Successfully"
                    },
                    "path": {
                      "type": "string",
                      "description": "Uploaded file path (with timestamp prefix)",
                      "example": "product-image__fluent-cart__.1763112373.jpg"
                    },
                    "file": {
                      "type": "object",
                      "description": "File information",
                      "properties": {
                        "driver": {
                          "type": "string",
                          "description": "Storage driver used",
                          "example": "local"
                        },
                        "size": {
                          "type": "integer",
                          "description": "File size in bytes",
                          "example": 1024000
                        },
                        "name": {
                          "type": "string",
                          "description": "File name (with timestamp prefix)",
                          "example": "product-image__fluent-cart__.1763112373.jpg"
                        },
                        "bucket": {
                          "type": "string",
                          "description": "Storage bucket (empty for local driver)",
                          "example": ""
                        }
                      }
                    }
                  }
                },
                "example": {
                  "message": "File Uploaded Successfully",
                  "path": "product-image__fluent-cart__.1763112373.jpg",
                  "file": {
                    "driver": "local",
                    "size": 1024000,
                    "name": "product-image__fluent-cart__.1763112373.jpg",
                    "bucket": ""
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error or file empty",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Error message",
                      "example": "Failed To Upload File"
                    },
                    "additional": {
                      "type": "string",
                      "nullable": true,
                      "description": "Additional error information",
                      "example": "File is empty"
                    }
                  }
                },
                "examples": {
                  "validationError": {
                    "value": {
                      "message": "Name field is required"
                    }
                  },
                  "fileEmpty": {
                    "value": {
                      "message": "Failed To Upload File",
                      "additional": "File is empty"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UploadFileRequest": {
        "type": "object",
        "required": [
          "file",
          "name"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "The file to upload (required)"
          },
          "name": {
            "type": "string",
            "maxLength": 160,
            "description": "Custom file name without extension (required, max 160 characters). The extension will be automatically added from the uploaded file.",
            "example": "product-image"
          },
          "driver": {
            "type": "string",
            "description": "Storage driver to use (optional, default: local)",
            "example": "local"
          },
          "bucket": {
            "type": "string",
            "description": "Bucket/folder name (optional, for cloud storage drivers)",
            "example": "products"
          }
        }
      },
      "FileUploadResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "File Uploaded Successfully"
          },
          "path": {
            "type": "string",
            "description": "Uploaded file path (with timestamp prefix)",
            "example": "product-image__fluent-cart__.1763112373.jpg"
          },
          "file": {
            "type": "object",
            "description": "File information",
            "properties": {
              "driver": {
                "type": "string",
                "description": "Storage driver used",
                "example": "local"
              },
              "size": {
                "type": "integer",
                "description": "File size in bytes",
                "example": 1024000
              },
              "name": {
                "type": "string",
                "description": "File name (with timestamp prefix)",
                "example": "product-image__fluent-cart__.1763112373.jpg"
              },
              "bucket": {
                "type": "string",
                "description": "Storage bucket (empty for local driver)",
                "example": ""
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message",
            "example": "Failed To Upload File"
          },
          "additional": {
            "type": "string",
            "nullable": true,
            "description": "Additional error information",
            "example": "File is empty"
          }
        }
      }
    }
  }
}