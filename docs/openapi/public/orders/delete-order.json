{
  "paths": {
    "/orders/{order_id}": {
      "delete": {
        "operationId": "deleteOrder",
        "summary": "DELETE Delete Order",
        "description": "Delete an order.",
        "tags": ["Orders"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Order deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteOrderResponse"
                },
                "example": {
                  "message": "Order 7536300 deleted successfully",
                  "data": {
                    "order_id": 7536300,
                    "invoice_no": "INV-163762",
                    "status": "success"
                  },
                  "errors": []
                }
              }
            }
          },
          "400": {
            "description": "Bad request - order cannot be deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": "rest_invalid_param",
                  "message": "Order cannot be deleted",
                  "data": {
                    "order_id": 7536300,
                    "invoice_no": "INV-163762",
                    "status": "error",
                    "reason": "cannot_delete"
                  },
                  "errors": [
                    "Order cannot be deleted"
                  ]
                }
              }
            }
          }
        }
      },
      "DeleteOrderResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "Order 7536300 deleted successfully"
          },
          "data": {
            "type": "object",
            "properties": {
              "order_id": {
                "type": "integer",
                "description": "Deleted order ID",
                "example": 7536300
              },
              "invoice_no": {
                "type": "string",
                "description": "Invoice number",
                "example": "INV-163762"
              },
              "status": {
                "type": "string",
                "enum": ["success", "error"],
                "example": "success"
              }
            }
          },
          "errors": {
            "type": "array",
            "description": "Array of error messages (empty on success)",
            "items": {
              "type": "string"
            },
            "example": []
          }
        }
      }
    }
  }
}

