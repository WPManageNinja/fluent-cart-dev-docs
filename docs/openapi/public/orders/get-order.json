{
  "paths": {
    "/orders/{order_id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "GET Get Order Details",
        "description": "Retrieve detailed information about a specific order.",
        "tags": ["Orders"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Order ID",
            "example": 1
          },
          "uuid": {
            "type": "string",
            "description": "Unique order identifier",
            "example": "abc123"
          },
          "status": {
            "type": "string",
            "description": "Order status",
            "example": "completed"
          },
          "payment_status": {
            "type": "string",
            "description": "Payment status",
            "example": "paid"
          },
          "customer_id": {
            "type": "integer",
            "description": "Customer ID",
            "example": 123
          },
          "total_amount": {
            "type": "integer",
            "description": "Total amount in cents",
            "example": 5000
          },
          "currency": {
            "type": "string",
            "description": "Currency code",
            "example": "USD"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Order creation timestamp",
            "example": "2024-01-01T10:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Order last update timestamp",
            "example": "2024-01-01T11:00:00Z"
          },
          "customer": {
            "$ref": "#/components/schemas/Customer"
          },
          "order_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "product_id": {
            "type": "integer",
            "example": 456
          },
          "variation_id": {
            "type": "integer",
            "example": 789
          },
          "quantity": {
            "type": "integer",
            "example": 2
          },
          "price": {
            "type": "integer",
            "description": "Price in cents",
            "example": 2500
          },
          "product": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "title": {
                "type": "string"
              },
              "sku": {
                "type": "string"
              }
            }
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 123
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "customer@example.com"
          },
          "first_name": {
            "type": "string",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "example": "Doe"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "payment_method": {
            "type": "string",
            "example": "stripe"
          },
          "status": {
            "type": "string",
            "example": "succeeded"
          },
          "amount": {
            "type": "integer",
            "description": "Amount in cents",
            "example": 5000
          },
          "transaction_id": {
            "type": "string",
            "example": "txn_123456"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "order": {
                "$ref": "#/components/schemas/Order"
              }
            }
          }
        }
      }
    }
  }
}

