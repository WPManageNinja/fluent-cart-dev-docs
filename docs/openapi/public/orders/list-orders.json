{
  "paths": {
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "GET List Orders",
        "description": "Retrieve a paginated list of orders with optional filtering and searching.",
        "tags": ["Orders"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for pagination",
            "example": 1
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            },
            "description": "Number of items to return per page (max 100)",
            "example": 10
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query to filter orders",
            "required": false
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by order status",
            "required": false
          },
          {
            "name": "payment_status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by payment status",
            "required": false
          },
          {
            "name": "customer_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by customer ID",
            "required": false
          },
          {
            "name": "order_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Sort field",
            "example": "id"
          },
          {
            "name": "order_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["ASC", "DESC"],
              "default": "DESC"
            },
            "description": "Sort direction",
            "example": "DESC"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of orders.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderListResponse"
                },
                "example": {
                  "success": true,
                  "data": {
                    "orders": [
                      {
                        "id": 1,
                        "uuid": "abc123",
                        "status": "completed",
                        "payment_status": "paid",
                        "customer_id": 123,
                        "total_amount": 5000,
                        "currency": "USD",
                        "created_at": "2024-01-01T10:00:00Z"
                      }
                    ],
                    "pagination": {
                      "current_page": 1,
                      "per_page": 10,
                      "total": 100,
                      "total_pages": 10
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Order ID",
            "example": 1
          },
          "uuid": {
            "type": "string",
            "description": "Unique order identifier",
            "example": "abc123"
          },
          "status": {
            "type": "string",
            "description": "Order status",
            "example": "completed"
          },
          "payment_status": {
            "type": "string",
            "description": "Payment status",
            "example": "paid"
          },
          "customer_id": {
            "type": "integer",
            "description": "Customer ID",
            "example": 123
          },
          "total_amount": {
            "type": "integer",
            "description": "Total amount in cents",
            "example": 5000
          },
          "currency": {
            "type": "string",
            "description": "Currency code",
            "example": "USD"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Order creation timestamp",
            "example": "2024-01-01T10:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Order last update timestamp",
            "example": "2024-01-01T11:00:00Z"
          },
          "customer": {
            "$ref": "#/components/schemas/Customer"
          },
          "order_items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            }
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "product_id": {
            "type": "integer",
            "example": 456
          },
          "variation_id": {
            "type": "integer",
            "example": 789
          },
          "quantity": {
            "type": "integer",
            "example": 2
          },
          "price": {
            "type": "integer",
            "description": "Price in cents",
            "example": 2500
          },
          "product": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "title": {
                "type": "string"
              },
              "sku": {
                "type": "string"
              }
            }
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 123
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "customer@example.com"
          },
          "first_name": {
            "type": "string",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "example": "Doe"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "payment_method": {
            "type": "string",
            "example": "stripe"
          },
          "status": {
            "type": "string",
            "example": "succeeded"
          },
          "amount": {
            "type": "integer",
            "description": "Amount in cents",
            "example": 5000
          },
          "transaction_id": {
            "type": "string",
            "example": "txn_123456"
          }
        }
      },
      "OrderListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "orders": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Order"
                }
              },
              "pagination": {
                "type": "object",
                "properties": {
                  "current_page": {
                    "type": "integer"
                  },
                  "per_page": {
                    "type": "integer"
                  },
                  "total": {
                    "type": "integer"
                  },
                  "total_pages": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

