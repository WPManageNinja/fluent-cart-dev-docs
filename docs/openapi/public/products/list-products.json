{
  "paths": {
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "GET List Products",
        "description": "Retrieve a paginated list of products with optional filtering and searching.",
        "tags": ["Products"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["simple", "advanced"],
              "default": "simple"
            },
            "description": "Product filter type",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1
            },
            "description": "Number of products per page",
            "example": 10
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Current page number",
            "example": 1
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "ID"
            },
            "description": "Field to sort products by",
            "example": "ID"
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["ASC", "DESC"],
              "default": "DESC"
            },
            "description": "Sort order",
            "example": "DESC"
          },
          {
            "name": "with[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Related data to include (e.g., detail, variants, categories)",
            "required": false,
            "style": "form",
            "explode": true
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search keyword",
            "required": false
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["draft", "physical", "publish", "digital", "subscribable", "all"],
              "default": "all"
            },
            "description": "Current active view or context",
            "required": false
          },
          {
            "name": "user_tz",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "Asia/Dhaka"
            },
            "description": "User's timezone for GMT conversion",
            "required": false
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "json"
            },
            "description": "Advanced relation-based filters. Provide an array of rule objects as JSON string.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of products.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListResponse"
                },
                "example": {
                  "products": {
                    "current_page": 1,
                    "data": [
                      {
                        "ID": 74,
                        "post_title": "Zipper Hoodie",
                        "post_status": "publish",
                        "post_type": "fluent-products"
                      }
                    ],
                    "per_page": 10,
                    "total": 100,
                    "last_page": 10
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductListResponse": {
        "type": "object",
        "properties": {
          "products": {
            "type": "object",
            "properties": {
              "current_page": {
                "type": "integer",
                "description": "Current page number",
                "example": 1
              },
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Product"
                }
              },
              "first_page_url": {
                "type": "string",
                "format": "uri",
                "description": "URL to first page"
              },
              "from": {
                "type": "integer",
                "description": "Starting record number"
              },
              "last_page": {
                "type": "integer",
                "description": "Last page number"
              },
              "last_page_url": {
                "type": "string",
                "format": "uri",
                "description": "URL to last page"
              },
              "links": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PaginationLink"
                }
              },
              "next_page_url": {
                "type": "string",
                "format": "uri",
                "nullable": true,
                "description": "URL to next page"
              },
              "path": {
                "type": "string",
                "format": "uri",
                "description": "Base path"
              },
              "per_page": {
                "type": "integer",
                "description": "Items per page"
              },
              "prev_page_url": {
                "type": "string",
                "format": "uri",
                "nullable": true,
                "description": "URL to previous page"
              },
              "to": {
                "type": "integer",
                "description": "Ending record number"
              },
              "total": {
                "type": "integer",
                "description": "Total number of records"
              }
            }
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer",
            "description": "Product ID",
            "example": 74
          },
          "post_author": {
            "type": "string",
            "description": "Author ID",
            "example": "1"
          },
          "post_date": {
            "type": "string",
            "format": "date-time",
            "description": "Post creation date",
            "example": "2025-09-24 05:12:35"
          },
          "post_date_gmt": {
            "type": "string",
            "format": "date-time",
            "description": "Post creation date (GMT)",
            "example": "2025-09-24 05:12:35"
          },
          "post_content": {
            "type": "string",
            "description": "Product description",
            "example": "This stylish zipper hoodie is designed for versatility and comfort."
          },
          "post_title": {
            "type": "string",
            "description": "Product title",
            "example": "Zipper Hoodie"
          },
          "post_excerpt": {
            "type": "string",
            "description": "Product excerpt",
            "example": "A stylish zipper hoodie with modern detailing."
          },
          "post_status": {
            "type": "string",
            "enum": ["draft", "publish", "private"],
            "description": "Post status",
            "example": "publish"
          },
          "post_name": {
            "type": "string",
            "description": "Post slug",
            "example": "zipper-hoodie-24-09-2025-05:12:35"
          },
          "post_type": {
            "type": "string",
            "description": "Post type",
            "example": "fluent-products"
          },
          "view_url": {
            "type": "string",
            "format": "uri",
            "description": "Product view URL"
          },
          "edit_url": {
            "type": "string",
            "format": "uri",
            "description": "Product edit URL"
          },
          "detail": {
            "$ref": "#/components/schemas/ProductDetail"
          },
          "variants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductVariant"
            }
          }
        }
      },
      "ProductDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Product detail ID"
          },
          "post_id": {
            "type": "integer",
            "description": "Product post ID"
          },
          "fulfillment_type": {
            "type": "string",
            "enum": ["digital", "physical"],
            "description": "Fulfillment type"
          },
          "min_price": {
            "type": "integer",
            "description": "Minimum price in cents"
          },
          "max_price": {
            "type": "integer",
            "description": "Maximum price in cents"
          },
          "variation_type": {
            "type": "string",
            "enum": ["simple", "simple_variations"],
            "description": "Variation type"
          },
          "stock_availability": {
            "type": "string",
            "description": "Stock availability status"
          },
          "manage_stock": {
            "type": "string",
            "description": "Whether stock is managed"
          }
        }
      },
      "ProductVariant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Variant ID"
          },
          "post_id": {
            "type": "integer",
            "description": "Product post ID"
          },
          "variation_title": {
            "type": "string",
            "description": "Variant title"
          },
          "item_price": {
            "type": "integer",
            "description": "Price in cents"
          },
          "stock_status": {
            "type": "string",
            "description": "Stock status"
          }
        }
      },
      "PaginationLink": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "Link URL"
          },
          "label": {
            "type": "string",
            "description": "Link label"
          },
          "active": {
            "type": "boolean",
            "description": "Whether this is the active page"
          }
        }
      }
    }
  }
}

