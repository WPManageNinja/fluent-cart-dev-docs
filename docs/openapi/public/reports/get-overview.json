{
  "paths": {
    "/reports/overview": {
      "get": {
        "operationId": "getReportsOverview",
        "summary": "GET Get Reports Overview",
        "description": "Retrieve a comprehensive overview report with key metrics.",
        "tags": ["Reports"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object"
            },
            "description": "Report parameters object",
            "style": "deepObject",
            "explode": true
          },
          {
            "name": "params[startDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for the report (ISO 8601 format)",
            "example": "2024-01-01"
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for the report (ISO 8601 format)",
            "example": "2024-12-31"
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["daily", "monthly", "yearly"]
            },
            "description": "Grouping key (auto-determined if not provided)",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "description": "Report overview data"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

