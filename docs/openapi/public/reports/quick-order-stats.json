{
  "paths": {
    "/reports/quick-order-stats": {
      "get": {
        "operationId": "getQuickOrderStats",
        "summary": "GET Get Quick Order Stats",
        "description": "Retrieve quick statistics about orders. Note: This endpoint may have issues in some installations.",
        "tags": ["Reports"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "day_range",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["-0 days", "this_month", "all_time"],
              "default": "-0 days"
            },
            "description": "Date range",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "description": "Quick order statistics"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error - class not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Class \"FluentCart\\App\\Modules\\ReportingModule\\Status\" not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message",
            "example": "Class \"FluentCart\\App\\Modules\\ReportingModule\\Status\" not found"
          }
        }
      }
    }
  }
}
