{
  "paths": {
    "/reports/quick-order-stats": {
      "get": {
        "operationId": "getQuickOrderStats",
        "summary": "GET Get Quick Order Stats",
        "description": "Retrieve quick statistics about orders.",
        "tags": ["Reports"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "day_range",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["-0 days", "this_month", "all_time"],
              "default": "-0 days"
            },
            "description": "Date range",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "description": "Quick order statistics"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

