{
  "paths": {
    "/tax/classes": {
      "post": {
        "operationId": "createTaxClass",
        "summary": "POST Create Tax Class",
        "description": "Create a new tax class.",
        "tags": [
          "Tax"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Tax class title",
                    "example": "Reduced Rate"
                  },
                  "description": {
                    "type": "string",
                    "description": "Tax class description",
                    "required": false,
                    "example": "Reduced tax rate for essential goods"
                  },
                  "categories": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of product category IDs",
                    "required": false,
                    "example": [
                      1,
                      2
                    ]
                  },
                  "priority": {
                    "type": "integer",
                    "description": "Display priority (default: 0)",
                    "required": false,
                    "default": 0,
                    "example": 5
                  }
                }
              },
              "example": {
                "title": "Reduced Rate",
                "description": "Reduced tax rate for essential goods",
                "categories": [
                  1,
                  2
                ],
                "priority": 5
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tax class created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Tax class has been created successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateTaxClassRequest": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Tax class title",
            "example": "Reduced Rate"
          },
          "description": {
            "type": "string",
            "description": "Tax class description",
            "required": false,
            "example": "Reduced tax rate for essential goods"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Array of product category IDs",
            "required": false,
            "example": [
              1,
              2
            ]
          },
          "priority": {
            "type": "integer",
            "description": "Display priority (default: 0)",
            "required": false,
            "default": 0,
            "example": 5
          }
        }
      }
    }
  }
}