{
  "paths": {
    "/tax/classes": {
      "get": {
        "operationId": "listTaxClasses",
        "summary": "GET List Tax Classes",
        "description": "Retrieve all tax classes, sorted by priority.",
        "tags": [
          "Tax"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns all tax classes.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tax_classes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TaxClass"
                      }
                    }
                  }
                },
                "example": {
                  "tax_classes": [
                    {
                      "id": 7,
                      "title": "BD Standered",
                      "description": "",
                      "slug": "bd-standered",
                      "created_at": "2025-10-13T07:13:38+00:00",
                      "updated_at": "2025-10-13T10:22:34+00:00",
                      "meta": {
                        "priority": 10,
                        "categories": [
                          2,
                          3,
                          4
                        ]
                      },
                      "categories": [
                        2,
                        3,
                        4
                      ]
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaxClassListResponse": {
        "type": "object",
        "properties": {
          "tax_classes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaxClass"
            }
          }
        }
      },
      "TaxClass": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Tax class ID",
            "example": 7
          },
          "title": {
            "type": "string",
            "description": "Tax class title",
            "example": "BD Standered"
          },
          "slug": {
            "type": "string",
            "description": "Tax class slug",
            "example": "bd-standered"
          },
          "description": {
            "type": "string",
            "description": "Tax class description",
            "example": ""
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-10-13T07:13:38+00:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-10-13T10:22:34+00:00"
          },
          "meta": {
            "type": "object",
            "description": "Tax class metadata",
            "properties": {
              "priority": {
                "type": "integer",
                "description": "Display priority",
                "example": 10
              },
              "categories": {
                "type": "array",
                "items": {
                  "type": "integer"
                },
                "description": "Product category IDs",
                "example": [
                  2,
                  3,
                  4
                ]
              }
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Product category IDs",
            "example": [
              2,
              3,
              4
            ]
          }
        }
      }
    }
  }
}