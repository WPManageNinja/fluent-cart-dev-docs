{
  "paths": {
    "/customers": {
      "post": {
        "operationId": "createCustomer",
        "summary": "POST Create Customer",
        "description": "Create a new customer. The system will automatically split the full_name into first_name and last_name.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "full_name"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Customer email address (must be unique)",
                    "example": "newcustomer@example.com"
                  },
                  "full_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Customer's full name (max 255 characters)",
                    "example": "Jane Smith"
                  },
                  "city": {
                    "type": "string",
                    "description": "Customer's city",
                    "required": false
                  },
                  "status": {
                    "type": "string",
                    "description": "Customer status",
                    "required": false
                  },
                  "notes": {
                    "type": "string",
                    "description": "Customer notes",
                    "required": false
                  },
                  "country": {
                    "type": "string",
                    "description": "Customer's country",
                    "required": false
                  },
                  "state": {
                    "type": "string",
                    "description": "Customer's state",
                    "required": false
                  },
                  "postcode": {
                    "type": "string",
                    "description": "Customer's postal code",
                    "required": false
                  },
                  "user_id": {
                    "type": "integer",
                    "description": "WordPress user ID to attach",
                    "required": false
                  },
                  "wp_user": {
                    "type": "string",
                    "description": "Set to 'yes' to create WordPress user if email matches existing user",
                    "required": false
                  }
                }
              },
              "example": {
                "email": "newcustomer@example.com",
                "full_name": "Jane Smith",
                "city": "New York",
                "status": "active",
                "country": "US",
                "state": "NY",
                "postcode": "10001",
                "wp_user": "yes"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message",
                      "example": "Customer created successfully!"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Customer"
                    }
                  }
                },
                "example": {
                  "message": "Customer created successfully!",
                  "data": {
                    "id": 63212,
                    "email": "newcustomer@example.com",
                    "first_name": "Jane",
                    "last_name": "Smith",
                    "full_name": "Jane Smith",
                    "status": "active",
                    "city": "New York",
                    "country": "US",
                    "state": "NY",
                    "postcode": "10001",
                    "created_at": "2025-11-13T06:57:28+00:00",
                    "updated_at": "2025-11-13T06:57:28+00:00"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error, customer already exists, or creation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "alreadyExists": {
                    "value": {
                      "code": 400,
                      "message": "Customer already exists.",
                      "data": ""
                    }
                  },
                  "creationFailed": {
                    "value": {
                      "code": 400,
                      "message": "Customer creation failed.",
                      "data": ""
                    }
                  }
                }
              }
            }
          },
          "423": {
            "description": "Failed to create WordPress user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": 423,
                  "message": "Failed to create user.",
                  "data": ""
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateCustomerRequest": {
        "type": "object",
        "required": [
          "email",
          "full_name"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address (must be unique)",
            "example": "newcustomer@example.com"
          },
          "full_name": {
            "type": "string",
            "maxLength": 255,
            "description": "Customer's full name (max 255 characters)",
            "example": "Jane Smith"
          },
          "city": {
            "type": "string",
            "description": "Customer's city",
            "required": false
          },
          "status": {
            "type": "string",
            "description": "Customer status",
            "required": false
          },
          "notes": {
            "type": "string",
            "description": "Customer notes",
            "required": false
          },
          "country": {
            "type": "string",
            "description": "Customer's country",
            "required": false
          },
          "state": {
            "type": "string",
            "description": "Customer's state",
            "required": false
          },
          "postcode": {
            "type": "string",
            "description": "Customer's postal code",
            "required": false
          },
          "user_id": {
            "type": "integer",
            "description": "WordPress user ID to attach",
            "required": false
          },
          "wp_user": {
            "type": "string",
            "description": "Set to 'yes' to create WordPress user if email matches existing user",
            "required": false
          }
        }
      },
      "CustomerResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "Customer created successfully!"
          },
          "data": {
            "$ref": "#/components/schemas/Customer"
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Customer ID",
            "example": 63212
          },
          "user_id": {
            "type": "string",
            "nullable": true,
            "description": "WordPress user ID",
            "example": null
          },
          "contact_id": {
            "type": "string",
            "description": "Contact ID",
            "example": "0"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address",
            "example": "newcustomer@example.com"
          },
          "first_name": {
            "type": "string",
            "description": "Customer first name",
            "example": "Jane"
          },
          "last_name": {
            "type": "string",
            "description": "Customer last name",
            "example": "Smith"
          },
          "full_name": {
            "type": "string",
            "description": "Customer full name",
            "example": "Jane Smith"
          },
          "status": {
            "type": "string",
            "nullable": true,
            "description": "Customer status",
            "example": "active"
          },
          "purchase_value": {
            "type": "array",
            "description": "Purchase value array",
            "example": []
          },
          "purchase_count": {
            "type": "string",
            "description": "Number of purchases",
            "example": "0"
          },
          "ltv": {
            "type": "string",
            "description": "Lifetime value",
            "example": "0"
          },
          "first_purchase_date": {
            "type": "string",
            "nullable": true,
            "description": "First purchase date"
          },
          "last_purchase_date": {
            "type": "string",
            "nullable": true,
            "description": "Last purchase date"
          },
          "aov": {
            "type": "string",
            "nullable": true,
            "description": "Average order value"
          },
          "notes": {
            "type": "string",
            "description": "Customer notes",
            "example": ""
          },
          "uuid": {
            "type": "string",
            "description": "Customer UUID"
          },
          "country": {
            "type": "string",
            "nullable": true,
            "description": "Country code",
            "example": "US"
          },
          "city": {
            "type": "string",
            "nullable": true,
            "description": "City",
            "example": "New York"
          },
          "state": {
            "type": "string",
            "nullable": true,
            "description": "State",
            "example": "NY"
          },
          "postcode": {
            "type": "string",
            "nullable": true,
            "description": "Postal code",
            "example": "10001"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-11-13T06:57:28+00:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-11-13T06:57:28+00:00"
          }
        }
      }
    }
  }
}