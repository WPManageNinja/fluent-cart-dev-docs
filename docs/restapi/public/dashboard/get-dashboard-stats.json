{
  "paths": {
    "/dashboard/stats": {
      "get": {
        "operationId": "getDashboardStats",
        "summary": "GET Get Dashboard Stats",
        "description": "Retrieve dashboard statistics and widgets.",
        "tags": [
          "Dashboard"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stats": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/StatWidget"
                      }
                    }
                  }
                },
                "example": {
                  "stats": [
                    {
                      "title": "Total Products",
                      "current_count": "54",
                      "icon": "Frame",
                      "url": "https://YourWebsite.com/wp-admin/admin.php?page=fluent-cart#/products/?active_view=all"
                    },
                    {
                      "title": "Orders",
                      "current_count": "26",
                      "icon": "AllOrdersIcon",
                      "url": "https://YourWebsite.com/wp-admin/admin.php?page=fluent-cart#/orders"
                    },
                    {
                      "title": "Revenue",
                      "current_count": "2340.5000",
                      "icon": "Currency",
                      "url": "https://YourWebsite.com/wp-admin/admin.php?page=fluent-cart#/reports/revenue",
                      "has_currency": true
                    },
                    {
                      "title": "Refund",
                      "current_count": "0.0000",
                      "icon": "Failed",
                      "url": "https://YourWebsite.com/wp-admin/admin.php?page=fluent-cart#/reports/refunds",
                      "has_currency": true
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DashboardStatsResponse": {
        "type": "object",
        "properties": {
          "stats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StatWidget"
            }
          }
        }
      },
      "StatWidget": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Stat widget title",
            "example": "Total Products"
          },
          "current_count": {
            "type": "string",
            "description": "Stat value/count",
            "example": "54"
          },
          "icon": {
            "type": "string",
            "description": "Icon name",
            "example": "Frame"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to view details",
            "example": "https://YourWebsite.com/wp-admin/admin.php?page=fluent-cart#/products/?active_view=all"
          },
          "has_currency": {
            "type": "boolean",
            "description": "Whether the value is a currency amount",
            "example": true
          }
        }
      }
    }
  }
}