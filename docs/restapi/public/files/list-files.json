{
  "paths": {
    "/files": {
      "get": {
        "operationId": "listFiles",
        "summary": "GET List Files",
        "description": "Retrieve a list of uploaded files.",
        "tags": [
          "Files"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a list of files.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "files": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/File"
                      }
                    }
                  }
                },
                "example": {
                  "files": [
                    {
                      "name": "10000-assets.png.zip__fluent-cart__.1761039177.zip",
                      "size": 1345778,
                      "driver": "local",
                      "bucket": ""
                    },
                    {
                      "name": "2000-assets.png.zip__fluent-cart__.1761039120.zip",
                      "size": 1354215,
                      "driver": "local",
                      "bucket": ""
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FileListResponse": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/File"
            }
          }
        }
      },
      "File": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "File name",
            "example": "10000-assets.png.zip__fluent-cart__.1761039177.zip"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes",
            "example": 1345778
          },
          "driver": {
            "type": "string",
            "description": "Storage driver",
            "example": "local"
          },
          "bucket": {
            "type": "string",
            "description": "Storage bucket (empty for local driver)",
            "example": ""
          }
        }
      }
    }
  }
}