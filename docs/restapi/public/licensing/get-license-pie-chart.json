        "tags": ["Licensing"],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object"
            },
            "description": "Request parameters object containing filters and date range",
            "style": "deepObject",
            "explode": true
          },
          {
            "name": "params[startDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for the report (ISO 8601 format)",
            "example": "2024-01-01"
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for the report (ISO 8601 format)",
            "example": "2024-12-31"
          },
          {
            "name": "params[filters]",
            "in": "query",
            "schema": {
              "type": "object"
            },
            "description": "Filter criteria",
            "required": false,
            "style": "deepObject",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "License pie chart data"
                }
              }
            }
          }
        }
      }
    }
  }
}

