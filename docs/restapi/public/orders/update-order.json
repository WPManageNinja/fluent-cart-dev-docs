                    "description": "Coupon calculation data"
                  },
                  "trigger": {
                    "type": "string",
                    "description": "Trigger"
                  }
                }
              },
              "example": {
                "order_items": [
                  {
                    "id": 283870,
                    "order_id": 7536300,
                    "post_id": 7529088,
                    "variation_id": 59,
                    "quantity": 1,
                    "unit_price": 500,
                    "item_price": 500,
                    "item_cost": 0,
                    "item_total": 500,
                    "line_total": 500,
                    "tax_amount": 0,
                    "discount_total": 0,
                    "shipping_charge": 0,
                    "title": "Orange"
                  }
                ],
                "status": "processing",
                "note": "Updated order note",
                "total_amount": 500
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order updated successfully. Returns the updated order data.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Response contains the updated order data",
                  "properties": {
                    "order": {
                      "$ref": "#/components/schemas/OrderDetail"
                    },
                    "discount_meta": {
                      "type": "string"
                    },
                    "shipping_meta": {
                      "type": "string"
                    },
                    "order_settings": {
                      "type": "array"
                    },
                    "selected_labels": {
                      "type": "array"
                    },
                    "tax_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error, subscription order, or completed order status update",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "subscription": {
                    "value": {
                      "code": "rest_invalid_param",
                      "message": "Subscription Order cannot be edited.",
                      "data": {
                        "status": 400
                      }
                    }
                  },
                  "completed": {
                    "value": {
                      "code": "rest_invalid_param",
                      "message": "Completed status can not be updated",
                      "data": {
                        "status": 400
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
