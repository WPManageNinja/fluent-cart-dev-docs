                  },
                  "uuid": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Order UUID"
                  },
                  "ip_address": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Customer IP address"
                  },
                  "completed_at": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Completion timestamp"
                  },
                  "refunded_at": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Refund timestamp"
                  },
                  "discount": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string",
                        "maxLength": 100
                      },
                      "value": {
                        "type": "number"
                      },
                      "label": {
                        "type": "string",
                        "maxLength": 100
                      },
                      "reason": {
                        "type": "string",
                        "maxLength": 100
                      },
                      "action": {
                        "type": "string",
                        "maxLength": 100
                      }
                    }
                  },
                  "shipping": {
                    "type": "array",
