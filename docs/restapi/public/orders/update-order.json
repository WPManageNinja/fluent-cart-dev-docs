                          "minimum": 1
                        },
                        "order_id": {
                          "type": "integer",
                          "minimum": 1
                        },
                        "coupon_id": {
                          "type": "integer",
                          "minimum": 1
                        },
                        "code": {
                          "type": "string",
                          "maxLength": 100
                        },
                        "amount": {
                          "type": "number"
                        },
                        "discounted_amount": {
                          "type": "number"
                        },
                        "discount": {
                          "type": "number"
                        },
                        "stackable": {
                          "type": "integer"
                        },
                        "priority": {
                          "type": "integer"
                        },
                        "max_uses": {
                          "type": "integer"
                        },
                        "use_count": {
                          "type": "integer"
                        },
                        "max_per_customer": {
