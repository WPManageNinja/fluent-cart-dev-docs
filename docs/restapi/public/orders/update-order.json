{
  "paths": {
    "/orders/{order_id}": {
      "post": {
        "operationId": "updateOrder",
        "summary": "POST Update Order",
        "description": "Update an existing order's information. Note: Subscription orders cannot be edited. Completed orders cannot have their status updated.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "order_items"
                ],
                "properties": {
                  "order_items": {
                    "type": "array",
                    "description": "Array of order items (required). Include all existing items to keep them, or omit items to remove them.",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": [
                        "id",
                        "order_id",
                        "post_id",
                        "variation_id"
                      ],
                      "properties": {
                        "id": {
                          "type": "integer",
                          "minimum": 1,
                          "description": "Order item ID (required for updates)"
                        },
                        "order_id": {
                          "type": "integer",
                          "minimum": 1,
                          "description": "Order ID (required for updates)"
                        },
                        "post_id": {
                          "type": "integer",
                          "minimum": 1,
                          "description": "Product post ID (required)"
                        },
                        "variation_id": {
                          "type": "integer",
                          "minimum": 1,
                          "description": "Product variation ID (required)"
                        },
                        "type": {
                          "type": "string",
                          "maxLength": 100,
                          "description": "Item type"
                        },
                        "quantity": {
                          "type": "number",
                          "minimum": 1,
                          "description": "Quantity"
                        },
                        "title": {
                          "type": "string",
                          "maxLength": 255,
                          "description": "Item title"
                        },
                        "price": {
                          "type": "number",
                          "description": "Item price"
                        },
                        "unit_price": {
                          "type": "number",
                          "description": "Unit price"
                        },
                        "shipping_charge": {
                          "type": "number",
                          "description": "Shipping charge"
                        },
                        "item_cost": {
                          "type": "number",
                          "description": "Item cost"
                        },
                        "item_total": {
                          "type": "number",
                          "description": "Item total"
                        },
                        "tax_amount": {
                          "type": "number",
                          "description": "Tax amount"
                        },
                        "discount_total": {
                          "type": "number",
                          "description": "Discount total"
                        },
                        "total": {
                          "type": "number",
                          "description": "Total"
                        },
                        "line_total": {
                          "type": "number",
                          "description": "Line total"
                        },
                        "cart_index": {
                          "type": "integer",
                          "description": "Cart index"
                        },
                        "rate": {
                          "type": "number",
                          "description": "Exchange rate"
                        },
                        "line_meta": {
                          "type": "array",
                          "description": "Line metadata"
                        },
                        "other_info": {
                          "type": "object",
                          "description": "Additional item information"
                        }
                      }
                    }
                  },
                  "status": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Order status (cannot be 'completed' if updating)",
                    "example": "processing"
                  },
                  "invoice_no": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Invoice number"
                  },
                  "fulfillment_type": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Fulfillment type"
                  },
                  "type": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Order type"
                  },
                  "payment_method": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Payment method"
                  },
                  "payment_method_title": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Payment method title"
                  },
                  "payment_status": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Payment status"
                  },
                  "currency": {
                    "type": "string",
                    "maxLength": 10,
                    "description": "Currency code"
                  },
                  "subtotal": {
                    "type": "number",
                    "description": "Subtotal in cents"
                  },
                  "discount_tax": {
                    "type": "number",
                    "description": "Discount tax in cents"
                  },
                  "manual_discount_total": {
                    "type": "number",
                    "description": "Manual discount total in cents"
                  },
                  "coupon_discount_total": {
                    "type": "number",
                    "description": "Coupon discount total in cents"
                  },
                  "shipping_tax": {
                    "type": "number",
                    "description": "Shipping tax in cents"
                  },
                  "shipping_total": {
                    "type": "number",
                    "description": "Shipping total in cents"
                  },
                  "tax_total": {
                    "type": "number",
                    "description": "Tax total in cents"
                  },
                  "total_amount": {
                    "type": "number",
                    "description": "Total amount in cents"
                  },
                  "total_paid": {
                    "type": "number",
                    "description": "Total paid amount in cents"
                  },
                  "rate": {
                    "type": "number",
                    "description": "Exchange rate"
                  },
                  "note": {
                    "type": "string",
                    "maxLength": 5000,
                    "description": "Order notes",
