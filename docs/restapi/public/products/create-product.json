{
  "paths": {
    "/products": {
      "post": {
        "operationId": "createProduct",
        "summary": "POST Create Product",
        "description": "Create a new product.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "post_title",
                  "detail"
                ],
                "properties": {
                  "post_title": {
                    "type": "string",
                    "description": "Product title",
                    "example": "Dynamic Product"
                  },
                  "post_status": {
                    "type": "string",
                    "enum": [
                      "draft",
                      "publish",
                      "private"
                    ],
                    "default": "draft",
                    "description": "Post status",
                    "example": "draft"
                  },
                  "post_content": {
                    "type": "string",
                    "description": "Product description/content",
                    "required": false
                  },
                  "post_excerpt": {
                    "type": "string",
                    "description": "Product excerpt",
                    "required": false
                  },
                  "detail": {
                    "type": "object",
                    "required": [
                      "fulfillment_type"
                    ],
                    "properties": {
                      "fulfillment_type": {
                        "type": "string",
                        "enum": [
                          "digital",
                          "physical"
                        ],
                        "description": "Fulfillment type for the product",
                        "example": "digital"
                      },
                      "variation_type": {
                        "type": "string",
                        "enum": [
                          "simple",
                          "simple_variations"
                        ],
                        "description": "Variation type",
                        "required": false
                      },
                      "manage_stock": {
                        "type": "string",
                        "description": "Whether to manage stock",
                        "required": false
                      },
                      "stock_availability": {
                        "type": "string",
                        "description": "Stock availability status",
                        "required": false
                      }
                    }
                  }
                }
              },
              "example": {
                "post_title": "Dynamic Product",
                "post_status": "draft",
                "detail": {
                  "fulfillment_type": "digital"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "ID": {
                          "type": "integer",
                          "description": "Created product ID",
                          "example": 7529320
                        },
                        "variant": {
                          "type": "object",
                          "description": "Created product variant",
                          "properties": {
                            "id": {
                              "type": "integer",
                              "description": "Variant ID"
                            },
                            "post_id": {
                              "type": "integer",
                              "description": "Product post ID"
                            },
                            "variation_title": {
                              "type": "string",
                              "description": "Variant title"
                            },
                            "item_price": {
                              "type": "integer",
                              "description": "Item price in cents"
                            },
                            "stock_status": {
                              "type": "string",
                              "description": "Stock status",
                              "example": "in-stock"
                            },
                            "payment_type": {
                              "type": "string",
                              "description": "Payment type",
                              "example": "onetime"
                            }
                          }
                        },
                        "product_details": {
                          "type": "object",
                          "description": "Product details",
                          "properties": {
                            "id": {
                              "type": "integer",
                              "description": "Product detail ID"
                            },
                            "post_id": {
                              "type": "integer",
                              "description": "Product post ID"
                            },
                            "fulfillment_type": {
                              "type": "string",
                              "enum": [
                                "digital",
                                "physical"
                              ],
                              "description": "Fulfillment type"
                            }
                          }
                        }
                      }
                    },
                    "message": {
                      "type": "string",
                      "description": "Success message",
                      "example": "Product has been created successfully"
                    }
                  }
                },
                "example": {
                  "data": {
                    "ID": 7529320,
                    "variant": {
                      "id": 1,
                      "post_id": 7529320,
                      "variation_title": "Dynamic Product",
                      "item_price": 0,
                      "stock_status": "in-stock",
                      "payment_type": "onetime"
                    },
                    "product_details": {
                      "id": 1,
                      "post_id": 7529320,
                      "fulfillment_type": "digital"
                    }
                  },
                  "message": "Product has been created successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error or creation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": 400,
                  "message": "Product creation failed!"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateProductRequest": {
        "type": "object",
        "required": [
          "post_title",
          "detail"
        ],
        "properties": {
          "post_title": {
            "type": "string",
            "description": "Product title",
            "example": "Dynamic Product"
          },
          "post_status": {
            "type": "string",
            "enum": [
              "draft",
              "publish",
              "private"
            ],
            "default": "draft",
            "description": "Post status",
            "example": "draft"
          },
          "post_content": {
            "type": "string",
            "description": "Product description/content",
            "required": false
          },
          "post_excerpt": {
            "type": "string",
            "description": "Product excerpt",
            "required": false
          },
          "detail": {
            "$ref": "#/components/schemas/ProductDetailInput"
          }
        }
      },
      "ProductDetailInput": {
        "type": "object",
        "required": [
          "fulfillment_type"
        ],
        "properties": {
          "fulfillment_type": {
            "type": "string",
            "enum": [
              "digital",
              "physical"
            ],
            "description": "Fulfillment type for the product",
            "example": "digital"
          },
          "variation_type": {
            "type": "string",
            "enum": [
              "simple",
              "simple_variations"
            ],
            "description": "Variation type",
            "required": false
          },
          "manage_stock": {
            "type": "string",
            "description": "Whether to manage stock",
            "required": false
          },
          "stock_availability": {
            "type": "string",
            "description": "Stock availability status",
            "required": false
          }
        }
      },
      "CreateProductResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "ID": {
                "type": "integer",
                "description": "Created product ID",
                "example": 7529320
              },
              "variant": {
                "type": "object",
                "description": "Created product variant",
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "Variant ID"
                  },
                  "post_id": {
                    "type": "integer",
                    "description": "Product post ID"
                  },
                  "variation_title": {
                    "type": "string",
                    "description": "Variant title"
                  },
                  "item_price": {
                    "type": "integer",
                    "description": "Item price in cents"
                  },
                  "stock_status": {
                    "type": "string",
                    "description": "Stock status",
                    "example": "in-stock"
                  },
                  "payment_type": {
                    "type": "string",
                    "description": "Payment type",
                    "example": "onetime"
                  }
                }
              },
              "product_details": {
                "type": "object",
                "description": "Product details",
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "Product detail ID"
                  },
                  "post_id": {
                    "type": "integer",
                    "description": "Product post ID"
                  },
                  "fulfillment_type": {
                    "type": "string",
                    "enum": [
                      "digital",
                      "physical"
                    ],
                    "description": "Fulfillment type"
                  }
                }
              }
            }
          },
          "message": {
            "type": "string",
            "description": "Success message",
            "example": "Product has been created successfully"
          }
        }
      }
    }
  }
}