{
  "paths": {
    "/shipping/zones": {
      "get": {
        "operationId": "listShippingZones",
        "summary": "GET List Shipping Zones",
        "description": "Retrieve a paginated list of all shipping zones.",
        "tags": [
          "Shipping"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search term for filtering zones",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of items per page",
            "required": false
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of shipping zones.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "shipping_zones": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                },
                "example": {
                  "shipping_zones": {
                    "current_page": 1,
                    "data": [
                      {
                        "id": 4,
                        "name": "US",
                        "region": "US",
                        "order": "0",
                        "created_at": "2025-10-14T04:36:44+00:00",
                        "updated_at": "2025-10-14T04:36:44+00:00",
                        "formatted_region": "United States (US)"
                      }
                    ],
                    "first_page_url": "https://YourWebsite.com/wp-json/fluent-cart/v2/shipping/zones/?page=1",
                    "from": 1,
                    "last_page": 1,
                    "last_page_url": "https://YourWebsite.com/wp-json/fluent-cart/v2/shipping/zones/?page=1",
                    "links": [],
                    "next_page_url": null,
                    "path": "https://YourWebsite.com/wp-json/fluent-cart/v2/shipping/zones",
                    "per_page": 10,
                    "prev_page_url": null,
                    "to": 3,
                    "total": 3
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ShippingZoneListResponse": {
        "type": "object",
        "properties": {
          "shipping_zones": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "ShippingZone": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Shipping zone ID",
            "example": 4
          },
          "name": {
            "type": "string",
            "description": "Shipping zone name",
            "example": "US"
          },
          "region": {
            "type": "string",
            "description": "Region code",
            "example": "US"
          },
          "order": {
            "type": "string",
            "description": "Display order",
            "example": "0"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-10-14T04:36:44+00:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-10-14T04:36:44+00:00"
          },
          "formatted_region": {
            "type": "string",
            "description": "Formatted region name",
            "example": "United States (US)"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer",
            "example": 1
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShippingZone"
            }
          },
          "first_page_url": {
            "type": "string",
            "example": "https://YourWebsite.com/wp-json/fluent-cart/v2/shipping/zones/?page=1"
          },
          "from": {
            "type": "integer",
            "example": 1
          },
          "last_page": {
            "type": "integer",
            "example": 1
          },
          "last_page_url": {
            "type": "string",
            "example": "https://YourWebsite.com/wp-json/fluent-cart/v2/shipping/zones/?page=1"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "nullable": true
                },
                "label": {
                  "type": "string"
                },
                "active": {
                  "type": "boolean"
                }
              }
            }
          },
          "next_page_url": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "path": {
            "type": "string",
            "example": "https://YourWebsite.com/wp-json/fluent-cart/v2/shipping/zones"
          },
          "per_page": {
            "type": "integer",
            "example": 10
          },
          "prev_page_url": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "to": {
            "type": "integer",
            "example": 3
          },
          "total": {
            "type": "integer",
            "example": 3
          }
        }
      }
    }
  }
}