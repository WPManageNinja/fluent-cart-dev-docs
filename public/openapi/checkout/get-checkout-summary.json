{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/checkout/get-checkout-summary-view": {
      "get": {
        "operationId": "getCheckoutSummary",
        "summary": "GET Get Checkout Summary",
        "description": "Retrieve a rendered HTML summary of the current cart along with pricing totals. Used to dynamically update the checkout page when the customer changes shipping methods or other options.",
        "tags": [
          "Checkout"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "shipping_method_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "ID of the selected shipping method to include its charge in the totals",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns cart summary with pricing totals.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "object",
                      "description": "Cart summary data",
                      "properties": {
                        "views": {
                          "type": "string",
                          "description": "Server-rendered HTML of the cart item list for the checkout page"
                        },
                        "subtotal": {
                          "type": "string",
                          "description": "Formatted subtotal of all cart items (before shipping)"
                        },
                        "has_subscriptions": {
                          "type": "boolean",
                          "description": "Whether the cart contains subscription products"
                        },
                        "shipping_charge": {
                          "type": "integer",
                          "description": "Shipping charge in cents"
                        },
                        "unformatted_total": {
                          "type": "integer",
                          "description": "Grand total in cents (subtotal + shipping)"
                        },
                        "total": {
                          "type": "string",
                          "description": "Formatted grand total string"
                        },
                        "shipping_charge_formated": {
                          "type": "string",
                          "description": "Formatted shipping charge string"
                        },
                        "shipping_method_id": {
                          "type": "string",
                          "description": "The shipping method ID used for calculation"
                        }
                      }
                    }
                  },
                  "example": {
                    "items": {
                      "views": "<div class=\"fct-checkout-items\">...rendered HTML...</div>",
                      "subtotal": "$50.00",
                      "has_subscriptions": false,
                      "shipping_charge": 500,
                      "unformatted_total": 5500,
                      "total": "$55.00",
                      "shipping_charge_formated": "$5.00",
                      "shipping_method_id": "3"
                    }
                  }
                },
                "example": {
                  "items": {
                    "views": "<div class=\"fct-checkout-items\">...rendered HTML...</div>",
                    "subtotal": "$50.00",
                    "has_subscriptions": false,
                    "shipping_charge": 500,
                    "unformatted_total": 5500,
                    "total": "$55.00",
                    "shipping_charge_formated": "$5.00",
                    "shipping_method_id": "3"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
