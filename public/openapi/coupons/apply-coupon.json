{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/coupons/apply": {
      "post": {
        "operationId": "applyCoupon",
        "summary": "POST Apply Coupon",
        "description": "Apply a coupon code to a set of order line items. This endpoint validates the coupon, checks eligibility for each line item, and returns the recalculated discount breakdown.",
        "tags": [
          "Coupons"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "coupon_code",
                  "order_items"
                ],
                "properties": {
                  "coupon_code": {
                    "type": "string",
                    "description": "The coupon code to apply"
                  },
                  "order_items": {
                    "type": "array",
                    "description": "Array of order line item objects",
                    "items": {
                      "$ref": "#/components/schemas/OrderItem"
                    }
                  },
                  "order_uuid": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "UUID of an existing order to apply the coupon to. When provided, previously applied coupons from the order are included."
                  },
                  "applied_coupons": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of coupon IDs that are already applied (but not yet persisted to the order)"
                  },
                  "customer_email": {
                    "type": "string",
                    "format": "email",
                    "description": "Customer email for email-based coupon restrictions"
                  }
                },
                "example": {
                  "coupon_code": "WELCOME20",
                  "order_items": [
                    {
                      "post_id": 123,
                      "quantity": 1,
                      "price": 9900,
                      "unit_price": 9900,
                      "item_total": 9900,
                      "line_total": 9900,
                      "other_info": {
                        "payment_type": "onetime"
                      }
                    }
                  ],
                  "applied_coupons": [],
                  "customer_email": "sarah.johnson@example.com"
                }
              },
              "example": {
                "coupon_code": "WELCOME20",
                "order_items": [
                  {
                    "post_id": 123,
                    "quantity": 1,
                    "price": 9900,
                    "unit_price": 9900,
                    "item_total": 9900,
                    "line_total": 9900,
                    "other_info": {
                      "payment_type": "onetime"
                    }
                  }
                ],
                "applied_coupons": [],
                "customer_email": "sarah.johnson@example.com"
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "coupon_code": "WELCOME20",
                    "order_items": [
                      {
                        "post_id": 123,
                        "quantity": 1,
                        "price": 9900,
                        "unit_price": 9900,
                        "item_total": 9900,
                        "line_total": 9900,
                        "other_info": {
                          "payment_type": "onetime"
                        }
                      }
                    ],
                    "applied_coupons": [],
                    "customer_email": "sarah.johnson@example.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon applied successfully. Returns the applied coupons and recalculated items.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "applied_coupons": {
                      "type": "object",
                      "description": "Map of coupon codes to their applied details",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/AppliedCoupon"
                      }
                    },
                    "calculated_items": {
                      "type": "array",
                      "description": "Recalculated order items with discounts",
                      "items": {
                        "$ref": "#/components/schemas/CalculatedItem"
                      }
                    }
                  },
                  "example": {
                    "applied_coupons": {
                      "WELCOME20": {
                        "id": 3,
                        "title": "Welcome Discount",
                        "code": "WELCOME20",
                        "type": "percent",
                        "amount": 20,
                        "discount_amount": 1980,
                        "stackable": "no",
                        "priority": 10
                      }
                    },
                    "calculated_items": [
                      {
                        "post_id": 123,
                        "quantity": 1,
                        "price": 9900,
                        "discounted_price": 7920,
                        "discount_total": 1980
                      }
                    ]
                  }
                },
                "example": {
                  "applied_coupons": {
                    "WELCOME20": {
                      "id": 3,
                      "title": "Welcome Discount",
                      "code": "WELCOME20",
                      "type": "percent",
                      "amount": 20,
                      "discount_amount": 1980,
                      "stackable": "no",
                      "priority": 10
                    }
                  },
                  "calculated_items": [
                    {
                      "post_id": 123,
                      "quantity": 1,
                      "price": 9900,
                      "discounted_price": 7920,
                      "discount_total": 1980
                    }
                  ]
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "applied_coupons": {
                        "WELCOME20": {
                          "id": 3,
                          "title": "Welcome Discount",
                          "code": "WELCOME20",
                          "type": "percent",
                          "amount": 20,
                          "discount_amount": 1980,
                          "stackable": "no",
                          "priority": 10
                        }
                      },
                      "calculated_items": [
                        {
                          "post_id": 123,
                          "quantity": 1,
                          "price": 9900,
                          "discounted_price": 7920,
                          "discount_total": 1980
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrderItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "description": "Line item ID (for existing orders)"
          },
          "order_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Parent order ID"
          },
          "post_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Product post ID"
          },
          "variation_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Variation ID"
          },
          "type": {
            "type": "string",
            "maxLength": 100,
            "description": "Item type"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Item quantity"
          },
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "Item title"
          },
          "price": {
            "type": "number",
            "description": "Item price in cents"
          },
          "unit_price": {
            "type": "number",
            "description": "Unit price in cents"
          },
          "item_cost": {
            "type": "number",
            "description": "Item cost in cents"
          },
          "item_total": {
            "type": "number",
            "description": "Item total in cents"
          },
          "tax_amount": {
            "type": "number",
            "description": "Tax amount in cents"
          },
          "discount_total": {
            "type": "number",
            "description": "Discount total in cents"
          },
          "total": {
            "type": "number",
            "description": "Total in cents"
          },
          "line_total": {
            "type": "number",
            "description": "Line total in cents"
          },
          "cart_index": {
            "type": "integer",
            "description": "Position in cart"
          },
          "rate": {
            "type": "number",
            "description": "Tax rate"
          },
          "line_meta": {
            "type": "string",
            "description": "Line item metadata"
          },
          "other_info": {
            "type": "object",
            "description": "Additional item info (e.g., payment_type, manage_setup_fee, signup_fee)"
          }
        }
      },
      "AppliedCoupon": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Coupon ID"
          },
          "title": {
            "type": "string",
            "description": "Coupon title"
          },
          "code": {
            "type": "string",
            "description": "Coupon code"
          },
          "type": {
            "type": "string",
            "description": "Discount type"
          },
          "amount": {
            "type": "number",
            "description": "Discount amount"
          },
          "discount_amount": {
            "type": "number",
            "description": "Calculated discount amount in cents"
          },
          "stackable": {
            "type": "string",
            "description": "Whether coupon is stackable"
          },
          "priority": {
            "type": "integer",
            "description": "Coupon priority"
          }
        }
      },
      "CalculatedItem": {
        "type": "object",
        "properties": {
          "post_id": {
            "type": "integer",
            "description": "Product post ID"
          },
          "quantity": {
            "type": "integer",
            "description": "Item quantity"
          },
          "price": {
            "type": "number",
            "description": "Original price in cents"
          },
          "discounted_price": {
            "type": "number",
            "description": "Price after discount in cents"
          },
          "discount_total": {
            "type": "number",
            "description": "Total discount amount in cents"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
