{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/coupons/cancel": {
      "post": {
        "operationId": "cancelCoupon",
        "summary": "POST Cancel Coupon",
        "description": "Remove a coupon from an order and recalculate the remaining discounts. If an order_uuid is provided and the coupon was already persisted to the order, it is deleted from the fct_applied_coupons table and the coupon's use_count is decremented.",
        "tags": [
          "Coupons"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "coupon_code",
                  "order_items"
                ],
                "properties": {
                  "coupon_code": {
                    "type": "string",
                    "description": "The coupon code to cancel"
                  },
                  "order_items": {
                    "type": "array",
                    "description": "Array of current order line item objects",
                    "items": {
                      "$ref": "#/components/schemas/OrderItem"
                    }
                  },
                  "id": {
                    "type": "integer",
                    "description": "The applied coupon record ID (from fct_applied_coupons). Required to delete the persisted record from an existing order."
                  },
                  "order_uuid": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "UUID of the existing order"
                  },
                  "applied_coupons": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of remaining coupon IDs that should stay applied"
                  },
                  "customer_email": {
                    "type": "string",
                    "format": "email",
                    "description": "Customer email address"
                  }
                },
                "example": {
                  "coupon_code": "WELCOME20",
                  "id": 9,
                  "order_uuid": "e7b3a1d4-5f2c-48e9-a6b1-c3d4e5f67890",
                  "order_items": [
                    {
                      "post_id": 123,
                      "quantity": 1,
                      "price": 9900,
                      "unit_price": 9900,
                      "item_total": 9900,
                      "line_total": 9900
                    }
                  ],
                  "applied_coupons": [
                    5
                  ]
                }
              },
              "example": {
                "coupon_code": "WELCOME20",
                "id": 9,
                "order_uuid": "e7b3a1d4-5f2c-48e9-a6b1-c3d4e5f67890",
                "order_items": [
                  {
                    "post_id": 123,
                    "quantity": 1,
                    "price": 9900,
                    "unit_price": 9900,
                    "item_total": 9900,
                    "line_total": 9900
                  }
                ],
                "applied_coupons": [
                  5
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon cancelled successfully. Returns remaining applied coupons and recalculated items.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "applied_coupons": {
                      "type": "object",
                      "description": "Map of remaining coupon codes to their applied details",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/AppliedCoupon"
                      }
                    },
                    "calculated_items": {
                      "type": "array",
                      "description": "Recalculated order items with remaining discounts",
                      "items": {
                        "$ref": "#/components/schemas/CalculatedItem"
                      }
                    }
                  },
                  "example": {
                    "applied_coupons": {
                      "SUMMER15": {
                        "id": 5,
                        "title": "Summer Sale 15%",
                        "code": "SUMMER15",
                        "type": "percent",
                        "amount": 15,
                        "discount_amount": 1485,
                        "stackable": "yes",
                        "priority": 5
                      }
                    },
                    "calculated_items": [
                      {
                        "post_id": 123,
                        "quantity": 1,
                        "price": 9900,
                        "discounted_price": 8415,
                        "discount_total": 1485
                      }
                    ]
                  }
                },
                "example": {
                  "applied_coupons": {
                    "SUMMER15": {
                      "id": 5,
                      "title": "Summer Sale 15%",
                      "code": "SUMMER15",
                      "type": "percent",
                      "amount": 15,
                      "discount_amount": 1485,
                      "stackable": "yes",
                      "priority": 5
                    }
                  },
                  "calculated_items": [
                    {
                      "post_id": 123,
                      "quantity": 1,
                      "price": 9900,
                      "discounted_price": 8415,
                      "discount_total": 1485
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrderItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "description": "Line item ID"
          },
          "order_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Parent order ID"
          },
          "post_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Product post ID"
          },
          "variation_id": {
            "type": "integer",
            "minimum": 1,
            "description": "Variation ID"
          },
          "type": {
            "type": "string",
            "maxLength": 100,
            "description": "Item type"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Item quantity"
          },
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "Item title"
          },
          "price": {
            "type": "number",
            "description": "Item price in cents"
          },
          "unit_price": {
            "type": "number",
            "description": "Unit price in cents"
          },
          "item_total": {
            "type": "number",
            "description": "Item total in cents"
          },
          "line_total": {
            "type": "number",
            "description": "Line total in cents"
          },
          "other_info": {
            "type": "object",
            "description": "Additional item info"
          }
        }
      },
      "AppliedCoupon": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Coupon ID"
          },
          "title": {
            "type": "string",
            "description": "Coupon title"
          },
          "code": {
            "type": "string",
            "description": "Coupon code"
          },
          "type": {
            "type": "string",
            "description": "Discount type"
          },
          "amount": {
            "type": "number",
            "description": "Discount amount"
          },
          "discount_amount": {
            "type": "number",
            "description": "Calculated discount amount in cents"
          },
          "stackable": {
            "type": "string",
            "description": "Whether coupon is stackable"
          },
          "priority": {
            "type": "integer",
            "description": "Coupon priority"
          }
        }
      },
      "CalculatedItem": {
        "type": "object",
        "properties": {
          "post_id": {
            "type": "integer",
            "description": "Product post ID"
          },
          "quantity": {
            "type": "integer",
            "description": "Item quantity"
          },
          "price": {
            "type": "number",
            "description": "Original price in cents"
          },
          "discounted_price": {
            "type": "number",
            "description": "Price after discount in cents"
          },
          "discount_total": {
            "type": "number",
            "description": "Total discount amount in cents"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
