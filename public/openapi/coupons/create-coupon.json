{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/coupons": {
      "post": {
        "operationId": "createCoupon",
        "summary": "POST Create Coupon",
        "description": "Create a new discount coupon.",
        "tags": [
          "Coupons"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "code",
                  "type",
                  "amount",
                  "status",
                  "stackable",
                  "show_on_checkout"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "maxLength": 200,
                    "description": "Coupon display name"
                  },
                  "code": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Unique coupon code. Must be unique across all coupons."
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "fixed",
                      "percentage",
                      "free_shipping",
                      "buy_x_get_y"
                    ],
                    "description": "Discount type"
                  },
                  "amount": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Discount amount. For percentage: value 0-100. For fixed: amount in store currency (auto-converted to cents)."
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "expired",
                      "disabled",
                      "scheduled"
                    ],
                    "description": "Coupon status"
                  },
                  "stackable": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "maxLength": 50,
                    "description": "Whether coupon can be combined with others"
                  },
                  "show_on_checkout": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "maxLength": 50,
                    "description": "Whether to display the coupon on checkout"
                  },
                  "priority": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Sort priority for discount calculation order. Lower numbers are applied first."
                  },
                  "notes": {
                    "type": "string",
                    "description": "Internal notes about the coupon"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Start date in any parseable datetime format. Required if end_date is provided. Automatically converted to GMT."
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date-time",
                    "description": "End date in any parseable datetime format. Must be after start_date."
                  },
                  "conditions": {
                    "type": "object",
                    "description": "Coupon conditions and restrictions",
                    "properties": {
                      "min_purchase_amount": {
                        "type": "number",
                        "description": "Minimum purchase amount in store currency (auto-converted to cents)"
                      },
                      "max_discount_amount": {
                        "type": "number",
                        "description": "Maximum discount cap in store currency (auto-converted to cents)"
                      },
                      "max_purchase_amount": {
                        "type": "number",
                        "description": "Maximum purchase amount allowed"
                      },
                      "apply_to_whole_cart": {
                        "type": "string",
                        "enum": [
                          "yes",
                          "no"
                        ],
                        "description": "Apply discount to the entire cart"
                      },
                      "apply_to_quantity": {
                        "type": "string",
                        "enum": [
                          "yes",
                          "no"
                        ],
                        "description": "Apply discount per quantity"
                      },
                      "max_uses": {
                        "type": "integer",
                        "description": "Maximum total uses across all customers. Must be >= max_per_customer."
                      },
                      "max_per_customer": {
                        "type": "integer",
                        "description": "Maximum uses per individual customer"
                      },
                      "included_products": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "Product IDs the coupon is limited to"
                      },
                      "excluded_products": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "Product IDs excluded from the coupon"
                      },
                      "included_categories": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "Category IDs the coupon is limited to"
                      },
                      "excluded_categories": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "Category IDs excluded from the coupon"
                      },
                      "email_restrictions": {
                        "type": "string",
                        "description": "Email-based restriction"
                      },
                      "is_recurring": {
                        "type": "string",
                        "enum": [
                          "yes",
                          "no"
                        ],
                        "description": "Whether the coupon applies to subscription renewals"
                      },
                      "buy_products": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "Product IDs for the buy part of buy-x-get-y coupons"
                      },
                      "get_products": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "Product IDs for the get part of buy-x-get-y coupons"
                      }
                    }
                  }
                },
                "example": {
                  "title": "Summer Sale 20%",
                  "code": "SUMMER20",
                  "type": "percentage",
                  "amount": 20,
                  "status": "active",
                  "stackable": "yes",
                  "show_on_checkout": "yes",
                  "priority": 1,
                  "start_date": "2025-06-01 00:00:00",
                  "end_date": "2025-08-31 23:59:59",
                  "conditions": {
                    "min_purchase_amount": 20.0,
                    "max_discount_amount": 50.0,
                    "max_uses": 500,
                    "max_per_customer": 2,
                    "apply_to_whole_cart": "yes",
                    "is_recurring": "no"
                  }
                }
              },
              "example": {
                "title": "Summer Sale 20%",
                "code": "SUMMER20",
                "type": "percentage",
                "amount": 20,
                "status": "active",
                "stackable": "yes",
                "show_on_checkout": "yes",
                "priority": 1,
                "start_date": "2025-06-01 00:00:00",
                "end_date": "2025-08-31 23:59:59",
                "conditions": {
                  "min_purchase_amount": 20.0,
                  "max_discount_amount": 50.0,
                  "max_uses": 500,
                  "max_per_customer": 2,
                  "apply_to_whole_cart": "yes",
                  "is_recurring": "no"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Coupon created successfully!"
                    },
                    "data": {
                      "type": "object",
                      "description": "The created coupon object"
                    }
                  },
                  "example": {
                    "message": "Coupon created successfully!",
                    "data": {
                      "id": 7,
                      "parent": null,
                      "title": "Summer Sale 20%",
                      "code": "SUMMER20",
                      "status": "active",
                      "type": "percent",
                      "conditions": {
                        "min_purchase_amount": 2000,
                        "max_discount_amount": 5000,
                        "max_purchase_amount": 0,
                        "apply_to_whole_cart": "yes",
                        "apply_to_quantity": "no",
                        "max_uses": 500,
                        "max_per_customer": 2,
                        "excluded_categories": [],
                        "included_categories": [],
                        "excluded_products": [],
                        "included_products": [],
                        "email_restrictions": "",
                        "is_recurring": "no"
                      },
                      "amount": 20,
                      "stackable": "yes",
                      "priority": 1,
                      "use_count": 0,
                      "notes": "Summer promotional campaign - limited to new signups",
                      "show_on_checkout": "yes",
                      "start_date": "2025-06-01 00:00:00",
                      "end_date": "2025-08-31 23:59:59",
                      "created_at": "2025-05-25 10:00:00",
                      "updated_at": "2025-05-25 10:00:00"
                    }
                  }
                },
                "example": {
                  "message": "Coupon created successfully!",
                  "data": {
                    "id": 7,
                    "parent": null,
                    "title": "Summer Sale 20%",
                    "code": "SUMMER20",
                    "status": "active",
                    "type": "percent",
                    "conditions": {
                      "min_purchase_amount": 2000,
                      "max_discount_amount": 5000,
                      "max_purchase_amount": 0,
                      "apply_to_whole_cart": "yes",
                      "apply_to_quantity": "no",
                      "max_uses": 500,
                      "max_per_customer": 2,
                      "excluded_categories": [],
                      "included_categories": [],
                      "excluded_products": [],
                      "included_products": [],
                      "email_restrictions": "",
                      "is_recurring": "no"
                    },
                    "amount": 20,
                    "stackable": "yes",
                    "priority": 1,
                    "use_count": 0,
                    "notes": "Summer promotional campaign - limited to new signups",
                    "show_on_checkout": "yes",
                    "start_date": "2025-06-01 00:00:00",
                    "end_date": "2025-08-31 23:59:59",
                    "created_at": "2025-05-25 10:00:00",
                    "updated_at": "2025-05-25 10:00:00"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "object"
                    }
                  },
                  "example": {
                    "message": "The given data was invalid.",
                    "errors": {
                      "code": [
                        "The code field is required."
                      ],
                      "type": [
                        "The type field is required."
                      ],
                      "amount": [
                        "The amount field is required."
                      ]
                    }
                  }
                },
                "example": {
                  "message": "The given data was invalid.",
                  "errors": {
                    "code": [
                      "The code field is required."
                    ],
                    "type": [
                      "The type field is required."
                    ],
                    "amount": [
                      "The amount field is required."
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
