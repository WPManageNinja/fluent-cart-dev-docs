{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/coupons/{id}": {
      "get": {
        "operationId": "getCoupon",
        "summary": "GET Coupon Details",
        "description": "Retrieve detailed information about a specific coupon, including its activity log. The coupon status is automatically updated to expired if its end_date has passed.",
        "tags": [
          "Coupons"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The coupon ID",
            "example": 3
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns the coupon details with activity log.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "coupon": {
                      "$ref": "#/components/schemas/CouponDetail"
                    }
                  },
                  "example": {
                    "coupon": {
                      "id": 3,
                      "parent": null,
                      "title": "Welcome Discount",
                      "code": "WELCOME20",
                      "status": "active",
                      "type": "percent",
                      "conditions": {
                        "min_purchase_amount": 2000,
                        "max_discount_amount": 10000,
                        "max_purchase_amount": 0,
                        "apply_to_whole_cart": "no",
                        "apply_to_quantity": "no",
                        "max_uses": 500,
                        "max_per_customer": 1,
                        "excluded_categories": [],
                        "included_categories": [],
                        "excluded_products": [],
                        "included_products": [],
                        "email_restrictions": "",
                        "is_recurring": "no"
                      },
                      "amount": 20,
                      "stackable": "no",
                      "priority": 10,
                      "use_count": 47,
                      "notes": "20% off for new customers",
                      "show_on_checkout": "yes",
                      "start_date": "2025-01-01 00:00:00",
                      "end_date": "2025-12-31 23:59:59",
                      "created_at": "2025-01-01 10:00:00",
                      "updated_at": "2025-09-15 08:30:00",
                      "activities": [
                        {
                          "id": 8,
                          "title": "Coupon Created",
                          "content": "Coupon \"WELCOME20\" created by Admin",
                          "status": "success",
                          "user_id": 1,
                          "created_at": "2025-01-01 10:00:00",
                          "user": {
                            "ID": 1,
                            "display_name": "Admin"
                          }
                        },
                        {
                          "id": 24,
                          "title": "Coupon Updated",
                          "content": "Coupon \"WELCOME20\" updated - max uses changed from 200 to 500",
                          "status": "info",
                          "user_id": 1,
                          "created_at": "2025-06-10 11:15:00",
                          "user": {
                            "ID": 1,
                            "display_name": "Admin"
                          }
                        }
                      ]
                    }
                  }
                },
                "example": {
                  "coupon": {
                    "id": 3,
                    "parent": null,
                    "title": "Welcome Discount",
                    "code": "WELCOME20",
                    "status": "active",
                    "type": "percent",
                    "conditions": {
                      "min_purchase_amount": 2000,
                      "max_discount_amount": 10000,
                      "max_purchase_amount": 0,
                      "apply_to_whole_cart": "no",
                      "apply_to_quantity": "no",
                      "max_uses": 500,
                      "max_per_customer": 1,
                      "excluded_categories": [],
                      "included_categories": [],
                      "excluded_products": [],
                      "included_products": [],
                      "email_restrictions": "",
                      "is_recurring": "no"
                    },
                    "amount": 20,
                    "stackable": "no",
                    "priority": 10,
                    "use_count": 47,
                    "notes": "20% off for new customers",
                    "show_on_checkout": "yes",
                    "start_date": "2025-01-01 00:00:00",
                    "end_date": "2025-12-31 23:59:59",
                    "created_at": "2025-01-01 10:00:00",
                    "updated_at": "2025-09-15 08:30:00",
                    "activities": [
                      {
                        "id": 8,
                        "title": "Coupon Created",
                        "content": "Coupon \"WELCOME20\" created by Admin",
                        "status": "success",
                        "user_id": 1,
                        "created_at": "2025-01-01 10:00:00",
                        "user": {
                          "ID": 1,
                          "display_name": "Admin"
                        }
                      },
                      {
                        "id": 24,
                        "title": "Coupon Updated",
                        "content": "Coupon \"WELCOME20\" updated - max uses changed from 200 to 500",
                        "status": "info",
                        "user_id": 1,
                        "created_at": "2025-06-10 11:15:00",
                        "user": {
                          "ID": 1,
                          "display_name": "Admin"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CouponDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Coupon ID",
            "example": 3
          },
          "parent": {
            "type": "integer",
            "nullable": true,
            "description": "Parent coupon ID"
          },
          "title": {
            "type": "string",
            "description": "Coupon display name",
            "example": "Welcome Discount"
          },
          "code": {
            "type": "string",
            "description": "Unique coupon code",
            "example": "WELCOME20"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "expired",
              "disabled",
              "scheduled"
            ],
            "description": "Coupon status",
            "example": "active"
          },
          "type": {
            "type": "string",
            "enum": [
              "fixed",
              "percentage",
              "free_shipping",
              "buy_x_get_y"
            ],
            "description": "Discount type",
            "example": "percent"
          },
          "conditions": {
            "type": "object",
            "description": "Coupon conditions and restrictions"
          },
          "amount": {
            "type": "number",
            "description": "Discount amount",
            "example": 20
          },
          "stackable": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ],
            "description": "Whether coupon can be combined with others",
            "example": "no"
          },
          "priority": {
            "type": "integer",
            "description": "Sort priority",
            "example": 10
          },
          "use_count": {
            "type": "integer",
            "nullable": true,
            "description": "Current usage count",
            "example": 47
          },
          "notes": {
            "type": "string",
            "description": "Internal notes",
            "example": "20% off for new customers"
          },
          "show_on_checkout": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ],
            "description": "Whether to display on checkout",
            "example": "yes"
          },
          "start_date": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Start date (GMT)"
          },
          "end_date": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "End date (GMT)"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "activities": {
            "type": "array",
            "description": "Activity log entries",
            "items": {
              "$ref": "#/components/schemas/Activity"
            }
          }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Activity ID",
            "example": 1
          },
          "title": {
            "type": "string",
            "description": "Activity title",
            "example": "Coupon Created"
          },
          "content": {
            "type": "string",
            "description": "Activity description",
            "example": "Coupon \"WELCOME20\" created by Admin"
          },
          "status": {
            "type": "string",
            "description": "Activity status",
            "example": "success"
          },
          "user_id": {
            "type": "integer",
            "description": "User ID who performed the action",
            "example": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Activity timestamp"
          },
          "user": {
            "type": "object",
            "properties": {
              "ID": {
                "type": "integer",
                "description": "WordPress user ID",
                "example": 1
              },
              "display_name": {
                "type": "string",
                "description": "User display name",
                "example": "Admin"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
