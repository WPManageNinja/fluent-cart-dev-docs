{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/coupons": {
      "get": {
        "operationId": "listCoupons",
        "summary": "GET List Coupons",
        "description": "Retrieve a paginated list of coupons with optional filtering, sorting, and search. Coupon statuses are automatically updated based on their start/end dates before the response is returned.",
        "tags": [
          "Coupons"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for pagination",
            "example": 1
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 199
            },
            "description": "Number of records per page (1-199, default: 10)",
            "example": 10
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by coupon title, code, or ID. If the search string contains %, it searches percentage-type coupons by amount. Numeric values also match the amount field. Supports operator syntax (e.g., status = active, id > 5).",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Column to sort by (default: id). Must be a fillable column on the Coupon model.",
            "example": "id"
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "description": "Sort direction: asc or desc (default: desc)",
            "example": "desc"
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "expired"
              ]
            },
            "description": "Tab filter. active = status is active. expired = end_date has passed or status != active.",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ],
              "default": "simple"
            },
            "description": "Filter mode: simple (default) or advanced",
            "required": false
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "json"
            },
            "description": "JSON-encoded array of advanced filter groups (requires Pro)",
            "required": false
          },
          {
            "name": "with",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Eager-load relations (comma-separated or array)",
            "required": false
          },
          {
            "name": "select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of columns to select",
            "required": false
          },
          {
            "name": "include_ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs that must always be included in results",
            "required": false
          },
          {
            "name": "user_tz",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "User timezone for date filtering (e.g., America/New_York)",
            "required": false,
            "example": "America/New_York"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of coupons.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "coupons": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Coupon"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "coupons": {
                    "total": 25,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 3,
                    "data": [
                      {
                        "id": 1,
                        "parent": null,
                        "title": "10% Off Everything",
                        "code": "SAVE10",
                        "status": "active",
                        "type": "percentage",
                        "conditions": {
                          "min_purchase_amount": 5000,
                          "max_discount_amount": 10000,
                          "max_purchase_amount": 0,
                          "apply_to_whole_cart": "no",
                          "apply_to_quantity": "no",
                          "max_uses": 100,
                          "max_per_customer": 1,
                          "excluded_categories": [],
                          "included_categories": [],
                          "excluded_products": [],
                          "included_products": [],
                          "email_restrictions": "",
                          "is_recurring": "no"
                        },
                        "amount": 10,
                        "stackable": "yes",
                        "priority": 1,
                        "use_count": 12,
                        "notes": "",
                        "show_on_checkout": "yes",
                        "start_date": "2025-01-01 00:00:00",
                        "end_date": "2025-12-31 23:59:59",
                        "created_at": "2025-01-01 10:00:00",
                        "updated_at": "2025-06-15 14:30:00",
                        "total_items": 12
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Coupon": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Coupon ID",
            "example": 1
          },
          "parent": {
            "type": "integer",
            "nullable": true,
            "description": "Parent coupon ID"
          },
          "title": {
            "type": "string",
            "description": "Coupon display name",
            "example": "10% Off Everything"
          },
          "code": {
            "type": "string",
            "description": "Unique coupon code",
            "example": "SAVE10"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "expired",
              "disabled",
              "scheduled"
            ],
            "description": "Coupon status",
            "example": "active"
          },
          "type": {
            "type": "string",
            "enum": [
              "fixed",
              "percentage",
              "free_shipping",
              "buy_x_get_y"
            ],
            "description": "Discount type",
            "example": "percentage"
          },
          "conditions": {
            "type": "object",
            "description": "Coupon conditions and restrictions"
          },
          "amount": {
            "type": "number",
            "description": "Discount amount. For percentage type: percentage value (e.g., 10 = 10%). For fixed type: amount in cents.",
            "example": 10
          },
          "stackable": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ],
            "description": "Whether coupon can be combined with others",
            "example": "yes"
          },
          "priority": {
            "type": "integer",
            "description": "Sort priority for discount calculation order",
            "example": 1
          },
          "use_count": {
            "type": "integer",
            "nullable": true,
            "description": "Current usage count",
            "example": 12
          },
          "notes": {
            "type": "string",
            "description": "Internal notes",
            "example": ""
          },
          "show_on_checkout": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ],
            "description": "Whether to display on checkout",
            "example": "yes"
          },
          "start_date": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "Start date (GMT)"
          },
          "end_date": {
            "type": "string",
            "nullable": true,
            "format": "date-time",
            "description": "End date (GMT)"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "total_items": {
            "type": "integer",
            "description": "Aggregate count of coupon applications",
            "example": 12
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}