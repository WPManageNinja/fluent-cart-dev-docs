{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/coupons/{id}": {
      "put": {
        "operationId": "updateCoupon",
        "summary": "PUT Update Coupon",
        "description": "Update an existing coupon. Accepts the same fields as Create Coupon. The code uniqueness check excludes the current coupon.",
        "tags": [
          "Coupons"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The coupon ID",
            "example": 3
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "code",
                  "type",
                  "amount",
                  "status",
                  "stackable",
                  "show_on_checkout"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "maxLength": 200,
                    "description": "Coupon display name"
                  },
                  "code": {
                    "type": "string",
                    "maxLength": 50,
                    "description": "Unique coupon code"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "fixed",
                      "percentage",
                      "free_shipping",
                      "buy_x_get_y"
                    ],
                    "description": "Discount type"
                  },
                  "amount": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Discount amount. For percentage: value 0-100. For fixed: amount in store currency."
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "expired",
                      "disabled",
                      "scheduled"
                    ],
                    "description": "Coupon status"
                  },
                  "stackable": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Whether coupon can be combined with others"
                  },
                  "show_on_checkout": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Whether to display the coupon on checkout"
                  },
                  "priority": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Sort priority"
                  },
                  "notes": {
                    "type": "string",
                    "description": "Internal notes"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Start date. Required if end_date is provided."
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date-time",
                    "description": "End date. Must be after start_date."
                  },
                  "conditions": {
                    "type": "object",
                    "description": "Coupon conditions and restrictions"
                  }
                },
                "example": {
                  "title": "Summer Sale 25%",
                  "code": "SUMMER25",
                  "type": "percentage",
                  "amount": 25,
                  "status": "active",
                  "stackable": "yes",
                  "show_on_checkout": "yes"
                }
              },
              "example": {
                "title": "Summer Sale 25%",
                "code": "SUMMER25",
                "type": "percentage",
                "amount": 25,
                "status": "active",
                "stackable": "yes",
                "show_on_checkout": "yes"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Coupon updated successfully!"
                    },
                    "data": {
                      "type": "object",
                      "description": "The updated coupon object"
                    }
                  },
                  "example": {
                    "message": "Coupon updated successfully!",
                    "data": {
                      "id": 5,
                      "title": "Summer Sale 25%",
                      "code": "SUMMER25",
                      "status": "active",
                      "type": "percent",
                      "amount": 25,
                      "conditions": {
                        "min_purchase_amount": 3000,
                        "max_discount_amount": 15000,
                        "max_purchase_amount": 0,
                        "apply_to_whole_cart": "yes",
                        "apply_to_quantity": "no",
                        "max_uses": 300,
                        "max_per_customer": 2,
                        "excluded_categories": [],
                        "included_categories": [],
                        "excluded_products": [],
                        "included_products": [],
                        "email_restrictions": "",
                        "is_recurring": "no"
                      },
                      "stackable": "yes",
                      "priority": 1,
                      "use_count": 12,
                      "notes": "Summer promotional campaign - 25% off all plans",
                      "show_on_checkout": "yes",
                      "start_date": "2025-06-01 00:00:00",
                      "end_date": "2025-08-31 23:59:59",
                      "created_at": "2025-05-25 10:00:00",
                      "updated_at": "2025-06-20 11:00:00"
                    }
                  }
                },
                "example": {
                  "message": "Coupon updated successfully!",
                  "data": {
                    "id": 5,
                    "title": "Summer Sale 25%",
                    "code": "SUMMER25",
                    "status": "active",
                    "type": "percent",
                    "amount": 25,
                    "conditions": {
                      "min_purchase_amount": 3000,
                      "max_discount_amount": 15000,
                      "max_purchase_amount": 0,
                      "apply_to_whole_cart": "yes",
                      "apply_to_quantity": "no",
                      "max_uses": 300,
                      "max_per_customer": 2,
                      "excluded_categories": [],
                      "included_categories": [],
                      "excluded_products": [],
                      "included_products": [],
                      "email_restrictions": "",
                      "is_recurring": "no"
                    },
                    "stackable": "yes",
                    "priority": 1,
                    "use_count": 12,
                    "notes": "Summer promotional campaign - 25% off all plans",
                    "show_on_checkout": "yes",
                    "start_date": "2025-06-01 00:00:00",
                    "end_date": "2025-08-31 23:59:59",
                    "created_at": "2025-05-25 10:00:00",
                    "updated_at": "2025-06-20 11:00:00"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Invalid coupon.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Please edit a valid coupon!"
                  }
                },
                "example": {
                  "message": "Please edit a valid coupon!"
                }
              }
            }
          },
          "404": {
            "description": "Coupon not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Coupon not found, please reload the page and try again!"
                  }
                },
                "example": {
                  "message": "Coupon not found, please reload the page and try again!"
                }
              }
            }
          },
          "400": {
            "description": "Update failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Coupon update failed."
                  }
                },
                "example": {
                  "message": "Coupon update failed."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
