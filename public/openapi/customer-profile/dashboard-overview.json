{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/": {
      "get": {
        "operationId": "dashboardOverview",
        "summary": "GET Dashboard Overview",
        "description": "Retrieve the customer's dashboard overview including the 5 most recent orders. This is the landing page data for the customer portal.",
        "tags": [
          "Customer Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response. Returns dashboard data with recent orders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "dashboard_data": {
                      "type": "object",
                      "properties": {
                        "orders": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    },
                    "sections_parts": {
                      "type": "object",
                      "properties": {
                        "before_orders_table": {
                          "type": "string"
                        },
                        "after_orders_table": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "example": {
                    "message": "Success",
                    "dashboard_data": {
                      "orders": [
                        {
                          "created_at": "2025-06-15 10:30:00",
                          "invoice_no": "INV-000101",
                          "total_amount": 4999,
                          "uuid": "abc-123-def",
                          "type": "one-time",
                          "status": "completed",
                          "renewals_count": 0,
                          "order_items": [
                            {
                              "id": 1,
                              "post_title": "Premium Plugin",
                              "title": "Premium Plugin - Single Site",
                              "quantity": 1,
                              "payment_type": "one-time",
                              "line_meta": {
                                "bundle_parent_item_id": null
                              }
                            }
                          ]
                        }
                      ]
                    },
                    "sections_parts": {
                      "before_orders_table": "",
                      "after_orders_table": ""
                    }
                  }
                },
                "example": {
                  "message": "Success",
                  "dashboard_data": {
                    "orders": [
                      {
                        "created_at": "2025-06-15 10:30:00",
                        "invoice_no": "INV-000101",
                        "total_amount": 4999,
                        "uuid": "abc-123-def",
                        "type": "one-time",
                        "status": "completed",
                        "renewals_count": 0,
                        "order_items": [
                          {
                            "id": 1,
                            "post_title": "Premium Plugin",
                            "title": "Premium Plugin - Single Site",
                            "quantity": 1,
                            "payment_type": "one-time",
                            "line_meta": {
                              "bundle_parent_item_id": null
                            }
                          }
                        ]
                      }
                    ]
                  },
                  "sections_parts": {
                    "before_orders_table": "",
                    "after_orders_table": ""
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Success",
                      "dashboard_data": {
                        "orders": [
                          {
                            "created_at": "2025-06-15 10:30:00",
                            "invoice_no": "INV-000101",
                            "total_amount": 4999,
                            "uuid": "abc-123-def",
                            "type": "one-time",
                            "status": "completed",
                            "renewals_count": 0,
                            "order_items": [
                              {
                                "id": 1,
                                "post_title": "Premium Plugin",
                                "title": "Premium Plugin - Single Site",
                                "quantity": 1,
                                "payment_type": "one-time",
                                "line_meta": {
                                  "bundle_parent_item_id": null
                                }
                              }
                            ]
                          }
                        ]
                      },
                      "sections_parts": {
                        "before_orders_table": "",
                        "after_orders_table": ""
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
