{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/delete-address": {
      "post": {
        "operationId": "deleteProfileAddress",
        "summary": "POST Delete Profile Address",
        "description": "Delete an address from the customer's profile. The address must belong to the authenticated customer. Primary addresses and the last remaining address cannot be deleted.",
        "tags": [
          "Customer Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "addressId"
                ],
                "properties": {
                  "addressId": {
                    "type": "integer",
                    "description": "The address record ID to delete"
                  }
                },
                "example": {
                  "addressId": 5
                }
              },
              "example": {
                "addressId": 5
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response. Address deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Address successfully deleted."
                  }
                },
                "example": {
                  "message": "Address successfully deleted."
                }
              }
            }
          },
          "400": {
            "description": "Address cannot be deleted (primary or last remaining).",
            "content": {
              "application/json": {
                "example": {
                  "message": "Primary address cannot be deleted!"
                },
                "schema": {
                  "example": {
                    "message": "Primary address cannot be deleted!"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. The authenticated user does not own this address.",
            "content": {
              "application/json": {
                "example": {
                  "message": "You are not authorized to update this address"
                },
                "schema": {
                  "example": {
                    "message": "You are not authorized to update this address"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
