{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}": {
      "get": {
        "operationId": "getCustomerDetails",
        "summary": "GET Get Customer Details",
        "description": "Retrieve the details of the currently authenticated customer. The customerId must match the logged-in customer's record.",
        "tags": [
          "Customer Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID. Must belong to the authenticated user.",
            "required": true
          },
          {
            "name": "with",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Relationships to eager-load (e.g., `billing_address`, `shipping_address`, `orders`)",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns the customer details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "customer": {
                      "type": "object"
                    }
                  },
                  "example": {
                    "customer": {
                      "id": 1,
                      "user_id": 5,
                      "email": "john@example.com",
                      "first_name": "John",
                      "last_name": "Doe",
                      "status": "active",
                      "purchase_value": {
                        "total": 15000,
                        "currency": "USD",
                        "formatted": "$150.00"
                      },
                      "purchase_count": 3,
                      "ltv": 15000,
                      "country": "US",
                      "city": "New York",
                      "state": "NY",
                      "postcode": "10001",
                      "created_at": "2025-01-10 08:00:00",
                      "updated_at": "2025-06-20 14:00:00"
                    }
                  }
                },
                "example": {
                  "customer": {
                    "id": 1,
                    "user_id": 5,
                    "email": "john@example.com",
                    "first_name": "John",
                    "last_name": "Doe",
                    "status": "active",
                    "purchase_value": {
                      "total": 15000,
                      "currency": "USD",
                      "formatted": "$150.00"
                    },
                    "purchase_count": 3,
                    "ltv": 15000,
                    "country": "US",
                    "city": "New York",
                    "state": "NY",
                    "postcode": "10001",
                    "created_at": "2025-01-10 08:00:00",
                    "updated_at": "2025-06-20 14:00:00"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. The authenticated user does not own this customer record.",
            "content": {
              "application/json": {
                "example": {
                  "message": "You are not authorized to view this customer"
                },
                "schema": {
                  "example": {
                    "message": "You are not authorized to view this customer"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
