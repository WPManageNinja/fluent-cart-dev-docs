{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}/orders": {
      "get": {
        "operationId": "getCustomerOrders",
        "summary": "GET Get Customer Orders",
        "description": "Retrieve a paginated list of orders for the specified customer. The customerId must match the logged-in user.",
        "tags": [
          "Customer Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID. Must belong to the authenticated user.",
            "required": true
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15
            },
            "description": "Number of items per page (default: 15)",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of customer orders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "orders": {
                      "total": 25,
                      "per_page": 15,
                      "current_page": 1,
                      "last_page": 2,
                      "data": [
                        {
                          "id": 101,
                          "invoice_no": "INV-000101",
                          "total_amount": 4999,
                          "uuid": "abc-123-def",
                          "type": "one-time",
                          "status": "completed",
                          "created_at": "2025-06-15 10:30:00"
                        }
                      ]
                    }
                  }
                },
                "example": {
                  "orders": {
                    "total": 25,
                    "per_page": 15,
                    "current_page": 1,
                    "last_page": 2,
                    "data": [
                      {
                        "id": 101,
                        "invoice_no": "INV-000101",
                        "total_amount": 4999,
                        "uuid": "abc-123-def",
                        "type": "one-time",
                        "status": "completed",
                        "created_at": "2025-06-15 10:30:00"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
