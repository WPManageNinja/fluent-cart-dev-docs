{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/orders/{order_uuid}/upgrade-paths": {
      "get": {
        "operationId": "getUpgradePaths",
        "summary": "GET Get Upgrade Paths",
        "description": "Retrieve available upgrade/downgrade paths for a specific product variation within an order. Used to show plan switching options in the customer portal.",
        "tags": [
          "Customer Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order_uuid",
            "in": "path",
            "schema": {
              "type": "string"
            },
            "description": "The UUID of the order (alphanumeric with dashes)",
            "required": true
          },
          {
            "name": "variation_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "The product variation ID to find upgrade paths for",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns available upgrade/downgrade paths.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "upgradePaths": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "variation_id": {
                            "type": "integer"
                          },
                          "title": {
                            "type": "string"
                          },
                          "price": {
                            "type": "integer"
                          },
                          "billing_interval": {
                            "type": "string"
                          },
                          "upgrade_type": {
                            "type": "string"
                          },
                          "prorated_amount": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "upgradePaths": [
                      {
                        "variation_id": 15,
                        "title": "Premium Plugin - 5 Sites",
                        "price": 9999,
                        "billing_interval": "year",
                        "upgrade_type": "upgrade",
                        "prorated_amount": 5000
                      },
                      {
                        "variation_id": 20,
                        "title": "Premium Plugin - Unlimited Sites",
                        "price": 19999,
                        "billing_interval": "year",
                        "upgrade_type": "upgrade",
                        "prorated_amount": 15000
                      }
                    ]
                  }
                },
                "example": {
                  "upgradePaths": [
                    {
                      "variation_id": 15,
                      "title": "Premium Plugin - 5 Sites",
                      "price": 9999,
                      "billing_interval": "year",
                      "upgrade_type": "upgrade",
                      "prorated_amount": 5000
                    },
                    {
                      "variation_id": 20,
                      "title": "Premium Plugin - Unlimited Sites",
                      "price": 19999,
                      "billing_interval": "year",
                      "upgrade_type": "upgrade",
                      "prorated_amount": 15000
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Not logged in.",
            "content": {
              "application/json": {
                "example": {
                  "message": "You must be logged in to view upgrade paths."
                },
                "schema": {
                  "example": {
                    "message": "You must be logged in to view upgrade paths."
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found or no permission.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Order not found or you do not have permission to view it."
                },
                "schema": {
                  "example": {
                    "message": "Order not found or you do not have permission to view it."
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
