{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/downloads": {
      "get": {
        "operationId": "listDownloads",
        "summary": "GET List Downloads",
        "description": "Retrieve a paginated list of downloadable files available to the authenticated customer. Only includes downloads from orders with a successful payment status. Filters downloads based on purchased product variations.",
        "tags": [
          "Customer Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination (default: 1)",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of items per page (default: 10)",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of downloadable files.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "downloads": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "file_size": {
                                "type": "string"
                              },
                              "title": {
                                "type": "string"
                              },
                              "download_url": {
                                "type": "string"
                              }
                            }
                          }
                        },
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "example": {
                    "message": "Success",
                    "downloads": {
                      "data": [
                        {
                          "file_size": "2.5 MB",
                          "title": "premium-plugin-v2.0.1.zip",
                          "download_url": "https://example.com/?fct_download=eyJ0eXAi..."
                        },
                        {
                          "file_size": "1.2 MB",
                          "title": "starter-theme-v1.5.zip",
                          "download_url": "https://example.com/?fct_download=eyJ0eXAi..."
                        }
                      ],
                      "total": 5,
                      "per_page": 10,
                      "current_page": 1,
                      "last_page": 1
                    }
                  }
                },
                "example": {
                  "message": "Success",
                  "downloads": {
                    "data": [
                      {
                        "file_size": "2.5 MB",
                        "title": "premium-plugin-v2.0.1.zip",
                        "download_url": "https://example.com/?fct_download=eyJ0eXAi..."
                      },
                      {
                        "file_size": "1.2 MB",
                        "title": "starter-theme-v1.5.zip",
                        "download_url": "https://example.com/?fct_download=eyJ0eXAi..."
                      }
                    ],
                    "total": 5,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
