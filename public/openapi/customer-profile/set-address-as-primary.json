{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}/address/make-primary": {
      "post": {
        "operationId": "setAddressAsPrimary",
        "summary": "POST Set Address as Primary",
        "description": "Mark a specific address as the primary address for its type (billing or shipping). All other addresses of the same type are demoted.",
        "tags": [
          "Customer Profile"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID. Must belong to the authenticated user.",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "address"
                ],
                "properties": {
                  "address": {
                    "type": "object",
                    "required": [
                      "id",
                      "type"
                    ],
                    "properties": {
                      "id": {
                        "type": "integer",
                        "description": "The address record ID to set as primary"
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "billing",
                          "shipping"
                        ],
                        "description": "Address type: `billing` or `shipping`"
                      }
                    }
                  }
                },
                "example": {
                  "address": {
                    "id": 5,
                    "type": "billing"
                  }
                }
              },
              "example": {
                "address": {
                  "id": 5,
                  "type": "billing"
                }
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "address": {
                      "id": 5,
                      "type": "billing"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response. Address set as primary.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Address successfully set as the primary"
                  }
                },
                "example": {
                  "message": "Address successfully set as the primary"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Address successfully set as the primary"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. The authenticated user does not own this address.",
            "content": {
              "application/json": {
                "example": {
                  "message": "You are not authorized to update this address"
                },
                "schema": {
                  "example": {
                    "message": "You are not authorized to update this address"
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "You are not authorized to update this address"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
