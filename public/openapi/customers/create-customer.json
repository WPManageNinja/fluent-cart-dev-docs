{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers": {
      "post": {
        "operationId": "createCustomer",
        "summary": "POST Create Customer",
        "description": "Create a new customer record. Automatically links to an existing WordPress user if a matching email is found.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 255,
                    "description": "Customer email address. Must be unique and valid."
                  },
                  "first_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Customer first name. Required when store is not configured for full name mode."
                  },
                  "last_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Customer last name."
                  },
                  "full_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Customer full name. Required when store is configured for full name mode. Automatically split into first_name and last_name."
                  },
                  "city": {
                    "type": "string",
                    "description": "Customer city"
                  },
                  "state": {
                    "type": "string",
                    "description": "Customer state/province code"
                  },
                  "postcode": {
                    "type": "string",
                    "description": "Customer postal/zip code"
                  },
                  "country": {
                    "type": "string",
                    "description": "Customer country code (e.g., US, GB)"
                  },
                  "notes": {
                    "type": "string",
                    "description": "Internal notes about the customer"
                  },
                  "status": {
                    "type": "string",
                    "description": "Customer status"
                  },
                  "user_id": {
                    "type": "integer",
                    "description": "WordPress user ID to associate"
                  },
                  "wp_user": {
                    "type": "string",
                    "description": "Set to 'yes' to create a new WordPress user account for this customer"
                  },
                  "aov": {
                    "type": "string",
                    "description": "Average order value"
                  },
                  "user_url": {
                    "type": "string",
                    "description": "Customer website URL"
                  }
                }
              },
              "example": {
                "first_name": "Jane",
                "last_name": "Smith",
                "email": "jane@example.com",
                "country": "US",
                "city": "Boston",
                "state": "MA",
                "postcode": "02101",
                "wp_user": "yes"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                },
                "example": {
                  "message": "Customer created successfully!",
                  "data": {
                    "id": 42,
                    "user_id": null,
                    "email": "jane@example.com",
                    "first_name": "Jane",
                    "last_name": "Smith",
                    "status": "active",
                    "purchase_value": [],
                    "uuid": "e5f6g7h8...",
                    "country": "US",
                    "city": "Boston",
                    "state": "MA",
                    "postcode": "02101",
                    "created_at": "2025-06-20 14:00:00",
                    "updated_at": "2025-06-20 14:00:00"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Customer already exists.",
            "content": {
              "application/json": {
                "example": {
                  "code": 400,
                  "message": "Customer already exists.",
                  "data": ""
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}