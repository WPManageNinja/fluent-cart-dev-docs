{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}/address": {
      "get": {
        "operationId": "getCustomerAddresses",
        "summary": "GET Get Customer Addresses",
        "description": "Retrieve addresses for a customer, optionally filtered by address type. Results are sorted with the primary address first.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "billing",
                "shipping"
              ],
              "default": "billing"
            },
            "description": "Address type filter: billing or shipping (default: billing)",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns customer addresses.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "addresses": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  },
                  "example": {
                    "addresses": [
                      {
                        "id": 25,
                        "customer_id": 12,
                        "is_primary": 1,
                        "type": "billing",
                        "status": "active",
                        "label": "Office",
                        "name": "Sarah Johnson",
                        "address_1": "456 Market Street",
                        "address_2": "Suite 300",
                        "city": "San Francisco",
                        "state": "CA",
                        "postcode": "94102",
                        "country": "US",
                        "phone": "+1-415-555-0142",
