{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}/orders": {
      "get": {
        "operationId": "getCustomerOrders",
        "summary": "GET Get Customer Orders",
        "description": "Retrieve a paginated list of orders belonging to a specific customer. Supports the same filtering and sorting parameters as the main Orders list.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search orders by invoice number, customer name/email, or order item title",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 199
            },
            "description": "Number of items per page (1-199, default: 10)",
            "required": false
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for pagination",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Column to sort by (default: id)",
            "required": false
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "description": "Sort direction: asc or desc (default: desc)",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ],
              "default": "simple"
            },
            "description": "Filter mode: simple or advanced (default: simple)",
            "required": false
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "json"
            },
            "description": "JSON-encoded array of advanced filter groups",
            "required": false
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Active tab filter (e.g., on-hold, paid, completed, processing)",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of customer orders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "orders": {
                      "total": 3,
                      "per_page": 10,
                      "current_page": 1,
                      "last_page": 1,
                      "data": [
                        {
                          "id": 42,
                          "invoice_no": "INV-042",
                          "customer_id": 12,
                          "status": "completed",
                          "payment_status": "paid",
                          "payment_method": "stripe",
                          "currency": "USD",
                          "total_amount": 10692,
                          "created_at": "2025-09-20 14:25:00"
                        },
                        {
                          "id": 35,
                          "invoice_no": "INV-035",
                          "customer_id": 12,
                          "status": "completed",
                          "payment_status": "paid",
                          "payment_method": "stripe",
                          "currency": "USD",
                          "total_amount": 7500,
                          "created_at": "2025-08-05 11:30:00"
                        },
                        {
                          "id": 28,
                          "invoice_no": "INV-028",
                          "customer_id": 12,
                          "status": "processing",
                          "payment_status": "paid",
                          "payment_method": "paypal",
                          "currency": "USD",
                          "total_amount": 6708,
                          "created_at": "2025-06-10 09:15:00"
                        }
                      ]
                    }
                  }
                },
                "example": {
                  "orders": {
                    "total": 3,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 1,
                    "data": [
                      {
                        "id": 42,
                        "invoice_no": "INV-042",
                        "customer_id": 12,
                        "status": "completed",
                        "payment_status": "paid",
                        "payment_method": "stripe",
                        "currency": "USD",
                        "total_amount": 10692,
                        "created_at": "2025-09-20 14:25:00"
                      },
                      {
                        "id": 35,
                        "invoice_no": "INV-035",
                        "customer_id": 12,
                        "status": "completed",
                        "payment_status": "paid",
                        "payment_method": "stripe",
                        "currency": "USD",
                        "total_amount": 7500,
                        "created_at": "2025-08-05 11:30:00"
                      },
                      {
                        "id": 28,
                        "invoice_no": "INV-028",
                        "customer_id": 12,
                        "status": "processing",
                        "payment_status": "paid",
                        "payment_method": "paypal",
                        "currency": "USD",
                        "total_amount": 6708,
                        "created_at": "2025-06-10 09:15:00"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
