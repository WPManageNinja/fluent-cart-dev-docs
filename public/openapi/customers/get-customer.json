{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}": {
      "get": {
        "operationId": "getCustomer",
        "summary": "GET Get Customer",
        "description": "Retrieve a single customer by ID with optional eager-loaded relationships.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          },
          {
            "name": "with",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Relationships to eager-load (e.g., `orders`, `labels`, `billing_address`, `shipping_address`, `subscriptions`, `wpUser`)",
            "required": false
          },
          {
            "name": "params[customer_only]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Set to `yes` to return the customer without labels processing",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns the customer object.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "customer": {
                      "type": "object"
                    }
                  }
                },
                "example": {
                  "customer": {
                    "id": 12,
                    "user_id": 5,
                    "contact_id": null,
                    "email": "sarah.johnson@example.com",
                    "first_name": "Sarah",
                    "last_name": "Johnson",
                    "status": "active",
                    "purchase_value": 24900,
                    "purchase_count": 3,
                    "ltv": 24900,
                    "first_purchase_date": "2025-06-10 09:15:00",
                    "last_purchase_date": "2025-09-20 14:25:00",
                    "aov": 8300,
                    "notes": "",
                    "uuid": "cust_a1b2c3d4",
                    "country": "US",
                    "city": "San Francisco",
                    "state": "CA",
                    "postcode": "94102",
                    "created_at": "2025-06-10 09:15:00",
                    "updated_at": "2025-09-20 14:30:00",
                    "full_name": "Sarah Johnson",
                    "photo": "https://www.gravatar.com/avatar/abc123",
                    "country_name": "United States",
                    "formatted_address": "San Francisco, CA 94102, US",
                    "user_link": "https://example.com/wp-admin/user-edit.php?user_id=5",
                    "selected_labels": [
                      1,
                      2
                    ],
                    "labels": [
                      {"id": 1, "title": "VIP", "color": "#3b82f6"},
                      {"id": 2, "title": "Enterprise", "color": "#10b981"}
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "Customer not found.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Customer not found",
                  "back_text": "Back to Customer List",
                  "back_url": "/customers"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}