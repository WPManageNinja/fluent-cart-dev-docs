{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers": {
      "get": {
        "operationId": "listCustomers",
        "summary": "GET List Customers",
        "description": "Retrieve a paginated list of customers with support for searching, sorting, and advanced filtering.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by customer name, email, or ID. Supports operator syntax (e.g., `id=5`, `ltv>1000`).",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 199
            },
            "description": "Number of items per page (1-199, default: 10)",
            "required": false
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for pagination",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Column to sort by. Must be a fillable field on the Customer model (default: `id`)",
            "required": false
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "description": "Sort direction: `asc` or `desc` (default: `desc`)",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ],
              "default": "simple"
            },
            "description": "Filter mode: `simple` or `advanced` (default: `simple`)",
            "required": false
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "json"
            },
            "description": "JSON-encoded array of advanced filter groups (Pro only). Supports filtering by order items, purchase count, purchase dates, customer name, email, LTV, and labels.",
            "required": false
          },
          {
            "name": "with",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Relationships to eager-load (e.g., `orders`, `labels`, `billing_address`, `shipping_address`)",
            "required": false
          },
          {
            "name": "select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated column names or array of columns to select",
            "required": false
          },
          {
            "name": "include_ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs or array of IDs that must be included in results",
            "required": false
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Active tab/view filter",
            "required": false
          },
          {
            "name": "user_tz",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "User timezone for date filter conversion",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of customers.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "customers": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "customers": {
                    "total": 150,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 15,
                    "data": [
                      {
                        "id": 1,
                        "user_id": 5,
                        "contact_id": null,
                        "email": "john@example.com",
                        "first_name": "John",
                        "last_name": "Doe",
                        "status": "active",
                        "purchase_value": {},
                        "purchase_count": 3,
                        "ltv": 15000,
                        "first_purchase_date": "2025-01-15 10:30:00",
                        "last_purchase_date": "2025-06-20 14:00:00",
                        "aov": 5000,
                        "notes": "",
                        "uuid": "a1b2c3d4...",
                        "country": "US",
                        "city": "New York",
                        "state": "NY",
                        "postcode": "10001",
                        "created_at": "2025-01-10 08:00:00",
                        "updated_at": "2025-06-20 14:00:00",
                        "full_name": "John Doe",
                        "photo": "https://gravatar.com/avatar/...",
                        "country_name": "United States",
                        "formatted_address": {},
                        "user_link": "https://example.com/wp-admin/user-edit.php?user_id=5"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}