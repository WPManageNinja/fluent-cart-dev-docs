{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}/address/make-primary": {
      "post": {
        "operationId": "setPrimaryAddress",
        "summary": "POST Set Primary Address",
        "description": "Set a specific address as the primary address for its type. The previous primary address of the same type is automatically demoted.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "addressId",
                  "type"
                ],
                "properties": {
                  "addressId": {
                    "type": "integer",
                    "description": "The address record ID to make primary"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "billing",
                      "shipping"
                    ],
                    "description": "Address type: billing or shipping"
                  }
                },
                "example": {
                  "addressId": 25,
                  "type": "billing"
                }
              },
              "example": {
                "addressId": 25,
                "type": "billing"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address set as primary successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Address successfully set as the primary",
                    "data": ""
                  }
                },
                "example": {
                  "message": "Address successfully set as the primary",
                  "data": ""
                }
              }
            }
          },
          "400": {
            "description": "Failed to set primary address.",
            "content": {
              "application/json": {
                "example": {
                  "code": 400,
                  "message": "Address set as primary failed.",
                  "data": ""
                },
                "schema": {
                  "example": {
                    "code": 400,
                    "message": "Address set as primary failed.",
                    "data": ""
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
