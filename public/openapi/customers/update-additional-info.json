{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}/additional-info": {
      "put": {
        "operationId": "updateCustomerAdditionalInfo",
        "summary": "PUT Update Additional Info (Labels)",
        "description": "Update a customer's labels/tags. Manages the label relationships for a customer by syncing provided label IDs with existing ones.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "labels"
                ],
                "properties": {
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of label IDs to assign to the customer. Existing labels not in this array will be removed."
                  }
                },
                "example": {
                  "labels": [
                    1,
                    2
                  ]
                }
              },
              "example": {
                "labels": [
                  1,
                  2
                ]
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "labels": [
                      1,
                      2
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer labels updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object"
                    }
                  },
                  "example": {
                    "message": "Customer updated successfully!",
                    "data": {
                      "id": 12,
                      "user_id": 5,
                      "email": "sarah.johnson@example.com",
                      "first_name": "Sarah",
                      "last_name": "Johnson",
                      "full_name": "Sarah Johnson",
                      "status": "active",
                      "labels": [
                        {
                          "id": 1,
                          "title": "VIP",
                          "color": "#3b82f6"
                        },
                        {
                          "id": 2,
                          "title": "Enterprise",
                          "color": "#10b981"
                        }
                      ]
                    }
                  }
                },
                "example": {
                  "message": "Customer updated successfully!",
                  "data": {
                    "id": 12,
                    "user_id": 5,
                    "email": "sarah.johnson@example.com",
                    "first_name": "Sarah",
                    "last_name": "Johnson",
                    "full_name": "Sarah Johnson",
                    "status": "active",
                    "labels": [
                      {
                        "id": 1,
                        "title": "VIP",
                        "color": "#3b82f6"
                      },
                      {
                        "id": 2,
                        "title": "Enterprise",
                        "color": "#10b981"
                      }
                    ]
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Customer updated successfully!",
                      "data": {
                        "id": 12,
                        "user_id": 5,
                        "email": "sarah.johnson@example.com",
                        "first_name": "Sarah",
                        "last_name": "Johnson",
                        "full_name": "Sarah Johnson",
                        "status": "active",
                        "labels": [
                          {
                            "id": 1,
                            "title": "VIP",
                            "color": "#3b82f6"
                          },
                          {
                            "id": 2,
                            "title": "Enterprise",
                            "color": "#10b981"
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
