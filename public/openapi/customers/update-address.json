{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}/address": {
      "put": {
        "operationId": "updateCustomerAddress",
        "summary": "PUT Update Address",
        "description": "Update an existing customer address by its address record ID. Optionally syncs changes to an associated order address.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "name",
                  "email",
                  "address_1",
                  "city",
                  "country",
                  "type"
                ],
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "The address record ID to update"
                  },
                  "name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Full name for the address."
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 255,
                    "description": "Email for the address."
                  },
                  "address_1": {
                    "type": "string",
                    "description": "Primary street address"
                  },
                  "address_2": {
                    "type": "string",
                    "description": "Secondary address line"
                  },
                  "city": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "City."
                  },
                  "state": {
                    "type": "string",
                    "description": "State/province code. May be required depending on store localization settings."
                  },
                  "postcode": {
                    "type": "string",
                    "description": "Postal/zip code. May be required depending on store localization settings."
                  },
                  "country": {
                    "type": "string",
                    "description": "Country code"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "billing",
                      "shipping"
                    ],
                    "description": "Address type: billing or shipping"
                  },
                  "label": {
                    "type": "string",
                    "maxLength": 15,
                    "description": "Custom label."
                  },
                  "status": {
                    "type": "string",
                    "description": "Address status"
                  },
                  "is_primary": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Set to 1 for primary address"
                  },
                  "company_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Company name."
                  },
                  "order_id": {
                    "type": "integer",
                    "description": "Order ID to sync address changes with"
                  }
                }
              },
              "example": {
                "id": 5,
                "name": "John Doe",
                "email": "john@example.com",
                "address_1": "789 Updated Street",
                "city": "New York",
                "state": "NY",
                "postcode": "10003",
                "country": "US",
                "type": "billing"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                },
                "example": {
                  "message": "Billing address updated successfully!",
                  "data": {
                    "id": 5,
                    "customer_id": 1,
                    "is_primary": 0,
                    "type": "billing",
                    "name": "John Doe",
                    "address_1": "789 Updated Street"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Address not found.",
            "content": {
              "application/json": {
                "example": {
                  "code": 404,
                  "message": "Address not found, please reload the page and try again!",
                  "data": ""
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}