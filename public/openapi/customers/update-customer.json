{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customers/{customerId}": {
      "put": {
        "operationId": "updateCustomer",
        "summary": "PUT Update Customer",
        "description": "Update an existing customer. If the customer is linked to a WordPress user, the corresponding WP user profile is also updated.",
        "tags": [
          "Customers"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "maxLength": 255,
                    "description": "Customer email address. Must be unique (excluding current customer)."
                  },
                  "first_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Customer first name. Required when store is not configured for full name mode."
                  },
                  "last_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Customer last name."
                  },
                  "full_name": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "Customer full name. Required when store is configured for full name mode."
                  },
                  "city": {
                    "type": "string",
                    "description": "Customer city"
                  },
                  "state": {
                    "type": "string",
                    "description": "Customer state/province code"
                  },
                  "postcode": {
                    "type": "string",
                    "description": "Customer postal/zip code"
                  },
                  "country": {
                    "type": "string",
                    "description": "Customer country code"
                  },
                  "notes": {
                    "type": "string",
                    "description": "Internal notes about the customer"
                  },
                  "status": {
                    "type": "string",
                    "description": "Customer status"
                  },
                  "user_id": {
                    "type": "integer",
                    "description": "WordPress user ID"
                  },
                  "aov": {
                    "type": "string",
                    "description": "Average order value"
                  },
                  "user_url": {
                    "type": "string",
                    "description": "Customer website URL"
                  },
                  "username": {
                    "type": "string",
                    "description": "Username"
                  },
                  "user_nicename": {
                    "type": "string",
                    "description": "User nicename"
                  },
                  "display_name": {
                    "type": "string",
                    "description": "Display name"
                  }
                }
              },
              "example": {
                "first_name": "John",
                "last_name": "Doe",
                "email": "john@example.com",
                "city": "San Francisco",
                "state": "CA",
                "country": "US"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object"
                    }
                  }
                },
                "example": {
                  "message": "Customer updated successfully!",
                  "data": {
                    "id": 1,
                    "user_id": 5,
                    "email": "john@example.com",
                    "first_name": "John",
                    "last_name": "Doe",
                    "status": "active"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}