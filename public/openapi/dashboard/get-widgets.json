{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/widgets": {
      "get": {
        "operationId": "getWidgets",
        "summary": "GET Get Widgets",
        "description": "Retrieve dynamic widget data for a specific context. Widgets are loaded via WordPress filters, allowing modules and extensions to register custom widgets.",
        "tags": [
          "Dashboard"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Widget context identifier (the fluent_cart_ prefix is automatically stripped). Example: single_order_page"
          },
          {
            "name": "data[order_id]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Additional context data. For single_order_page filter, must include order_id."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "widgets": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Widget"
                      }
                    }
                  },
                  "example": {
                    "widgets": [
                      {
                        "title": "Customer Lifetime Value",
                        "value": "$1,250.00",
                        "type": "stat"
                      }
                    ]
                  }
                },
                "example": {
                  "widgets": [
                    {
                      "title": "Customer Lifetime Value",
                      "value": "$1,250.00",
                      "type": "stat"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Order not found (when filter is single_order_page)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Order not found"
                  }
                },
                "example": {
                  "message": "Order not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Widget": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Widget title",
            "example": "Customer Lifetime Value"
          },
          "value": {
            "type": "string",
            "description": "Widget display value",
            "example": "$1,250.00"
          },
          "type": {
            "type": "string",
            "description": "Widget type",
            "example": "stat"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
