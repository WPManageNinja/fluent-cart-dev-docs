{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/app/attachments": {
      "get": {
        "operationId": "listAttachments",
        "summary": "GET List Attachments",
        "description": "Retrieve all image attachments from the WordPress media library. Used for the media picker in the admin interface.",
        "tags": [
          "Dashboard"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "attachments": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Attachment"
                      }
                    }
                  },
                  "example": {
                    "attachments": [
                      {
                        "id": 101,
                        "title": "product-image",
                        "url": "https://example.com/wp-content/uploads/2025/01/product-image.jpg"
                      },
                      {
                        "id": 102,
                        "title": "store-logo",
                        "url": "https://example.com/wp-content/uploads/2025/01/store-logo.png"
                      }
                    ]
                  }
                },
                "example": {
                  "attachments": [
                    {
                      "id": 101,
                      "title": "product-image",
                      "url": "https://example.com/wp-content/uploads/2025/01/product-image.jpg"
                    },
                    {
                      "id": 102,
                      "title": "store-logo",
                      "url": "https://example.com/wp-content/uploads/2025/01/store-logo.png"
                    }
                  ]
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "attachments": [
                        {
                          "id": 101,
                          "title": "product-image",
                          "url": "https://example.com/wp-content/uploads/2025/01/product-image.jpg"
                        },
                        {
                          "id": 102,
                          "title": "store-logo",
                          "url": "https://example.com/wp-content/uploads/2025/01/store-logo.png"
                        }
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "No images found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "No Images Found"
                  }
                },
                "example": {
                  "message": "No Images Found"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "No Images Found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Attachment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "WordPress attachment ID",
            "example": 101
          },
          "title": {
            "type": "string",
            "description": "Attachment title",
            "example": "product-image"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Attachment URL",
            "example": "https://example.com/wp-content/uploads/2025/01/product-image.jpg"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
