{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/email-notification/{notification}": {
      "get": {
        "operationId": "getEmailNotification",
        "summary": "GET Get Single Notification",
        "description": "Retrieve a single email notification template by its name, along with available shortcodes for the email editor.",
        "tags": [
          "Email Notifications"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "notification",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The notification key (e.g., order_paid_customer, subscription_renewal_admin)",
            "example": "order_paid_customer"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/EmailNotificationDetail"
                    },
                    "shortcodes": {
                      "type": "object",
                      "description": "Available shortcode groups for the email editor",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/ShortcodeGroup"
                      }
                    }
                  }
                },
                "example": {
                  "data": {
                    "event": "order_paid",
                    "group": "order",
                    "group_label": "Order Actions",
                    "title": "Purchase receipt to customer",
                    "description": "This email will be sent to the customer after an order is placed.",
                    "recipient": "customer",
                    "smartcode_groups": [],
                    "template_path": "order.paid.customer",
                    "is_async": false,
                    "name": "order_paid_customer",
                    "settings": {
                      "active": "yes",
                      "subject": "Purchase Receipt #{{order.invoice_no}}",
                      "is_default_body": "yes",
                      "email_body": ""
                    }
                  },
                  "shortcodes": {
                    "order": {
                      "title": "Order",
                      "key": "order",
                      "shortcodes": {
                        "{{order.id}}": "Order ID",
                        "{{order.invoice_no}}": "Order Number",
                        "{{order.status}}": "Order Status",
                        "{{order.total_amount_formatted}}": "Order Total Amount (Formatted)"
                      }
                    },
                    "general": {
                      "title": "General",
                      "key": "wp",
                      "shortcodes": {
                        "{{wp.admin_email}}": "Admin Email",
                        "{{wp.site_url}}": "Site URL",
                        "{{wp.site_title}}": "Site Title"
                      }
                    },
                    "customer": {
                      "title": "Customer",
                      "key": "customer",
                      "shortcodes": {
                        "{{order.billing.first_name}}": "First Name",
                        "{{order.billing.last_name}}": "Last Name",
                        "{{order.billing.email}}": "Email"
                      }
                    },
                    "transaction": {
                      "title": "transaction",
                      "key": "settings",
                      "shortcodes": {
                        "{{transaction.total_formatted}}": "Total Amount (Formatted)",
                        "{{transaction.payment_method}}": "Payment Method",
                        "{{transaction.status}}": "Status"
                      }
                    },
                    "settings": {
                      "title": "Settings",
                      "key": "settings",
                      "shortcodes": {
                        "{{settings.store_name}}": "Store Name",
                        "{{settings.store_logo}}": "Store Logo"
                      }
                    },
                    "license": {
                      "title": "License (Loop)",
                      "key": "license",
                      "shortcodes": {
                        "{{license.key}}": "License Key",
                        "{{license.status}}": "Status"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Notification not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Notification Details not found"
                    }
                  }
                },
                "example": {
                  "message": "Notification Details not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EmailNotificationDetail": {
        "type": "object",
        "properties": {
          "event": {
            "type": "string",
            "description": "The event hook that triggers this notification",
            "example": "order_paid"
          },
          "group": {
            "type": "string",
            "description": "Grouping category: order, subscription, or scheduler",
            "example": "order"
          },
          "group_label": {
            "type": "string",
            "description": "Human-readable group label",
            "example": "Order Actions"
          },
          "title": {
            "type": "string",
            "description": "Descriptive title of the notification",
            "example": "Purchase receipt to customer"
          },
          "description": {
            "type": "string",
            "description": "Explanation of when this notification is sent",
            "example": "This email will be sent to the customer after an order is placed."
          },
          "recipient": {
            "type": "string",
            "enum": [
              "admin",
              "customer"
            ],
            "description": "Target recipient type",
            "example": "customer"
          },
          "smartcode_groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Additional shortcode groups available for this notification"
          },
          "template_path": {
            "type": "string",
            "description": "Dot-notation path to the default PHP email template",
            "example": "order.paid.customer"
          },
          "is_async": {
            "type": "boolean",
            "description": "Whether the email is sent asynchronously",
            "example": false
          },
          "name": {
            "type": "string",
            "description": "Unique notification key identifier",
            "example": "order_paid_customer"
          },
          "settings": {
            "type": "object",
            "properties": {
              "active": {
                "type": "string",
                "enum": [
                  "yes",
                  "no"
                ],
                "description": "Whether the notification is enabled",
                "example": "yes"
              },
              "subject": {
                "type": "string",
                "description": "Email subject line. Supports shortcodes",
                "example": "Purchase Receipt #{{order.invoice_no}}"
              },
              "is_default_body": {
                "type": "string",
                "enum": [
                  "yes",
                  "no"
                ],
                "description": "Whether to use the built-in PHP template",
                "example": "yes"
              },
              "email_body": {
                "type": "string",
                "description": "Custom email body content (HTML). Empty when using default body",
                "example": ""
              }
            }
          }
        }
      },
      "ShortcodeGroup": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Group title",
            "example": "Order"
          },
          "key": {
            "type": "string",
            "description": "Group key",
            "example": "order"
          },
          "shortcodes": {
            "type": "object",
            "description": "Shortcodes in this group, keyed by shortcode pattern with description as value",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}