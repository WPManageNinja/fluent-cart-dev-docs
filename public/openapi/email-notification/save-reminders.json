{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/email-notification/reminders": {
      "post": {
        "operationId": "saveSchedulingSettings",
        "summary": "POST Save Scheduling Settings",
        "description": "Update reminder/scheduling settings for automated email notifications. Each reminder type has an enable toggle and a days configuration that controls how many days before the event the reminder is sent.",
        "tags": [
          "Email Notifications"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reminders_enabled": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Master toggle for all reminders",
                    "example": "yes"
                  },
                  "invoice_reminders_enabled": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Enable invoice payment reminders",
                    "example": "yes"
                  },
                  "invoice_reminder_due_days": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 365,
                    "description": "Days before due date to send invoice reminder. Required when invoice_reminders_enabled is yes",
                    "example": 3
                  },
                  "invoice_reminder_overdue_days": {
                    "type": "string",
                    "description": "Comma-separated day intervals for overdue reminders (e.g., 1,3,7)",
                    "example": "1,3,7"
                  },
                  "yearly_renewal_reminders_enabled": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Enable yearly subscription renewal reminders",
                    "example": "yes"
                  },
                  "yearly_renewal_reminder_days": {
                    "type": "integer",
                    "minimum": 7,
                    "maximum": 90,
                    "description": "Days before renewal to send reminder. Required when yearly_renewal_reminders_enabled is yes",
                    "example": 30
                  },
                  "trial_end_reminders_enabled": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Enable trial ending reminders",
                    "example": "yes"
                  },
                  "trial_end_reminder_days": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 14,
                    "description": "Days before trial ends to send reminder. Required when trial_end_reminders_enabled is yes",
                    "example": 3
                  },
                  "monthly_renewal_reminders_enabled": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Enable monthly renewal reminders",
                    "example": "no"
                  },
                  "monthly_renewal_reminder_days": {
                    "type": "integer",
                    "minimum": 3,
                    "maximum": 28,
                    "description": "Days before renewal to send reminder. Required when monthly_renewal_reminders_enabled is yes",
                    "example": 7
                  },
                  "quarterly_renewal_reminders_enabled": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Enable quarterly renewal reminders",
                    "example": "no"
                  },
                  "quarterly_renewal_reminder_days": {
                    "type": "integer",
                    "minimum": 7,
                    "maximum": 60,
                    "description": "Days before renewal to send reminder. Required when quarterly_renewal_reminders_enabled is yes",
                    "example": 14
                  },
                  "half_yearly_renewal_reminders_enabled": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "Enable half-yearly renewal reminders",
                    "example": "no"
                  },
                  "half_yearly_renewal_reminder_days": {
                    "type": "integer",
                    "minimum": 7,
                    "maximum": 60,
                    "description": "Days before renewal to send reminder. Required when half_yearly_renewal_reminders_enabled is yes",
                    "example": 14
                  }
                }
              },
              "example": {
                "reminders_enabled": "yes",
                "invoice_reminders_enabled": "yes",
                "invoice_reminder_due_days": 3,
                "invoice_reminder_overdue_days": "1,3,7",
                "yearly_renewal_reminders_enabled": "yes",
                "yearly_renewal_reminder_days": 30,
                "trial_end_reminders_enabled": "yes",
                "trial_end_reminder_days": 3,
                "monthly_renewal_reminders_enabled": "no",
                "monthly_renewal_reminder_days": 7,
                "quarterly_renewal_reminders_enabled": "no",
                "quarterly_renewal_reminder_days": 14,
                "half_yearly_renewal_reminders_enabled": "no",
                "half_yearly_renewal_reminder_days": 14
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scheduling settings saved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "description": "Updated settings data"
                    },
                    "message": {
                      "type": "string",
                      "example": "Scheduling settings saved successfully"
                    }
                  }
                },
                "example": {
                  "data": {},
                  "message": "Scheduling settings saved successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or save failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Failed to save scheduling settings"
                    }
                  }
                },
                "example": {
                  "message": "Failed to save scheduling settings"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}