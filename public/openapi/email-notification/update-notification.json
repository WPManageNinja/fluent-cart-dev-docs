{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/email-notification/{notification}": {
      "put": {
        "operationId": "updateEmailNotification",
        "summary": "PUT Update Notification",
        "description": "Update an email notification template's settings including subject, body content, and active status.",
        "tags": [
          "Email Notifications"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "notification",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The notification key (e.g., order_paid_customer)",
            "example": "order_paid_customer"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "settings"
                ],
                "properties": {
                  "settings": {
                    "type": "object",
                    "required": [
                      "subject"
                    ],
                    "properties": {
                      "subject": {
                        "type": "string",
                        "maxLength": 255,
                        "description": "Email subject line. Supports shortcodes like {{order.invoice_no}}",
                        "example": "Your Order #{{order.invoice_no}} is Confirmed!"
                      },
                      "email_body": {
                        "type": "string",
                        "nullable": true,
                        "description": "Custom email body content (HTML). Sanitized with wp_kses_post",
                        "example": "<p>Thank you for your purchase, {{order.billing.first_name}}!</p>"
                      },
                      "active": {
                        "type": "string",
                        "enum": [
                          "yes",
                          "no"
                        ],
                        "nullable": true,
                        "description": "Enable or disable the notification",
                        "example": "yes"
                      },
                      "is_default_body": {
                        "type": "string",
                        "enum": [
                          "yes",
                          "no"
                        ],
                        "nullable": true,
                        "description": "Whether to use the default template body. When set to yes, the custom email_body is cleared",
                        "example": "no"
                      }
                    }
                  }
                }
              },
              "example": {
                "settings": {
                  "subject": "Your Order #{{order.invoice_no}} is Confirmed!",
                  "email_body": "<p>Thank you for your purchase, {{order.billing.first_name}}!</p>",
                  "active": "yes",
                  "is_default_body": "no"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Notification updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Notification updated successfully"
                    }
                  }
                },
                "example": {
                  "message": "Notification updated successfully"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or update failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Failed to update notification"
                    }
                  }
                },
                "example": {
                  "message": "Failed to update notification"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}