{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/files/upload": {
      "post": {
        "operationId": "uploadFile",
        "summary": "POST Upload File",
        "description": "Upload a downloadable file to the specified storage driver. The file is stored with a unique name appended with a timestamp to prevent collisions.",
        "tags": [
          "Files"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadFileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message",
                      "example": "File Uploaded Successfully"
                    },
                    "path": {
                      "type": "string",
                      "description": "Uploaded file path with timestamp",
                      "example": "my-ebook__fluent-cart__.1710345600.pdf"
                    },
                    "file": {
                      "$ref": "#/components/schemas/File"
                    }
                  },
                  "example": {
                    "message": "File Uploaded Successfully",
                    "path": "my-ebook__fluent-cart__.1710345600.pdf",
                    "file": {
                      "driver": "local",
                      "size": 2048576,
                      "name": "my-ebook__fluent-cart__.1710345600.pdf",
                      "bucket": ""
                    }
                  }
                },
                "example": {
                  "message": "File Uploaded Successfully",
                  "path": "my-ebook__fluent-cart__.1710345600.pdf",
                  "file": {
                    "driver": "local",
                    "size": 2048576,
                    "name": "my-ebook__fluent-cart__.1710345600.pdf",
                    "bucket": ""
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "File Uploaded Successfully",
                      "path": "my-ebook__fluent-cart__.1710345600.pdf",
                      "file": {
                        "driver": "local",
                        "size": 2048576,
                        "name": "my-ebook__fluent-cart__.1710345600.pdf",
                        "bucket": ""
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation error or file empty.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Error message",
                      "example": "Failed To Upload File"
                    },
                    "additional": {
                      "type": "string",
                      "nullable": true,
                      "description": "Additional error information",
                      "example": "File is empty"
                    }
                  },
                  "example": {
                    "message": "Failed To Upload File",
                    "additional": "File is empty"
                  }
                },
                "example": {
                  "message": "Failed To Upload File",
                  "additional": "File is empty"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Failed To Upload File",
                      "additional": "File is empty"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UploadFileRequest": {
        "type": "object",
        "required": [
          "file",
          "name"
        ],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "The file to upload."
          },
          "name": {
            "type": "string",
            "maxLength": 160,
            "description": "Display name for the file (max 160 characters). The file extension is appended automatically from the uploaded file.",
            "example": "my-ebook"
          },
          "driver": {
            "type": "string",
            "description": "Storage driver to use (default: `local`).",
            "example": "local"
          }
        }
      },
      "File": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "File name with timestamp suffix",
            "example": "my-ebook__fluent-cart__.1710345600.pdf"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes",
            "example": 2048576
          },
          "driver": {
            "type": "string",
            "description": "Storage driver",
            "example": "local"
          },
          "bucket": {
            "type": "string",
            "description": "Storage bucket (empty for local driver)",
            "example": ""
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
