{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/integration/feed/chained": {
      "post": {
        "operationId": "chainedDataRequest",
        "summary": "POST Chained Data Request",
        "description": "Handle chained/dependent data requests for integration feeds. Used when selecting a value in one feed field needs to dynamically load options for another field. The behavior is entirely handled by the integration provider through the `fluent_cart/integration/chained_{route}` hook.",
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "route"
                ],
                "properties": {
                  "route": {
                    "type": "string",
                    "description": "The chained route identifier, determines which integration provider handles the request",
                    "example": "fluent-crm"
                  }
                },
                "additionalProperties": true,
                "example": {
                  "route": "fluent-crm",
                  "list_id": "2"
                }
              },
              "example": {
                "route": "fluent-crm",
                "list_id": "2"
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "route": "fluent-crm",
                    "list_id": "2"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response. The response format depends on the integration provider handling the chained route.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "options": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "label": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "options": [
                      {
                        "id": "1",
                        "label": "Option A"
                      },
                      {
                        "id": "2",
                        "label": "Option B"
                      }
                    ]
                  }
                },
                "example": {
                  "options": [
                    {
                      "id": "1",
                      "label": "Option A"
                    },
                    {
                      "id": "2",
                      "label": "Option B"
                    }
                  ]
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "options": [
                        {
                          "id": "1",
                          "label": "Option A"
                        },
                        {
                          "id": "2",
                          "label": "Option B"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
