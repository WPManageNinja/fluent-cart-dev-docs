{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{product_id}/integrations/feed/change-status": {
      "post": {
        "operationId": "changeProductFeedStatus",
        "summary": "POST Change Product Feed Status",
        "description": "Toggle a product-level integration feed on or off.",
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "description": "The product ID",
            "schema": {
              "type": "integer",
              "example": 123
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "product_id",
                  "notification_id",
                  "status"
                ],
                "properties": {
                  "product_id": {
                    "type": "integer",
                    "description": "The product ID (must also be provided in the request body)",
                    "example": 123
                  },
                  "notification_id": {
                    "type": "integer",
                    "description": "The feed ID to toggle",
                    "example": 15
                  },
                  "status": {
                    "type": "string",
                    "description": "New status: `yes` (enable) or `no` (disable)",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "example": "no"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    }
                  },
                  "example": {
                    "message": "Integration status has been updated"
                  }
                },
                "example": {
                  "message": "Integration status has been updated"
                }
              }
            }
          },
          "400": {
            "description": "Missing required parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Product ID and Notification ID are required"
                  }
                },
                "example": {
                  "message": "Product ID and Notification ID are required"
                }
              }
            }
          },
          "404": {
            "description": "Notification not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Notification not found"
                  }
                },
                "example": {
                  "message": "Notification not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
