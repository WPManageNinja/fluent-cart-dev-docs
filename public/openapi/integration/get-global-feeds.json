{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/integration/global-feeds": {
      "get": {
        "operationId": "listGlobalIntegrationFeeds",
        "summary": "GET List Global Integration Feeds",
        "description": "Retrieve all configured global integration feeds along with the list of available integrations that support global scope.",
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "feeds": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/GlobalFeed"
                      }
                    },
                    "available_integrations": {
                      "type": "object",
                      "description": "Available integrations that support global scope",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/AvailableIntegration"
                      }
                    },
                    "all_module_config_url": {
                      "type": "string",
                      "format": "uri",
                      "description": "URL to the integrations admin page"
                    }
                  }
                },
                "example": {
                  "feeds": [
                    {
                      "id": 42,
                      "name": "Add to FluentCRM list",
                      "enabled": "yes",
                      "provider": "fluent-crm",
                      "feed": {
                        "name": "Add to FluentCRM list",
                        "enabled": "yes",
                        "list_id": "2",
                        "list_name": "Customers",
                        "merge_fields": {
                          "first_name": "{customer.first_name}",
                          "last_name": "{customer.last_name}",
                          "email": "{customer.email}"
                        },
                        "conditionals": {
                          "conditions": [
                            {
                              "field": "payment_status",
                              "operator": "is",
                              "value": "paid"
                            }
                          ],
                          "status": false,
                          "type": "all"
                        }
                      },
                      "scope": "global"
                    }
                  ],
                  "available_integrations": {
                    "fluent-crm": {
                      "title": "FluentCRM",
                      "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluentcrm.svg",
                      "enabled": true,
                      "scopes": [
                        "global",
                        "product"
                      ],
                      "description": "The most powerful email marketing automation plugin for WordPress."
                    }
                  },
                  "all_module_config_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/integrations"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GlobalFeed": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique feed ID",
            "example": 42
          },
          "name": {
            "type": "string",
            "description": "Display name of the feed",
            "example": "Add to FluentCRM list"
          },
          "enabled": {
            "type": "string",
            "description": "Status: yes or no",
            "enum": [
              "yes",
              "no"
            ],
            "example": "yes"
          },
          "provider": {
            "type": "string",
            "description": "Integration provider key",
            "example": "fluent-crm"
          },
          "feed": {
            "type": "object",
            "description": "Full feed configuration data including field mappings and conditionals"
          },
          "scope": {
            "type": "string",
            "description": "Always 'global' for this endpoint",
            "example": "global"
          }
        }
      },
      "AvailableIntegration": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Display name",
            "example": "FluentCRM"
          },
          "logo": {
            "type": "string",
            "format": "uri",
            "description": "Logo URL"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the integration is enabled"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Supported scopes",
            "example": [
              "global",
              "product"
            ]
          },
          "description": {
            "type": "string",
            "description": "Integration description"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
