{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/integration/addons": {
      "get": {
        "operationId": "listIntegrationAddons",
        "summary": "GET List Available Add-ons",
        "description": "Retrieve the list of all available integration add-ons, including their installation status and metadata.",
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "addons": {
                      "type": "object",
                      "description": "Object of add-ons keyed by add-on identifier",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/IntegrationAddon"
                      }
                    }
                  },
                  "example": {
                    "addons": {
                      "fluent-crm": {
                        "installable": "fluent-crm",
                        "enabled": true,
                        "title": "FluentCRM",
                        "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluentcrm.svg",
                        "categories": [
                          "crm",
                          "core",
                          "marketing"
                        ],
                        "description": "The most powerful email marketing automation plugin for WordPress."
                      },
                      "fluent-smtp": {
                        "installable": "fluent-smtp",
                        "enabled": false,
                        "title": "FluentSMTP",
                        "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluent-smtp.svg",
                        "categories": [
                          "core",
                          "marketing"
                        ],
                        "description": "A free WordPress SMTP plugin to send emails via multiple providers."
                      },
                      "webhook": {
                        "title": "Webhook",
                        "description": "Send data anywhere via webhook",
                        "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/webhook.svg",
                        "enabled": true,
                        "is_pro": true,
                        "is_pro_active": true,
                        "categories": [
                          "core"
                        ]
                      }
                    }
                  }
                },
                "example": {
                  "addons": {
                    "fluent-crm": {
                      "installable": "fluent-crm",
                      "enabled": true,
                      "title": "FluentCRM",
                      "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluentcrm.svg",
                      "categories": [
                        "crm",
                        "core",
                        "marketing"
                      ],
                      "description": "The most powerful email marketing automation plugin for WordPress."
                    },
                    "fluent-smtp": {
                      "installable": "fluent-smtp",
                      "enabled": false,
                      "title": "FluentSMTP",
                      "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluent-smtp.svg",
                      "categories": [
                        "core",
                        "marketing"
                      ],
                      "description": "A free WordPress SMTP plugin to send emails via multiple providers."
                    },
                    "webhook": {
                      "title": "Webhook",
                      "description": "Send data anywhere via webhook",
                      "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/webhook.svg",
                      "enabled": true,
                      "is_pro": true,
                      "is_pro_active": true,
                      "categories": [
                        "core"
                      ]
                    }
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "addons": {
                        "fluent-crm": {
                          "installable": "fluent-crm",
                          "enabled": true,
                          "title": "FluentCRM",
                          "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluentcrm.svg",
                          "categories": [
                            "crm",
                            "core",
                            "marketing"
                          ],
                          "description": "The most powerful email marketing automation plugin for WordPress."
                        },
                        "fluent-smtp": {
                          "installable": "fluent-smtp",
                          "enabled": false,
                          "title": "FluentSMTP",
                          "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluent-smtp.svg",
                          "categories": [
                            "core",
                            "marketing"
                          ],
                          "description": "A free WordPress SMTP plugin to send emails via multiple providers."
                        },
                        "webhook": {
                          "title": "Webhook",
                          "description": "Send data anywhere via webhook",
                          "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/webhook.svg",
                          "enabled": true,
                          "is_pro": true,
                          "is_pro_active": true,
                          "categories": [
                            "core"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IntegrationAddon": {
        "type": "object",
        "properties": {
          "installable": {
            "type": "string",
            "description": "Plugin slug for WordPress.org installation (absent for pro add-ons)",
            "example": "fluent-crm"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the add-on's underlying plugin is active",
            "example": true
          },
          "title": {
            "type": "string",
            "description": "Display name of the add-on",
            "example": "FluentCRM"
          },
          "logo": {
            "type": "string",
            "format": "uri",
            "description": "URL to the add-on's logo image",
            "example": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluentcrm.svg"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Category tags (e.g., core, crm, marketing, community, lms)",
            "example": [
              "crm",
              "core",
              "marketing"
            ]
          },
          "description": {
            "type": "string",
            "description": "Human-readable description",
            "example": "The most powerful email marketing automation plugin for WordPress."
          },
          "is_pro": {
            "type": "boolean",
            "description": "Whether the add-on requires a Pro license (only present for premium add-ons)",
            "example": true
          },
          "is_pro_active": {
            "type": "boolean",
            "description": "Whether the Pro license is currently active (only present for premium add-ons)",
            "example": true
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
