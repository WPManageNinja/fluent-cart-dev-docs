{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{productId}/integrations": {
      "get": {
        "operationId": "listProductIntegrationFeeds",
        "summary": "GET List Product Integration Feeds",
        "description": "Retrieve all integration feeds configured for a specific product, along with available product-scoped integrations.",
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "description": "The product ID",
            "schema": {
              "type": "integer",
              "example": 123
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "feeds": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ProductFeed"
                      }
                    },
                    "available_integrations": {
                      "type": "object",
                      "description": "Available integrations that support product scope",
                      "additionalProperties": {
                        "$ref": "#/components/schemas/AvailableIntegration"
                      }
                    },
                    "all_module_config_url": {
                      "type": "string",
                      "format": "uri",
                      "description": "URL to the integrations admin page"
                    }
                  }
                },
                "example": {
                  "feeds": [
                    {
                      "id": 15,
                      "name": "Tag VIP buyers",
                      "enabled": "yes",
                      "provider": "fluent-crm",
                      "feed": {
                        "name": "Tag VIP buyers",
                        "enabled": "yes",
                        "list_id": "3",
                        "list_name": "VIP Customers",
                        "merge_fields": {},
                        "conditional_variation_ids": [
                          101,
                          102
                        ],
                        "conditionals": {
                          "conditions": [],
                          "status": false,
                          "type": "all"
                        }
                      },
                      "scope": "product"
                    }
                  ],
                  "available_integrations": {
                    "fluent-crm": {
                      "title": "FluentCRM",
                      "logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/integrations/fluentcrm.svg",
                      "enabled": true,
                      "scopes": [
                        "global",
                        "product"
                      ]
                    }
                  },
                  "all_module_config_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/integrations"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductFeed": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique feed ID",
            "example": 15
          },
          "name": {
            "type": "string",
            "description": "Display name of the feed",
            "example": "Tag VIP buyers"
          },
          "enabled": {
            "type": "string",
            "description": "Status: yes or no",
            "enum": [
              "yes",
              "no"
            ],
            "example": "yes"
          },
          "provider": {
            "type": "string",
            "description": "Integration provider key",
            "example": "fluent-crm"
          },
          "feed": {
            "type": "object",
            "description": "Full feed configuration data including field mappings, conditionals, and variation targeting"
          },
          "scope": {
            "type": "string",
            "description": "Always 'product' for this endpoint",
            "example": "product"
          }
        }
      },
      "AvailableIntegration": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Display name"
          },
          "logo": {
            "type": "string",
            "format": "uri",
            "description": "Logo URL"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the integration is enabled"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Supported scopes",
            "example": [
              "global",
              "product"
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}