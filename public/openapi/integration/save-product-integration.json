{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{product_id}/integrations": {
      "post": {
        "operationId": "saveProductIntegrationFeed",
        "summary": "POST Save Product Integration Feed",
        "description": "Create a new product-level integration feed or update an existing one. Validates required fields and associates the feed with the specified product.",
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "description": "The product ID",
            "schema": {
              "type": "integer",
              "example": 123
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "integration_name",
                  "integration"
                ],
                "properties": {
                  "integration_name": {
                    "type": "string",
                    "description": "The integration provider key (e.g., `fluent-crm`)",
                    "example": "fluent-crm"
                  },
                  "integration_id": {
                    "type": "integer",
                    "description": "Existing feed ID to update. Omit to create a new feed.",
                    "example": 15
                  },
                  "integration": {
                    "type": "string",
                    "description": "JSON-encoded feed settings data",
                    "example": "{\"name\":\"Tag VIP buyers\",\"enabled\":\"yes\",\"list_id\":\"3\",\"conditional_variation_ids\":[101],\"merge_fields\":{},\"conditionals\":{\"conditions\":[],\"status\":false,\"type\":\"all\"}}"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    },
                    "integration_id": {
                      "type": "integer",
                      "description": "The feed ID"
                    },
                    "integration_name": {
                      "type": "string",
                      "description": "The integration provider key"
                    },
                    "created": {
                      "type": "boolean",
                      "description": "true if a new feed was created, false if an existing one was updated"
                    },
                    "feedData": {
                      "type": "object",
                      "description": "The validated and saved feed data"
                    }
                  },
                  "example": {
                    "message": "Integration has been successfully saved",
                    "integration_id": 15,
                    "integration_name": "fluent-crm",
                    "created": true,
                    "feedData": {
                      "name": "Tag VIP buyers",
                      "enabled": "yes",
                      "list_id": "3",
                      "conditional_variation_ids": [
                        101
                      ]
                    }
                  }
                },
                "example": {
                  "message": "Integration has been successfully saved",
                  "integration_id": 15,
                  "integration_name": "fluent-crm",
                  "created": true,
                  "feedData": {
                    "name": "Tag VIP buyers",
                    "enabled": "yes",
                    "list_id": "3",
                    "conditional_variation_ids": [
                      101
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Product not found"
                  }
                },
                "example": {
                  "message": "Product not found"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      }
                    }
                  },
                  "example": {
                    "message": "Please fill up the required fields:",
                    "errors": {
                      "name": "Feed Name is required."
                    }
                  }
                },
                "example": {
                  "message": "Please fill up the required fields:",
                  "errors": {
                    "name": "Feed Name is required."
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
