{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/integration/global-settings": {
      "post": {
        "operationId": "saveGlobalIntegrationSettings",
        "summary": "POST Save Global Integration Settings",
        "description": "Save or update global configuration settings for a specific integration provider (e.g., API keys, authentication credentials).",
        "tags": [
          "Integrations"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "settings_key",
                  "integration"
                ],
                "properties": {
                  "settings_key": {
                    "type": "string",
                    "description": "The integration provider key",
                    "example": "fluent-crm"
                  },
                  "integration": {
                    "type": "object",
                    "description": "The settings data to save (fields vary by provider)",
                    "example": {
                      "api_key": "your-api-key",
                      "api_url": "https://example.com"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "boolean"
                    }
                  },
                  "example": {
                    "message": "Settings saved successfully",
                    "status": true
                  }
                },
                "example": {
                  "message": "Settings saved successfully",
                  "status": true
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
