{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/options/attr/group/{group_id}/term/{term_id}": {
      "delete": {
        "operationId": "deleteAttributeTerm",
        "summary": "DELETE Delete Attribute Term",
        "description": "Delete an attribute term. The term can only be deleted if it is not currently in use by any product variations.",
        "tags": [
          "Labels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "description": "The attribute group ID.",
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "term_id",
            "in": "path",
            "required": true,
            "description": "The term ID to delete.",
            "schema": {
              "type": "integer",
              "example": 6
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attribute term deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "string",
                      "example": ""
                    },
                    "message": {
                      "type": "string",
                      "example": "Attribute term successfully deleted!"
                    }
                  }
                },
                "example": {
                  "data": "",
                  "message": "Attribute term successfully deleted!"
                }
              }
            }
          },
          "403": {
            "description": "Term is in use by product variations.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "This term is already in use, can not be deleted."
                    },
                    "code": {
                      "type": "integer",
                      "example": 403
                    }
                  }
                },
                "example": {
                  "message": "This term is already in use, can not be deleted.",
                  "code": 403
                }
              }
            }
          },
          "404": {
            "description": "Term not found or group mismatch.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Term not found in database, failed to remove."
                    },
                    "code": {
                      "type": "integer",
                      "example": 404
                    }
                  }
                },
                "example": {
                  "message": "Term not found in database, failed to remove.",
                  "code": 404
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}