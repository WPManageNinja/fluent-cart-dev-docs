{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/labels": {
      "get": {
        "operationId": "listLabels",
        "summary": "GET List Labels",
        "description": "Retrieve all available labels. Labels are tags that can be attached to orders, customers, or other entities for organizational purposes.",
        "tags": [
          "Labels"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns all labels.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "labels": {
                      "type": "object",
                      "properties": {
                        "labels": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Label"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "labels": {
                      "labels": [
                        {
                          "id": 1,
                          "value": "VIP"
                        },
                        {
                          "id": 2,
                          "value": "Wholesale"
                        },
                        {
                          "id": 3,
                          "value": "Priority"
                        }
                      ]
                    }
                  }
                },
                "example": {
                  "labels": {
                    "labels": [
                      {
                        "id": 1,
                        "value": "VIP"
                      },
                      {
                        "id": 2,
                        "value": "Wholesale"
                      },
                      {
                        "id": 3,
                        "value": "Priority"
                      }
                    ]
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "labels": {
                        "labels": [
                          {
                            "id": 1,
                            "value": "VIP"
                          },
                          {
                            "id": 2,
                            "value": "Wholesale"
                          },
                          {
                            "id": 3,
                            "value": "Priority"
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Label": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Label ID",
            "example": 1
          },
          "value": {
            "type": "string",
            "description": "Label name",
            "example": "VIP"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
