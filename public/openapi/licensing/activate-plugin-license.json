{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/license/": {
      "post": {
        "operationId": "activatePluginLicense",
        "summary": "POST Activate Plugin License",
        "description": "Activate a FluentCart Pro license key on this WordPress site.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "license_key"
                ],
                "properties": {
                  "license_key": {
                    "type": "string",
                    "description": "The FluentCart Pro license key to activate"
                  }
                }
              },
              "example": {
                "license_key": "DTPRO-A1B2-C3D4-E5F6"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "license_key": {
                      "type": "string"
                    },
                    "notice": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "html": {
                          "type": "string"
                        },
                        "timeout": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "status": "valid",
                  "license_key": "DTPRO-A1B2-C3D4-E5F6",
                  "notice": {
                    "id": "fluent_cart_license_activated",
                    "html": "<div>Your FluentCart Pro license has been activated successfully.</div>",
                    "timeout": 5000
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid license key or activation failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "examples": {
                  "invalid_key": {
                    "summary": "Invalid license key",
                    "value": {
                      "code": "invalid_license",
                      "message": "The provided license key is invalid or has expired."
                    }
                  },
                  "activation_limit": {
                    "summary": "Activation limit reached",
                    "value": {
                      "code": "activation_limit_reached",
                      "message": "This license key has reached its maximum number of activations."
                    }
                  }
                },
                "example": {
                  "success": false,
                  "code": "invalid_license_key",
                  "message": "The provided license key is invalid or has expired."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
