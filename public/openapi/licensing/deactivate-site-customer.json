{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/licenses/{license_key}/deactivate_site": {
      "post": {
        "operationId": "deactivateSiteCustomer",
        "summary": "POST Deactivate Site (Customer)",
        "description": "Deactivate a specific site from a license. The customer can only deactivate sites from their own licenses.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "license_key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The license key (alphanumeric with dashes)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "site_url"
                ],
                "properties": {
                  "site_url": {
                    "type": "string",
                    "description": "The site URL to deactivate"
                  }
                },
                "example": {
                  "site_url": "example.com"
                }
              },
              "example": {
                "site_url": "example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Site deactivated successfully"
                  }
                },
                "example": {
                  "message": "Site deactivated successfully"
                }
              }
            }
          },
          "422": {
            "description": "License not found or site not activated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Site not found or not activated for this license"
                  }
                },
                "example": {
                  "message": "Site not found or not activated for this license"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
