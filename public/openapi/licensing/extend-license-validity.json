{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/licensing/licenses/{id}/extend-validity": {
      "post": {
        "operationId": "extendLicenseValidity",
        "summary": "POST Extend License Validity",
        "description": "Change the expiration date of a license. Can extend, reduce, or set to lifetime. If the license status is not `active` or `inactive`, it will be automatically set to `active`.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The license ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "expiration_date"
                ],
                "properties": {
                  "expiration_date": {
                    "type": "string",
                    "description": "New expiration date in `YYYY-MM-DD HH:MM:SS` format, or the string `lifetime` to remove expiration"
                  }
                },
                "example": {
                  "expiration_date": "2027-06-15 00:00:00"
                }
              },
              "example": {
                "expiration_date": "2027-06-15 00:00:00"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "license": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "expiration_date": {
                          "type": "string",
                          "nullable": true
                        },
                        "status": {
                          "type": "string"
                        }
                      }
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "license": {
                      "id": 1,
                      "expiration_date": "2027-01-15 00:00:00",
                      "status": "active"
                    },
                    "message": "License validity extended!"
                  }
                },
                "example": {
                  "license": {
                    "id": 1,
                    "expiration_date": "2027-01-15 00:00:00",
                    "status": "active"
                  },
                  "message": "License validity extended!"
                }
              }
            }
          },
          "423": {
            "description": "Invalid expiration date",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Invalid expiration date!"
                  }
                },
                "example": {
                  "message": "Invalid expiration date!"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
