{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/licensing/licenses/customer/{id}": {
      "get": {
        "operationId": "getCustomerLicensesAdmin",
        "summary": "GET Get Customer Licenses (Admin)",
        "description": "Retrieve a paginated list of licenses belonging to a specific customer.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The customer ID"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination (default: 1)"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of records per page (default: 10)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "licenses": {
                      "type": "object",
                      "properties": {
                        "current_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "status": {
                                "type": "string"
                              },
                              "limit": {
                                "type": "integer"
                              },
                              "activation_count": {
                                "type": "integer"
                              },
                              "license_key": {
                                "type": "string"
                              },
                              "product_id": {
                                "type": "integer"
                              },
                              "variation_id": {
                                "type": "integer"
                              },
                              "order_id": {
                                "type": "integer"
                              },
                              "customer_id": {
                                "type": "integer"
                              },
                              "expiration_date": {
                                "type": "string",
                                "nullable": true
                              },
                              "customer": {
                                "type": "object"
                              },
                              "product_variant": {
                                "type": "object"
                              },
                              "order": {
                                "type": "object"
                              },
                              "product": {
                                "type": "object"
                              },
                              "activations_count": {
                                "type": "integer"
                              }
                            }
                          }
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "example": {
                    "licenses": {
                      "current_page": 1,
                      "data": [
                        {
                          "id": 1,
                          "status": "active",
                          "limit": 5,
                          "activation_count": 2,
                          "license_key": "DTPRO-A1B2-C3D4-E5F6",
                          "product_id": 10,
                          "variation_id": 15,
                          "order_id": 42,
                          "customer_id": 7,
                          "expiration_date": "2026-01-15 00:00:00",
                          "customer": {
                            "id": 7,
                            "first_name": "Sarah",
                            "last_name": "Johnson",
                            "email": "sarah.johnson@example.com"
                          },
                          "product_variant": {
                            "id": 15,
                            "title": "Personal License",
                            "price": 4900,
                            "product_id": 10
                          },
                          "order": {
                            "id": 42,
                            "invoice_no": "INV-042",
                            "status": "completed",
                            "total_amount": 4900
                          },
                          "product": {
                            "ID": 10,
                            "post_title": "Developer Toolkit Pro"
                          },
                          "activations_count": 2
                        }
                      ],
                      "per_page": 10,
                      "total": 5,
                      "last_page": 1
                    }
                  }
                },
                "example": {
                  "licenses": {
                    "current_page": 1,
                    "data": [
                      {
                        "id": 1,
                        "status": "active",
                        "limit": 5,
                        "activation_count": 2,
                        "license_key": "DTPRO-A1B2-C3D4-E5F6",
                        "product_id": 10,
                        "variation_id": 15,
                        "order_id": 42,
                        "customer_id": 7,
                        "expiration_date": "2026-01-15 00:00:00",
                        "customer": {
                          "id": 7,
                          "first_name": "Sarah",
                          "last_name": "Johnson",
                          "email": "sarah.johnson@example.com"
                        },
                        "product_variant": {
                          "id": 15,
                          "title": "Personal License",
                          "price": 4900,
                          "product_id": 10
                        },
                        "order": {
                          "id": 42,
                          "invoice_no": "INV-042",
                          "status": "completed",
                          "total_amount": 4900
                        },
                        "product": {
                          "ID": 10,
                          "post_title": "Developer Toolkit Pro"
                        },
                        "activations_count": 2
                      }
                    ],
                    "per_page": 10,
                    "total": 5,
                    "last_page": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
