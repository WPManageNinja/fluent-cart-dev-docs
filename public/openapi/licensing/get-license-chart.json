{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/license-chart": {
      "get": {
        "operationId": "getLicenseLineChart",
        "summary": "GET Get License Line Chart",
        "description": "Retrieve license data formatted for a line chart visualization.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object"
            },
            "description": "Request parameters object containing filters, date range, and grouping",
            "style": "deepObject",
            "explode": true
          },
          {
            "name": "params[startDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for the report (ISO 8601 format)",
            "example": "2024-01-01"
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for the report (ISO 8601 format)",
            "example": "2024-12-31"
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Grouping key for the chart (e.g., 'day', 'week', 'month')",
            "example": "month"
          },
          {
            "name": "params[filters]",
            "in": "query",
            "schema": {
              "type": "object"
            },
            "description": "Filter criteria",
            "required": false,
            "style": "deepObject",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "License chart data"
                },
                "example": {
                  "labels": [
                    "2024-01",
                    "2024-02",
                    "2024-03",
                    "2024-04",
                    "2024-05",
                    "2024-06"
                  ],
                  "datasets": [
                    {
                      "label": "Licenses Issued",
                      "data": [
                        18,
                        22,
                        28,
                        24,
                        32,
                        30
                      ]
                    },
                    {
                      "label": "Activations",
                      "data": [
                        25,
                        30,
                        38,
                        35,
                        45,
                        42
                      ]
                    }
                  ],
                  "summary": {
                    "total_licenses_issued": 154,
                    "total_activations": 215
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}