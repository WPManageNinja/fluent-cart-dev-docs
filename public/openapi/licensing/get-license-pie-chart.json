{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/license-pie-chart": {
      "get": {
        "operationId": "getLicensePieChart",
        "summary": "GET Get License Pie Chart",
        "description": "Retrieve license data formatted for a pie chart visualization.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object"
            },
            "description": "Request parameters object containing filters and date range",
            "style": "deepObject",
            "explode": true
          },
          {
            "name": "params[startDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for the report (ISO 8601 format)",
            "example": "2024-01-01"
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for the report (ISO 8601 format)",
            "example": "2024-12-31"
          },
          {
            "name": "params[filters]",
            "in": "query",
            "schema": {
              "type": "object"
            },
            "description": "Filter criteria",
            "required": false,
            "style": "deepObject",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "License pie chart data",
                  "example": {
                    "distribution": [
                      {
                        "label": "Active",
                        "value": 198,
                        "percentage": 80.8,
                        "color": "#67C23A"
                      },
                      {
                        "label": "Expired",
                        "value": 32,
                        "percentage": 13.1,
                        "color": "#E6A23C"
                      },
                      {
                        "label": "Revoked",
                        "value": 15,
                        "percentage": 6.1,
                        "color": "#F56C6C"
                      }
                    ],
                    "total_licenses": 245
                  }
                },
                "example": {
                  "distribution": [
                    {
                      "label": "Active",
                      "value": 198,
                      "percentage": 80.8,
                      "color": "#67C23A"
                    },
                    {
                      "label": "Expired",
                      "value": 32,
                      "percentage": 13.1,
                      "color": "#E6A23C"
                    },
                    {
                      "label": "Revoked",
                      "value": 15,
                      "percentage": 6.1,
                      "color": "#F56C6C"
                    }
                  ],
                  "total_licenses": 245
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
