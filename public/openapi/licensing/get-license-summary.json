{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/license-summary": {
      "get": {
        "operationId": "getLicenseSummary",
        "summary": "GET Get License Summary",
        "description": "Retrieve a summary of license statistics.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object"
            },
            "description": "Request parameters object containing filters and date range",
            "style": "deepObject",
            "explode": true
          },
          {
            "name": "params[startDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for the report (ISO 8601 format)",
            "example": "2024-01-01"
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for the report (ISO 8601 format)",
            "example": "2024-12-31"
          },
          {
            "name": "params[filters]",
            "in": "query",
            "schema": {
              "type": "object"
            },
            "description": "Filter criteria",
            "required": false,
            "style": "deepObject",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "License summary statistics",
                  "example": {
                    "total_licenses": 245,
                    "active_licenses": 198,
                    "expired_licenses": 32,
                    "revoked_licenses": 15,
                    "total_activations": 412,
                    "average_activations_per_license": 1.68,
                    "activation_limit_reached": 24
                  }
                },
                "example": {
                  "total_licenses": 245,
                  "active_licenses": 198,
                  "expired_licenses": 32,
                  "revoked_licenses": 15,
                  "total_activations": 412,
                  "average_activations_per_license": 1.68,
                  "activation_limit_reached": 24
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "total_licenses": 245,
                      "active_licenses": 198,
                      "expired_licenses": 32,
                      "revoked_licenses": 15,
                      "total_activations": 412,
                      "average_activations_per_license": 1.68,
                      "activation_limit_reached": 24
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
