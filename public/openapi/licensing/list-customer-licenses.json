{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/licenses/": {
      "get": {
        "operationId": "listCustomerLicenses",
        "summary": "GET List Customer Licenses",
        "description": "Retrieve a paginated list of licenses belonging to the currently logged-in customer.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination (default: 1)"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of records per page (default: 10)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "licenses": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "license_key": {
                                "type": "string"
                              },
                              "status": {
                                "type": "string"
                              },
                              "expiration_date": {
                                "type": "string",
                                "nullable": true
                              },
                              "variation_id": {
                                "type": "integer"
                              },
                              "activation_count": {
                                "type": "integer"
                              },
                              "limit": {
                                "type": "integer"
                              },
                              "product_id": {
                                "type": "integer"
                              },
                              "created_at": {
                                "type": "string"
                              },
                              "title": {
                                "type": "string"
                              },
                              "subtitle": {
                                "type": "string"
                              },
                              "renewal_url": {
                                "type": "string"
                              },
                              "has_upgrades": {
                                "type": "boolean"
                              },
                              "order": {
                                "type": "object",
                                "properties": {
                                  "uuid": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        },
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        }
                      }
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "licenses": {
                    "data": [
                      {
                        "license_key": "DTPRO-A1B2-C3D4-E5F6",
                        "status": "active",
                        "expiration_date": "2026-01-15 00:00:00",
                        "variation_id": 15,
                        "activation_count": 2,
                        "limit": 5,
                        "product_id": 10,
                        "created_at": "2025-01-15 10:30:00",
                        "title": "My Plugin",
                        "subtitle": "Pro License",
                        "renewal_url": "",
                        "has_upgrades": true,
                        "order": {
                          "uuid": "order-uuid-here"
                        }
                      }
                    ],
                    "total": 5,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
