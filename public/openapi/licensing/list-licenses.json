{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/licensing/licenses": {
      "get": {
        "operationId": "listLicenses",
        "summary": "GET List Licenses",
        "description": "Retrieve a paginated list of all licenses with optional filtering, sorting, and search.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Page number for pagination"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 200
            },
            "description": "Number of records per page (default: 10, max: 200)"
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Search term. Searches across license key, order ID, customer name, customer email, and activated site URLs. Also supports operator syntax (e.g., `license_key = abc123`)"
          },
          {
            "name": "sort_by",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Column to sort by (default: `id`). Must be a fillable column on the License model"
          },
          {
            "name": "sort_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "description": "Sort direction: `asc` or `desc` (default: `desc`)"
          },
          {
            "name": "active_view",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "expired",
                "disabled",
                "inactive"
              ]
            },
            "description": "Tab filter. One of: `active`, `expired`, `disabled`, `inactive`"
          },
          {
            "name": "filter_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ],
              "default": "simple"
            },
            "description": "Filter mode: `simple` (default) or `advanced`"
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded array of advanced filter groups (requires Pro). Supports filtering by product, customer, and license properties"
          },
          {
            "name": "with",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Eager-load relations. Supports relation names and `{relation}Count` for counts"
          },
          {
            "name": "select",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of columns to select"
          },
          {
            "name": "scopes",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Model scopes to apply"
          },
          {
            "name": "include_ids",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs that must always be included in results"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Limit number of records (used with non-paginated queries)"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Offset for records"
          },
          {
            "name": "user_tz",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "User timezone for date filtering (e.g., `America/New_York`)",
            "example": "America/New_York"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "licenses": {
                      "type": "object",
                      "properties": {
                        "current_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "status": {
                                "type": "string"
                              },
                              "limit": {
                                "type": "integer"
                              },
                              "activation_count": {
                                "type": "integer"
                              },
                              "license_key": {
                                "type": "string"
                              },
                              "product_id": {
                                "type": "integer"
                              },
                              "variation_id": {
                                "type": "integer"
                              },
                              "order_id": {
                                "type": "integer"
                              },
                              "parent_id": {
                                "type": "integer",
                                "nullable": true
                              },
                              "customer_id": {
                                "type": "integer"
                              },
                              "expiration_date": {
                                "type": "string",
                                "nullable": true
                              },
                              "subscription_id": {
                                "type": "integer",
                                "nullable": true
                              },
                              "created_at": {
                                "type": "string"
                              },
                              "updated_at": {
                                "type": "string"
                              }
                            }
                          }
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "licenses": {
                    "current_page": 1,
                    "data": [
                      {
                        "id": 1,
                        "status": "active",
                        "limit": 5,
                        "activation_count": 2,
                        "license_key": "DTPRO-A1B2-C3D4-E5F6",
                        "product_id": 10,
                        "variation_id": 15,
                        "order_id": 42,
                        "parent_id": null,
                        "customer_id": 7,
                        "expiration_date": "2026-01-15 00:00:00",
                        "subscription_id": 3,
                        "created_at": "2025-01-15 10:30:00",
                        "updated_at": "2025-06-15 10:35:00"
                      }
                    ],
                    "per_page": 10,
                    "total": 50,
                    "last_page": 5
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
