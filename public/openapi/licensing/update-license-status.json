{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/licensing/licenses/{id}/update_status": {
      "post": {
        "operationId": "updateLicenseStatus",
        "summary": "POST Update License Status",
        "description": "Change the status of a license.",
        "tags": [
          "Licensing"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The license ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "active",
                      "disabled",
                      "expired"
                    ],
                    "description": "New status. One of: `active`, `disabled`, `expired`"
                  }
                },
                "example": {
                  "status": "disabled"
                }
              },
              "example": {
                "status": "disabled"
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "status": "disabled"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "license": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer"
                        },
                        "status": {
                          "type": "string"
                        }
                      }
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "license": {
                      "id": 1,
                      "status": "disabled"
                    },
                    "message": "License status has been updated successfully!"
                  }
                },
                "example": {
                  "license": {
                    "id": 1,
                    "status": "disabled"
                  },
                  "message": "License status has been updated successfully!"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "license": {
                        "id": 1,
                        "status": "disabled"
                      },
                      "message": "License status has been updated successfully!"
                    }
                  }
                }
              }
            }
          },
          "423": {
            "description": "Invalid status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Invalid status!"
                  }
                },
                "example": {
                  "message": "Invalid status!"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Invalid status!"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
