{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/order_bump": {
      "post": {
        "operationId": "createOrderBump",
        "summary": "POST Create Order Bump",
        "description": "Create a new order bump promotion. The order bump is created with minimal data (title and source variant) and can be fully configured via the Update endpoint.",
        "tags": [
          "Order Bumps"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "src_object_id"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Display title for the order bump."
                  },
                  "src_object_id": {
                    "type": "integer",
                    "description": "The product variation ID that this order bump offers. Must reference an existing product variation."
                  }
                },
                "example": {
                  "title": "Add Extended Warranty",
                  "src_object_id": 42
                }
              },
              "example": {
                "title": "Add Extended Warranty",
                "src_object_id": 42
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "title": "Add Extended Warranty",
                    "src_object_id": 42
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    },
                    "id": {
                      "type": "integer",
                      "description": "The ID of the newly created order bump"
                    }
                  },
                  "example": {
                    "message": "Order bump created successfully",
                    "id": 5
                  }
                },
                "example": {
                  "message": "Order bump created successfully",
                  "id": 5
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Order bump created successfully",
                      "id": 5
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "success": false,
                    "data": {
                      "message": "Invalid request. Please check your input and try again."
                    }
                  }
                },
                "examples": {
                  "missingFields": {
                    "summary": "Missing required fields",
                    "value": {
                      "message": "Title and source object id are required"
                    }
                  },
                  "createFailed": {
                    "summary": "Creation failed",
                    "value": {
                      "message": "Failed to create order bump"
                    }
                  }
                },
                "example": {
                  "success": false,
                  "data": {
                    "message": "Invalid request. Please check your input and try again."
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
