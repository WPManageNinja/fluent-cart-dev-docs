{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "summary": "POST Create Order",
        "description": "Create a new order manually from the admin panel.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "order_items"
                ],
                "properties": {
                  "customer_id": {
                    "type": "integer",
                    "description": "ID of the customer placing the order"
                  },
                  "order_items": {
                    "type": "array",
                    "description": "Array of order items",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Order item ID (for updates)"
                        },
                        "order_id": {
                          "type": "integer",
                          "description": "Parent order ID"
                        },
                        "post_id": {
                          "type": "integer",
                          "description": "WordPress post ID of the product"
                        },
                        "variation_id": {
                          "type": "integer",
                          "description": "Product variation ID"
                        },
                        "object_id": {
                          "type": "integer",
                          "description": "Object reference ID"
                        },
                        "fulfillment_type": {
                          "type": "string",
                          "description": "`digital` or `physical`"
                        },
                        "payment_type": {
                          "type": "string",
                          "description": "Payment type (max 100 chars), e.g., `subscription`"
                        },
                        "quantity": {
                          "type": "integer",
                          "description": "Item quantity (min: 1)",
                          "minimum": 1
                        },
                        "post_title": {
                          "type": "string",
                          "description": "Product title (max 255 chars)"
                        },
                        "title": {
                          "type": "string",
                          "description": "Item title (max 255 chars)"
                        },
                        "price": {
                          "type": "number",
                          "description": "Item price in cents"
                        },
                        "unit_price": {
                          "type": "number",
                          "description": "Unit price in cents"
                        },
                        "shipping_charge": {
                          "type": "number",
                          "description": "Shipping charge in cents"
                        },
                        "item_cost": {
                          "type": "number",
                          "description": "Item cost in cents"
                        },
                        "item_total": {
                          "type": "number",
                          "description": "Item total in cents"
                        },
                        "tax_amount": {
                          "type": "number",
                          "description": "Tax amount in cents"
                        },
                        "discount_total": {
                          "type": "number",
                          "description": "Discount total in cents"
                        },
                        "total": {
                          "type": "number",
                          "description": "Total in cents"
                        },
                        "line_total": {
                          "type": "number",
                          "description": "Line total in cents"
                        },
                        "cart_index": {
                          "type": "integer",
                          "description": "Cart position index"
                        },
                        "rate": {
                          "type": "number",
                          "description": "Exchange rate"
                        },
                        "line_meta": {
                          "type": "array",
                          "description": "Line item metadata",
                          "items": {
                            "type": "object"
                          }
                        },
                        "other_info": {
                          "type": "object",
                          "description": "Additional item information"
                        }
                      }
                    }
                  },
                  "status": {
                    "type": "string",
                    "description": "Order status (max 50 chars)"
                  },
                  "invoice_no": {
                    "type": "string",
                    "description": "Invoice number (max 100 chars)"
                  },
                  "fulfillment_type": {
                    "type": "string",
                    "description": "Fulfillment type (max 50 chars)"
                  },
                  "type": {
                    "type": "string",
                    "description": "Order type (max 50 chars)"
                  },
                  "payment_method": {
                    "type": "string",
                    "description": "Payment method key (max 50 chars)"
                  },
                  "payment_method_title": {
                    "type": "string",
                    "description": "Payment method display title (max 50 chars)"
                  },
                  "payment_status": {
                    "type": "string",
                    "description": "Payment status (max 50 chars)"
                  },
                  "currency": {
                    "type": "string",
                    "description": "Currency code, e.g., `USD` (max 10 chars)"
                  },
                  "subtotal": {
                    "type": "number",
                    "description": "Order subtotal in cents"
                  },
                  "discount_tax": {
                    "type": "number",
                    "description": "Discount tax amount in cents"
                  },
                  "manual_discount_total": {
                    "type": "number",
                    "description": "Manual discount total in cents"
                  },
                  "coupon_discount_total": {
                    "type": "number",
                    "description": "Coupon discount total in cents"
                  },
                  "shipping_tax": {
                    "type": "number",
                    "description": "Shipping tax in cents"
                  },
                  "shipping_total": {
                    "type": "number",
                    "description": "Shipping total in cents"
                  },
                  "tax_total": {
                    "type": "number",
                    "description": "Tax total in cents"
                  },
                  "total_amount": {
                    "type": "number",
                    "description": "Total order amount in cents"
                  },
                  "rate": {
                    "type": "number",
                    "description": "Exchange rate"
                  },
                  "note": {
                    "type": "string",
                    "description": "Order note (max 5000 chars)"
                  },
                  "uuid": {
                    "type": "string",
                    "description": "Order UUID (max 100 chars)"
                  },
                  "ip_address": {
                    "type": "string",
                    "description": "Customer IP address (max 100 chars)"
                  },
                  "completed_at": {
                    "type": "string",
                    "description": "Completion timestamp (max 100 chars)"
                  },
                  "refunded_at": {
                    "type": "string",
                    "description": "Refund timestamp (max 100 chars)"
                  },
                  "user_tz": {
                    "type": "string",
                    "description": "User timezone (max 50 chars)"
                  },
                  "discount": {
                    "type": "object",
                    "description": "Manual discount details",
                    "properties": {
                      "type": {
                        "type": "string",
                        "description": "Discount type (max 100 chars)"
                      },
                      "value": {
                        "type": "number",
                        "description": "Discount value"
                      },
                      "label": {
                        "type": "string",
                        "description": "Discount label (max 100 chars)"
                      },
                      "reason": {
                        "type": "string",
                        "description": "Discount reason (max 100 chars)"
                      },
                      "action": {
                        "type": "string",
                        "description": "Discount action (max 100 chars)"
                      }
                    }
                  },
                  "shipping": {
                    "type": "array",
                    "description": "Shipping method details",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "description": "Shipping type (max 100 chars)"
                        },
                        "rate_name": {
                          "type": "string",
                          "description": "Shipping rate name (max 100 chars)"
                        },
                        "custom_price": {
                          "type": "number",
                          "description": "Custom shipping price in cents"
                        }
                      }
                    }
                  },
                  "applied_coupon": {
                    "type": "array",
                    "description": "Applied coupon details",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Applied coupon record ID"
                        },
                        "order_id": {
                          "type": "integer",
                          "description": "Order ID"
                        },
                        "coupon_id": {
                          "type": "integer",
                          "description": "Coupon ID (min: 1)"
                        },
                        "code": {
                          "type": "string",
                          "description": "Coupon code (max 100 chars)"
                        },
                        "amount": {
                          "type": "number",
                          "description": "Coupon amount"
                        },
                        "discounted_amount": {
                          "type": "number",
                          "description": "Discounted amount in cents"
                        },
                        "discount": {
                          "type": "number",
                          "description": "Discount value"
                        },
                        "stackable": {
                          "type": "integer",
                          "description": "Whether coupon is stackable (0 or 1)"
                        },
                        "priority": {
                          "type": "integer",
                          "description": "Coupon priority"
                        },
                        "max_uses": {
                          "type": "integer",
                          "description": "Maximum uses"
                        },
                        "use_count": {
                          "type": "integer",
                          "description": "Current use count"
                        },
                        "max_per_customer": {
                          "type": "integer",
                          "description": "Max uses per customer (min: 1)"
                        },
                        "min_purchase_amount": {
                          "type": "number",
                          "description": "Minimum purchase amount in cents"
                        },
                        "max_discount_amount": {
                          "type": "number",
                          "description": "Maximum discount amount in cents"
                        },
                        "notes": {
                          "type": "string",
                          "description": "Coupon notes (max 100 chars)"
                        }
                      }
                    }
                  },
                  "trigger": {
                    "type": "string",
                    "description": "Trigger source"
                  }
                },
                "example": {
                  "customer_id": 1,
                  "order_items": [
                    {
                      "post_id": 10,
                      "variation_id": 5,
                      "object_id": 5,
                      "quantity": 1,
                      "unit_price": 2500,
                      "price": 2500,
                      "item_total": 2500,
                      "total": 2500,
                      "line_total": 2500,
                      "title": "Pro License"
                    }
                  ],
                  "subtotal": 2500,
                  "total_amount": 2500,
                  "payment_method": "offline_payment"
                }
              },
              "example": {
                "customer_id": 1,
                "order_items": [
                  {
                    "post_id": 10,
                    "variation_id": 5,
                    "object_id": 5,
                    "quantity": 1,
                    "unit_price": 2500,
                    "price": 2500,
                    "item_total": 2500,
                    "total": 2500,
                    "line_total": 2500,
                    "title": "Pro License"
                  }
                ],
                "subtotal": 2500,
                "total_amount": 2500,
                "payment_method": "offline_payment"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    },
                    "order_id": {
                      "type": "integer",
                      "description": "Created order ID"
                    },
                    "uuid": {
                      "type": "string",
                      "description": "Created order UUID"
                    }
                  },
                  "example": {
                    "message": "Order created successfully!",
                    "order_id": 42,
                    "uuid": "abc123-def456-ghi789"
                  }
                },
                "example": {
                  "message": "Order created successfully!",
                  "order_id": 42,
                  "uuid": "abc123-def456-ghi789"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
