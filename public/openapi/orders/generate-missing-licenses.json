{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order}/generate-missing-licenses": {
      "post": {
        "operationId": "generateMissingLicenses",
        "summary": "POST Generate Missing Licenses",
        "description": "Generate any missing license keys for an order's items (requires Pro with licensing module).",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Missing licenses generated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    }
                  },
                  "example": {
                    "message": "Missing licenses generated successfully"
                  }
                },
                "example": {
                  "message": "Missing licenses generated successfully"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Missing licenses generated successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "No missing licenses found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "No missing licenses found!"
                  }
                },
                "example": {
                  "message": "No missing licenses found!"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "No missing licenses found!"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Order not found"
                  }
                },
                "example": {
                  "message": "Order not found"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Order not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
