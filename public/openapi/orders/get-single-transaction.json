                "schema": {
                  "type": "object",
                  "properties": {
                    "order": {
                      "type": "object",
                      "description": "Full order object with relations"
                    },
                    "discount_meta": {
                      "type": "object",
                      "description": "Discount metadata"
                    },
                    "shipping_meta": {
                      "type": "object",
                      "description": "Shipping metadata"
                    },
                    "order_settings": {
                      "type": "object",
                      "description": "Order settings"
                    },
                    "selected_labels": {
                      "type": "array",
                      "description": "Array of selected label IDs",
                      "items": {
                        "type": "integer"
                      }
                    },
                    "tax_id": {
                      "type": "integer",
                      "nullable": true,
                      "description": "Tax ID if applicable"
                    }
                  },
                  "example": {
                    "order": {
                      "id": 42,
                      "uuid": "ord_a1b2c3d4e5f6",
                      "invoice_no": "INV-042",
