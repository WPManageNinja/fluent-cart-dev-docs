            "description": "Filter by payment status",
            "required": false
          },
          {
            "name": "customer_id",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by customer ID",
            "required": false
          },
          {
            "name": "order_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Sort field",
            "example": "id"
          },
          {
            "name": "order_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["ASC", "DESC"],
              "default": "DESC"
            },
            "description": "Sort direction",
            "example": "DESC"
          }
        ],
