{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "GET List Orders",
        "description": "Retrieve a paginated list of orders with optional filtering, sorting, and search.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for pagination",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 200
            },
            "description": "Number of records per page (default: 10, max: 200)",
            "required": false
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search term. Searches invoice number, customer name/email, and order item titles. Also supports operator syntax (e.g., `status = completed`, `id > 5`, `id :: 1-10`)",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Column to sort by (default: `id`). Must be a fillable column on the Order model",
            "required": false
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "description": "Sort direction: `asc` or `desc` (default: `desc`)",
            "required": false
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "on-hold",
                "paid",
                "completed",
                "processing",
                "renewal",
                "subscription",
                "onetime",
                "refunded",
                "partially_refunded",
                "upgraded_to",
                "upgraded_from"
              ]
            },
            "description": "Tab filter for quick views",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ],
              "default": "simple"
            },
            "description": "Filter mode: `simple` (default) or `advanced`",
            "required": false
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded array of advanced filter groups (requires Pro). Supports filtering by order properties, customer properties, transaction properties, license properties, and UTM properties",
            "required": false
          },
          {
            "name": "with",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Eager-load relations. Supports relation names and `{relation}Count` for counts",
            "required": false
          },
          {
            "name": "select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of columns to select",
            "required": false
          },
          {
            "name": "include_ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs that must always be included in results",
            "required": false
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Limit number of records (used with non-paginated queries)",
            "required": false
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Offset for records",
            "required": false
          },
          {
            "name": "user_tz",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "User timezone for date filtering (e.g., `America/New_York`)",
            "required": false
          },
          {
            "name": "payment_statuses",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Filter by payment statuses",
            "required": false
          },
          {
            "name": "order_statuses",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Filter by order statuses",
            "required": false
          },
          {
            "name": "shipping_statuses",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Filter by shipping statuses",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of orders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "object",
                      "description": "Paginated response",
                      "properties": {
                        "current_page": {
                          "type": "integer",
                          "description": "Current page number"
                        },
                        "data": {
                          "type": "array",
                          "description": "Array of order objects",
                          "items": {
                            "type": "object"
                          }
                        },
                        "per_page": {
                          "type": "integer",
                          "description": "Items per page"
                        },
                        "total": {
                          "type": "integer",
                          "description": "Total number of records"
                        },
                        "last_page": {
                          "type": "integer",
                          "description": "Last page number"
                        }
                      }
                    }
                  },
