{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order}/mark-as-paid": {
      "post": {
        "operationId": "markOrderAsPaid",
        "summary": "POST Mark Order as Paid",
        "description": "Mark a pending order as paid, creating or updating the transaction record.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "payment_method": {
                    "type": "string",
                    "description": "Payment method used (e.g., `offline_payment`, `stripe`)"
                  },
                  "vendor_charge_id": {
                    "type": "string",
                    "description": "External payment reference/charge ID"
                  },
                  "transaction_type": {
                    "type": "string",
                    "description": "Transaction type identifier"
                  },
                  "mark_paid_note": {
                    "type": "string",
                    "description": "Note to attach to the order"
                  }
                },
                "example": {
                  "payment_method": "offline_payment",
                  "vendor_charge_id": "CHK-12345",
                  "mark_paid_note": "Payment received via bank transfer"
                }
              },
              "example": {
                "payment_method": "offline_payment",
                "vendor_charge_id": "CHK-12345",
                "mark_paid_note": "Payment received via bank transfer"
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "payment_method": "offline_payment",
                    "vendor_charge_id": "CHK-12345",
                    "mark_paid_note": "Payment received via bank transfer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order marked as paid successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    }
                  },
                  "example": {
                    "message": "Order has been marked as paid"
                  }
                },
                "example": {
                  "message": "Order has been marked as paid"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Order has been marked as paid"
                    }
                  }
                }
              }
            }
          },
          "423": {
            "description": "Order cannot be marked as paid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Order has already been paid"
                  }
                },
                "example": {
                  "message": "Order has already been paid"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Order has already been paid"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
