{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order_id}/refund": {
      "post": {
        "operationId": "refundOrder",
        "summary": "POST Refund Order",
        "description": "Process a full or partial refund for an order. Supports both gateway refunds and manual refunds, with optional subscription cancellation.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "refund_info"
                ],
                "properties": {
                  "refund_info": {
                    "type": "object",
                    "required": [
                      "transaction_id",
                      "amount"
                    ],
                    "description": "Refund details object",
                    "properties": {
                      "transaction_id": {
                        "type": "integer",
                        "description": "ID of the transaction to refund"
                      },
                      "amount": {
                        "type": "number",
                        "description": "Refund amount in decimal format (e.g., 10.00 not cents). Will be converted to cents internally"
                      },
                      "cancelSubscription": {
                        "type": "string",
                        "description": "Set to `\"true\"` to cancel associated subscription"
                      }
                    }
                  }
                },
                "example": {
                  "refund_info": {
                    "transaction_id": 15,
                    "amount": 25.0,
                    "cancelSubscription": "true"
                  }
                }
              },
              "example": {
                "refund_info": {
                  "transaction_id": 15,
                  "amount": 25.0,
                  "cancelSubscription": "true"
                }
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "refund_info": {
                      "transaction_id": 15,
                      "amount": 25.0,
                      "cancelSubscription": "true"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund processed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fluent_cart_refund": {
                      "type": "object",
                      "description": "FluentCart refund status",
                      "properties": {
                        "status": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    },
                    "gateway_refund": {
                      "type": "object",
                      "description": "Payment gateway refund status",
                      "properties": {
                        "status": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    },
                    "subscription_cancel": {
                      "type": "object",
                      "description": "Subscription cancellation status (if cancelSubscription was true)",
                      "properties": {
                        "status": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "example": {
                    "fluent_cart_refund": {
                      "status": "success",
                      "message": "Refund processed on FluentCart."
                    },
                    "gateway_refund": {
                      "status": "success",
                      "message": "Refund processed on Stripe"
                    },
                    "subscription_cancel": {
                      "status": "success",
                      "message": "Subscription cancelled successfully"
                    }
                  }
                },
                "example": {
                  "fluent_cart_refund": {
                    "status": "success",
                    "message": "Refund processed on FluentCart."
                  },
                  "gateway_refund": {
                    "status": "success",
                    "message": "Refund processed on Stripe"
                  },
                  "subscription_cancel": {
                    "status": "success",
                    "message": "Subscription cancelled successfully"
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "fluent_cart_refund": {
                        "status": "success",
                        "message": "Refund processed on FluentCart."
                      },
                      "gateway_refund": {
                        "status": "success",
                        "message": "Refund processed on Stripe"
                      },
                      "subscription_cancel": {
                        "status": "success",
                        "message": "Subscription cancelled successfully"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Order cannot be refunded.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Order can not be refunded"
                  }
                },
                "example": {
                  "message": "Order can not be refunded"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Order can not be refunded"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Transaction ID is required"
                  }
                },
                "example": {
                  "message": "Transaction ID is required"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Transaction ID is required"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
