{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order}/sync-statuses": {
      "put": {
        "operationId": "syncOrderStatuses",
        "summary": "PUT Sync Order Statuses",
        "description": "Synchronize the order's status and payment status based on the latest transaction data. Useful for resolving status mismatches.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Order statuses synced successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    },
                    "order": {
                      "type": "object",
                      "description": "Updated order object"
                    },
                    "payment_status": {
                      "type": "string",
                      "description": "Synced payment status"
                    },
                    "status": {
                      "type": "string",
                      "description": "Synced order status"
                    }
                  }
                },
                "example": {
                  "message": "Order statuses synced successfully",
                  "order": {},
                  "payment_status": "paid",
                  "status": "processing"
                }
              }
            }
          },
          "404": {
            "description": "No transaction found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "No transaction found for this order"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}