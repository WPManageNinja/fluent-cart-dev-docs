{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order}/sync-statuses": {
      "put": {
        "operationId": "syncOrderStatuses",
        "summary": "PUT Sync Order Statuses",
        "description": "Synchronize the order's status and payment status based on the latest transaction data. Useful for resolving status mismatches.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Order statuses synced successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    },
                    "order": {
                      "type": "object",
                      "description": "Updated order object"
                    },
                    "payment_status": {
                      "type": "string",
                      "description": "Synced payment status"
                    },
                    "status": {
                      "type": "string",
                      "description": "Synced order status"
                    }
                  },
                  "example": {
                    "message": "Order statuses synced successfully",
                    "order": {
                      "id": 42,
                      "uuid": "ord_a1b2c3d4e5f6",
                      "invoice_no": "INV-042",
                      "status": "processing",
                      "payment_status": "paid",
                      "payment_method": "stripe",
                      "payment_method_title": "Credit Card (Stripe)",
                      "type": "payment",
                      "fulfillment_type": "digital",
                      "currency": "USD",
                      "subtotal": 9900,
                      "total_amount": 10692,
                      "total_paid": 10692,
                      "total_refund": 0,
                      "customer_id": 12,
                      "mode": "live",
                      "created_at": "2025-09-20 14:25:00",
                      "updated_at": "2025-09-20 14:30:00"
                    },
                    "payment_status": "paid",
                    "status": "processing"
                  }
                },
                "example": {
                  "message": "Order statuses synced successfully",
                  "order": {
                    "id": 42,
                    "uuid": "ord_a1b2c3d4e5f6",
                    "invoice_no": "INV-042",
                    "status": "processing",
                    "payment_status": "paid",
                    "payment_method": "stripe",
                    "payment_method_title": "Credit Card (Stripe)",
                    "type": "payment",
                    "fulfillment_type": "digital",
                    "currency": "USD",
                    "subtotal": 9900,
                    "total_amount": 10692,
                    "total_paid": 10692,
                    "total_refund": 0,
                    "customer_id": 12,
                    "mode": "live",
                    "created_at": "2025-09-20 14:25:00",
                    "updated_at": "2025-09-20 14:30:00"
                  },
                  "payment_status": "paid",
                  "status": "processing"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Order statuses synced successfully",
                      "order": {
                        "id": 42,
                        "uuid": "ord_a1b2c3d4e5f6",
                        "invoice_no": "INV-042",
                        "status": "processing",
                        "payment_status": "paid",
                        "payment_method": "stripe",
                        "payment_method_title": "Credit Card (Stripe)",
                        "type": "payment",
                        "fulfillment_type": "digital",
                        "currency": "USD",
                        "subtotal": 9900,
                        "total_amount": 10692,
                        "total_paid": 10692,
                        "total_refund": 0,
                        "customer_id": 12,
                        "mode": "live",
                        "created_at": "2025-09-20 14:25:00",
                        "updated_at": "2025-09-20 14:30:00"
                      },
                      "payment_status": "paid",
                      "status": "processing"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "No transaction found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "No transaction found for this order"
                  }
                },
                "example": {
                  "message": "No transaction found for this order"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "No transaction found for this order"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
