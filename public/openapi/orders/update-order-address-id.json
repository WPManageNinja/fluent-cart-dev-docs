{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order_id}/update-address-id": {
      "post": {
        "operationId": "updateOrderAddressId",
        "summary": "POST Update Order Address ID",
        "description": "Assign an existing customer address to an order's billing or shipping address.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "address_id"
                ],
                "properties": {
                  "address_id": {
                    "type": "integer",
                    "description": "Customer address ID to assign"
                  },
                  "address_type": {
                    "type": "string",
                    "description": "Address type: `billing` (default) or `shipping`",
                    "enum": [
                      "billing",
                      "shipping"
                    ],
                    "default": "billing"
                  }
                },
                "example": {
                  "address_id": 5,
                  "address_type": "billing"
                }
              },
              "example": {
                "address_id": 5,
                "address_type": "billing"
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "address_id": 5,
                    "address_type": "billing"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    }
                  },
                  "example": {
                    "message": "Address updated successfully"
                  }
                },
                "example": {
                  "message": "Address updated successfully"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Address updated successfully"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Order not found"
                  }
                },
                "example": {
                  "message": "Order not found"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Order not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
