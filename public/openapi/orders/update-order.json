{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order_id}": {
      "post": {
        "operationId": "updateOrder",
        "summary": "POST Update Order",
        "description": "Update an existing order's details, items, discounts, shipping, and coupons. Subscription orders cannot be edited.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customer_id",
                  "order_items"
                ],
                "properties": {
                  "customer_id": {
                    "type": "integer",
                    "description": "Customer ID"
                  },
                  "order_items": {
                    "type": "array",
                    "description": "Updated array of order items (same structure as Create Order)",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Order item ID (for updates)"
                        },
                        "order_id": {
                          "type": "integer",
                          "description": "Parent order ID"
                        },
                        "post_id": {
                          "type": "integer",
                          "description": "WordPress post ID of the product"
                        },
                        "variation_id": {
                          "type": "integer",
                          "description": "Product variation ID"
                        },
                        "quantity": {
                          "type": "integer",
                          "description": "Item quantity",
                          "minimum": 1
                        },
                        "unit_price": {
                          "type": "number",
                          "description": "Unit price in cents"
                        },
                        "line_total": {
                          "type": "number",
                          "description": "Line total in cents"
                        },
                        "title": {
                          "type": "string",
                          "description": "Item title"
                        }
                      }
                    }
                  },
                  "status": {
                    "type": "string",
                    "description": "Order status (cannot be set to `completed`)"
                  },
                  "payment_status": {
                    "type": "string",
                    "description": "Payment status"
                  },
                  "subtotal": {
                    "type": "number",
                    "description": "Updated subtotal in cents"
                  },
                  "total_amount": {
                    "type": "number",
                    "description": "Updated total amount in cents"
                  },
                  "total_paid": {
                    "type": "number",
                    "description": "Total amount already paid in cents"
                  },
                  "shipping_total": {
                    "type": "number",
                    "description": "Updated shipping total in cents"
                  },
                  "tax_total": {
                    "type": "number",
                    "description": "Updated tax total in cents"
                  },
                  "manual_discount_total": {
                    "type": "number",
                    "description": "Manual discount in cents"
                  },
                  "coupon_discount_total": {
                    "type": "number",
                    "description": "Coupon discount in cents"
                  },
                  "discount": {
                    "type": "object",
                    "description": "Discount details (see Create Order)"
                  },
                  "shipping": {
                    "type": "array",
                    "description": "Shipping details (see Create Order)",
                    "items": {
                      "type": "object"
                    }
                  },
                  "applied_coupon": {
                    "type": "array",
                    "description": "Applied coupon details (see Create Order)",
                    "items": {
                      "type": "object"
                    }
                  },
                  "deletedItems": {
                    "type": "array",
                    "description": "Array of order item IDs to remove",
                    "items": {
                      "type": "integer"
                    }
                  },
                  "couponCalculation": {
                    "type": "array",
                    "description": "Coupon calculation details",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              },
              "example": {
                "customer_id": 1,
                "order_items": [
                  {
                    "id": 10,
                    "order_id": 42,
                    "quantity": 2,
                    "unit_price": 2500,
                    "line_total": 5000
                  }
                ],
                "subtotal": 5000,
                "total_amount": 5000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    },
                    "order": {
                      "type": "object",
                      "description": "Updated order object"
                    }
                  }
                },
                "example": {
                  "message": "Order updated successfully",
                  "order": {}
                }
              }
            }
          },
          "400": {
            "description": "Bad request - subscription order or completed status update.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Subscription Order cannot be edited"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}