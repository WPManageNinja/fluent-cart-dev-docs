{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order}/statuses": {
      "put": {
        "operationId": "updateOrderStatuses",
        "summary": "PUT Update Statuses",
        "description": "Update the order status or shipping status for an order.",
        "tags": [
          "Orders"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Order ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action",
                  "statuses"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "description": "Status change type: `change_order_status` or `change_shipping_status`",
                    "enum": [
                      "change_order_status",
                      "change_shipping_status"
                    ]
                  },
                  "statuses": {
                    "type": "object",
                    "description": "Status values object",
                    "properties": {
                      "order_status": {
                        "type": "string",
                        "description": "New order status. Required when action is `change_order_status`. One of: `completed`, `processing`, `on-hold`, `canceled`"
                      },
                      "shipping_status": {
                        "type": "string",
                        "description": "New shipping status. Required when action is `change_shipping_status`"
                      }
                    }
                  },
                  "manage_stock": {
                    "type": "boolean",
                    "description": "Whether to adjust stock levels on status change"
                  }
                },
                "example": {
                  "action": "change_order_status",
                  "statuses": {
                    "order_status": "processing"
                  },
                  "manage_stock": true
                }
              },
              "example": {
                "action": "change_order_status",
                "statuses": {
                  "order_status": "processing"
                },
                "manage_stock": true
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "action": "change_order_status",
                    "statuses": {
                      "order_status": "processing"
                    },
                    "manage_stock": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "Success message"
                    },
                    "data": {
                      "type": "object",
                      "description": "Updated data"
                    }
                  },
                  "example": {
                    "message": "Status has been updated",
                    "data": {
                      "order_id": 42,
                      "old_status": "pending",
                      "new_status": "processing",
                      "updated_at": "2025-09-20 15:00:00"
                    }
                  }
                },
                "example": {
                  "message": "Status has been updated",
                  "data": {
                    "order_id": 42,
                    "old_status": "pending",
                    "new_status": "processing",
                    "updated_at": "2025-09-20 15:00:00"
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Status has been updated",
                      "data": {
                        "order_id": 42,
                        "old_status": "pending",
                        "new_status": "processing",
                        "updated_at": "2025-09-20 15:00:00"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Order already has the same status"
                  }
                },
                "example": {
                  "message": "Order already has the same status"
                },
                "examples": {
                  "default": {
                    "summary": "Error response",
                    "value": {
                      "message": "Order already has the same status"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
