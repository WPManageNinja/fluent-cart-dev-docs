{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{product_id}/integrations/feed/change-status": {
      "post": {
        "operationId": "changeIntegrationStatus",
        "summary": "POST Change Integration Status",
        "description": "Enable or disable a product integration feed.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The product ID",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "notification_id",
                  "status"
                ],
                "properties": {
                  "notification_id": {
                    "type": "integer",
                    "description": "The integration feed ID"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "yes",
                      "no"
                    ],
                    "description": "yes to enable, no to disable"
                  }
                }
              },
              "example": {
                "product_id": 123,
                "notification_id": 10,
                "status": "yes"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Integration status has been updated"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}