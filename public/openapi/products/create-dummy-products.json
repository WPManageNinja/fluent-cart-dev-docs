{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/create-dummy": {
      "post": {
        "operationId": "createDummyProducts",
        "summary": "POST Create Dummy Products",
        "description": "Create sample/demo products for testing or onboarding purposes.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "string",
                    "description": "Product category for dummy products"
                  },
                  "index": {
                    "type": "integer",
                    "description": "Index for dummy product generation"
                  }
                },
                "example": {
                  "category": "digital",
                  "index": 1
                }
              },
              "example": {
                "category": "digital",
                "index": 1
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "category": "digital",
                    "index": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns the created dummy product data.",
            "content": {
              "application/json": {
                "example": {
                  "product": {
                    "ID": 135,
                    "post_title": "Sample Digital Product",
                    "post_status": "publish",
                    "post_type": "fluent-products",
                    "post_name": "sample-digital-product",
                    "detail": {
                      "id": 100,
                      "post_id": 135,
                      "fulfillment_type": "digital",
                      "variation_type": "single",
                      "manage_stock": 0
                    }
                  },
                  "message": "Dummy product created successfully"
                },
                "schema": {
                  "example": {
                    "product": {
                      "ID": 135,
                      "post_title": "Sample Digital Product",
                      "post_status": "publish",
                      "post_type": "fluent-products",
                      "post_name": "sample-digital-product",
                      "detail": {
                        "id": 100,
                        "post_id": 135,
                        "fulfillment_type": "digital",
                        "variation_type": "single",
                        "manage_stock": 0
                      }
                    },
                    "message": "Dummy product created successfully"
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "product": {
                        "ID": 135,
                        "post_title": "Sample Digital Product",
                        "post_status": "publish",
                        "post_type": "fluent-products",
                        "post_name": "sample-digital-product",
                        "detail": {
                          "id": 100,
                          "post_id": 135,
                          "fulfillment_type": "digital",
                          "variation_type": "single",
                          "manage_stock": 0
                        }
                      },
                      "message": "Dummy product created successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
