{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products": {
      "post": {
        "operationId": "createProduct",
        "summary": "POST Create Product",
        "description": "Create a new product. A default variation is automatically created with the product.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "post_title"
                ],
                "properties": {
                  "post_title": {
                    "type": "string",
                    "description": "Product title (max 200 characters)"
                  },
                  "post_status": {
                    "type": "string",
                    "description": "Post status",
                    "enum": [
                      "draft",
                      "publish"
                    ]
                  },
                  "detail": {
                    "type": "object",
                    "properties": {
                      "fulfillment_type": {
                        "type": "string",
                        "enum": [
                          "physical",
                          "digital"
                        ],
                        "description": "Fulfillment type (default: digital)"
                      },
                      "other_info": {
                        "type": "object",
                        "properties": {
                          "is_bundle_product": {
                            "type": "string",
                            "enum": [
                              "yes",
                              "no"
                            ],
                            "description": "Whether this is a bundle product (default: no)"
                          }
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "post_title": "New Digital Product",
                "post_status": "draft",
                "detail": {
                  "fulfillment_type": "digital"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "data": {
                    "ID": 124,
                    "variant": {
                      "id": 458,
                      "post_id": 124,
                      "serial_index": 0,
                      "variation_title": "New Digital Product",
                      "variation_identifier": "new-digital-product",
                      "sku": null,
                      "payment_type": "onetime",
                      "item_price": 0,
                      "item_cost": 0,
                      "compare_price": 0,
                      "item_status": "active",
                      "manage_stock": 0,
                      "stock_status": "in-stock",
                      "total_stock": 0,
                      "available": 0,
                      "committed": 0,
                      "on_hold": 0,
                      "fulfillment_type": "digital",
                      "downloadable": 0,
                      "sold_individually": 0,
                      "thumbnail": null
                    },
                    "product_details": {
                      "id": 91,
                      "post_id": 124,
                      "fulfillment_type": "digital",
                      "min_price": 0,
                      "max_price": 0,
                      "default_variation_id": 458,
                      "variation_type": "single",
                      "stock_availability": "in-stock",
                      "manage_stock": 0,
                      "manage_downloadable": 0,
                      "formatted_min_price": "$0.00",
                      "formatted_max_price": "$0.00"
                    }
                  },
                  "message": "Product has been created successfully"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}