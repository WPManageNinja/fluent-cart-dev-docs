{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/variants": {
      "post": {
        "operationId": "createVariation",
        "summary": "POST Create Variation",
        "description": "Create a new product variation.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "variants"
                ],
                "properties": {
                  "variants": {
                    "type": "object",
                    "required": [
                      "post_id",
                      "variation_title",
                      "fulfillment_type",
                      "total_stock",
                      "available",
                      "committed",
                      "on_hold"
                    ],
                    "properties": {
                      "post_id": {
                        "type": "integer",
                        "description": "Parent product ID"
                      },
                      "variation_title": {
                        "type": "string",
                        "description": "Variation title (max 200 chars)"
                      },
                      "sku": {
                        "type": "string",
                        "description": "SKU (max 30 chars, must be unique)"
                      },
                      "item_price": {
                        "type": "number",
                        "description": "Price in cents (min: 0)"
                      },
                      "compare_price": {
                        "type": "number",
                        "description": "Compare-at price in cents"
                      },
                      "manage_cost": {
                        "type": "string",
                        "description": "Enable cost tracking"
                      },
                      "item_cost": {
                        "type": "number",
                        "description": "Item cost (required if manage_cost is true)"
                      },
                      "fulfillment_type": {
                        "type": "string",
                        "enum": [
                          "physical",
                          "digital"
                        ]
                      },
                      "manage_stock": {
                        "type": "integer",
                        "enum": [
                          0,
                          1
                        ]
                      },
                      "stock_status": {
                        "type": "string",
                        "enum": [
                          "in-stock",
                          "out-of-stock"
                        ]
                      },
                      "total_stock": {
                        "type": "integer",
                        "description": "Total stock quantity"
                      },
                      "available": {
                        "type": "integer",
                        "description": "Available stock"
                      },
                      "committed": {
                        "type": "integer",
                        "description": "Committed stock"
                      },
                      "on_hold": {
                        "type": "integer",
                        "description": "Stock on hold"
                      },
                      "serial_index": {
                        "type": "integer",
                        "description": "Display order index"
                      },
                      "downloadable": {
                        "type": "string",
                        "description": "Downloadable flag"
                      },
                      "other_info": {
                        "type": "object",
                        "properties": {
                          "payment_type": {
                            "type": "string",
                            "enum": [
                              "onetime",
                              "subscription"
                            ]
                          },
                          "description": {
                            "type": "string"
                          },
                          "repeat_interval": {
                            "type": "string"
                          },
                          "times": {
                            "type": "number"
                          },
                          "trial_days": {
                            "type": "number"
                          },
                          "billing_summary": {
                            "type": "string"
                          },
                          "manage_setup_fee": {
                            "type": "string"
                          },
                          "signup_fee": {
                            "type": "number"
                          },
                          "signup_fee_name": {
                            "type": "string"
                          }
                        }
                      },
                      "media": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "variants": {
                    "post_id": 123,
                    "variation_title": "Pro Plan",
                    "item_price": 2999,
                    "sku": "PRO-PLN",
                    "fulfillment_type": "digital",
                    "total_stock": 1,
                    "available": 1,
                    "committed": 0,
                    "on_hold": 0,
                    "other_info": {
                      "payment_type": "onetime"
                    }
                  }
                }
              },
              "example": {
                "variants": {
                  "post_id": 123,
                  "variation_title": "Pro Plan",
                  "item_price": 2999,
                  "sku": "PRO-PLN",
                  "fulfillment_type": "digital",
                  "total_stock": 1,
                  "available": 1,
                  "committed": 0,
                  "on_hold": 0,
                  "other_info": {
                    "payment_type": "onetime"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "variant": {
                    "id": 460,
                    "post_id": 123,
                    "serial_index": 2,
                    "variation_title": "Pro Plan",
                    "variation_identifier": "pro-plan",
                    "sku": "PRO-PLN",
                    "payment_type": "onetime",
                    "item_price": 2999,
                    "item_cost": 0,
                    "compare_price": 0,
                    "item_status": "active",
                    "manage_stock": 0,
                    "stock_status": "in-stock",
                    "total_stock": 0,
                    "available": 0,
                    "committed": 0,
                    "on_hold": 0,
                    "fulfillment_type": "digital",
                    "downloadable": 0,
                    "sold_individually": 0,
                    "thumbnail": null
                  },
                  "message": "Variation created successfully"
                },
                "schema": {
                  "example": {
                    "variant": {
                      "id": 460,
                      "post_id": 123,
                      "serial_index": 2,
                      "variation_title": "Pro Plan",
                      "variation_identifier": "pro-plan",
                      "sku": "PRO-PLN",
                      "payment_type": "onetime",
                      "item_price": 2999,
                      "item_cost": 0,
                      "compare_price": 0,
                      "item_status": "active",
                      "manage_stock": 0,
                      "stock_status": "in-stock",
                      "total_stock": 0,
                      "available": 0,
                      "committed": 0,
                      "on_hold": 0,
                      "fulfillment_type": "digital",
                      "downloadable": 0,
                      "sold_individually": 0,
                      "thumbnail": null
                    },
                    "message": "Variation created successfully"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
