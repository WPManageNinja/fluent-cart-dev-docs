{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/do-bulk-action": {
      "post": {
        "operationId": "doBulkAction",
        "summary": "POST Do Bulk Action",
        "description": "Perform bulk actions on selected products (e.g., publish, draft, delete).",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action",
                  "product_ids"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "description": "The bulk action to perform"
                  },
                  "product_ids": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of product IDs to act on"
                  }
                },
                "example": {
                  "action": "publish",
                  "product_ids": [
                    123,
                    456,
                    789
                  ]
                }
              },
              "example": {
                "action": "publish",
                "product_ids": [
                  123,
                  456,
                  789
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Bulk action completed successfully"
                },
                "schema": {
                  "example": {
                    "message": "Bulk action completed successfully"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
