  "paths": {
    "/products/fetchProductsByIds": {
      "get": {
        "operationId": "fetchProductsByIds",
        "summary": "GET Fetch Products by IDs",
        "description": "Retrieve products by an array of IDs. Returns products with their detail relation.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "productIds[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product IDs to fetch",
            "required": true
          }
        ],
