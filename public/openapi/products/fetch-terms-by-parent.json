{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/fetch-term-by-parent": {
      "post": {
        "operationId": "fetchTermsByParent",
        "summary": "POST Fetch Terms by Parent",
        "description": "Retrieve taxonomy terms filtered by parent term IDs.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "parents",
                  "listeners"
                ],
                "properties": {
                  "parents": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of parent term IDs"
                  },
                  "listeners": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of taxonomy names to retrieve terms for"
                  }
                },
                "example": {
                  "parents": [
                    1,
                    2
                  ],
                  "listeners": [
                    "product-categories"
                  ]
                }
              },
              "example": {
                "parents": [
                  1,
                  2
                ],
                "listeners": [
                  "product-categories"
                ]
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "parents": [
                      1,
                      2
                    ],
                    "listeners": [
                      "product-categories"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "data": {
                    "product-categories": [
                      {
                        "value": 11,
                        "label": "Developer Tools",
                        "parent": 10
                      },
                      {
                        "value": 12,
                        "label": "Plugins",
                        "parent": 10
                      }
                    ]
                  }
                },
                "schema": {
                  "example": {
                    "data": {
                      "product-categories": [
                        {
                          "value": 11,
                          "label": "Developer Tools",
                          "parent": 10
                        },
                        {
                          "value": 12,
                          "label": "Plugins",
                          "parent": 10
                        }
                      ]
                    }
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "data": {
                        "product-categories": [
                          {
                            "value": 11,
                            "label": "Developer Tools",
                            "parent": 10
                          },
                          {
                            "value": 12,
                            "label": "Plugins",
                            "parent": 10
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
