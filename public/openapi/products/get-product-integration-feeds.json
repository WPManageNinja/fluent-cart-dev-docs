{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{productId}/integrations": {
      "get": {
        "operationId": "getProductIntegrationFeeds",
        "summary": "GET Get Product Integration Feeds",
        "description": "Retrieve all integration feeds configured for a product, along with available integrations.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The product ID",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "feeds": [
                    {
                      "id": 10,
                      "name": "Add to FluentCRM List",
                      "enabled": "yes",
                      "provider": "fluentcrm",
                      "feed": {
                        "name": "Add to FluentCRM List",
                        "list_id": 1,
                        "tag_ids": [
                          5,
                          8
                        ],
                        "conditional_variation_ids": [],
                        "enabled": "yes"
                      },
                      "scope": "product"
                    }
                  ],
                  "available_integrations": {
                    "fluentcrm": {
                      "title": "FluentCRM",
                      "logo": "...",
                      "enabled": true,
                      "scopes": [
                        "product",
                        "order"
                      ]
                    }
                  },
                  "all_module_config_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/integrations"
                },
                "schema": {
                  "example": {
                    "feeds": [
                      {
                        "id": 10,
                        "name": "Add to FluentCRM List",
                        "enabled": "yes",
                        "provider": "fluentcrm",
                        "feed": {
                          "name": "Add to FluentCRM List",
                          "list_id": 1,
                          "tag_ids": [
                            5,
                            8
                          ],
                          "conditional_variation_ids": [],
                          "enabled": "yes"
                        },
                        "scope": "product"
                      }
                    ],
                    "available_integrations": {
                      "fluentcrm": {
                        "title": "FluentCRM",
                        "logo": "...",
                        "enabled": true,
                        "scopes": [
                          "product",
                          "order"
                        ]
                      }
                    },
                    "all_module_config_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/integrations"
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "feeds": [
                        {
                          "id": 10,
                          "name": "Add to FluentCRM List",
                          "enabled": "yes",
                          "provider": "fluentcrm",
                          "feed": {
                            "name": "Add to FluentCRM List",
                            "list_id": 1,
                            "tag_ids": [
                              5,
                              8
                            ],
                            "conditional_variation_ids": [],
                            "enabled": "yes"
                          },
                          "scope": "product"
                        }
                      ],
                      "available_integrations": {
                        "fluentcrm": {
                          "title": "FluentCRM",
                          "logo": "...",
                          "enabled": true,
                          "scopes": [
                            "product",
                            "order"
                          ]
                        }
                      },
                      "all_module_config_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/integrations"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
