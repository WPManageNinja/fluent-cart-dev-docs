{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "GET List Products",
        "description": "Retrieve a paginated list of products with filtering, sorting, and search capabilities.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by product title, ID, or variation title",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of results per page",
            "required": false
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "ID"
            },
            "description": "Column to sort by",
            "required": false
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "desc",
              "enum": [
                "asc",
                "desc"
              ]
            },
            "description": "Sort direction: asc or desc",
            "required": false
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "publish",
                "draft",
                "physical",
                "digital",
                "subscribable",
                "not_subscribable",
                "bundle",
                "non_bundle"
              ]
            },
            "description": "Filter tab",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ]
            },
            "description": "Filter type",
            "required": false
          },
          {
            "name": "with[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Relations to eager load",
            "required": false
          },
          {
            "name": "search_groups",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "description": "Advanced filter groups for complex queries",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of products.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "products": {
                    "total": 50,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 5,
                    "data": [
                      {
                        "ID": 123,
                        "post_title": "Example Product",
                        "post_status": "publish",
                        "post_date": "2025-01-15 12:00:00",
                        "view_url": "https://example.com/product/example-product",
                        "edit_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/products/123"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}