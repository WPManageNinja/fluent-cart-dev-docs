{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "GET List Products",
        "description": "Retrieve a paginated list of products with filtering, sorting, and search capabilities.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by product title, ID, or variation title",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of results per page",
            "required": false
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "ID"
            },
            "description": "Column to sort by",
            "required": false
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "desc",
              "enum": [
                "asc",
                "desc"
              ]
            },
            "description": "Sort direction: asc or desc",
            "required": false
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "publish",
                "draft",
                "physical",
                "digital",
                "subscribable",
                "not_subscribable",
                "bundle",
                "non_bundle"
              ]
            },
            "description": "Filter tab",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ]
            },
            "description": "Filter type",
            "required": false
          },
          {
            "name": "with[]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Relations to eager load",
            "required": false
          },
          {
            "name": "search_groups",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "description": "Advanced filter groups for complex queries",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of products.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "products": {
                      "total": 50,
                      "per_page": 10,
                      "current_page": 1,
                      "last_page": 5,
                      "data": [
                        {
                          "ID": 123,
                          "post_title": "Developer Toolkit Pro",
                          "post_status": "publish",
                          "post_type": "fluent-products",
                          "post_date": "2025-03-15 10:00:00",
                          "post_modified": "2025-09-01 15:30:00",
                          "post_name": "developer-toolkit-pro",
                          "post_excerpt": "Professional developer tools for building modern applications.",
                          "thumbnail": "https://example.com/wp-content/uploads/2025/03/dev-toolkit.png",
                          "view_url": "https://example.com/product/developer-toolkit-pro",
                          "edit_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/products/123",
                          "detail": {
                            "id": 89,
                            "post_id": 123,
                            "fulfillment_type": "digital",
                            "min_price": 4900,
                            "max_price": 19900,
                            "default_variation_id": 456,
                            "variation_type": "multi",
                            "stock_availability": "in-stock",
                            "formatted_min_price": "$49.00",
                            "formatted_max_price": "$199.00"
                          }
                        },
                        {
                          "ID": 124,
                          "post_title": "Cloud Hosting Starter",
