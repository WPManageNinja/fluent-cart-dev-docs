{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{postId}/sync-downloadable-files": {
      "post": {
        "operationId": "syncDownloadableFiles",
        "summary": "POST Sync Downloadable Files",
        "description": "Attach multiple downloadable files to a product. Automatically enables the manage_downloadable flag.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "postId",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The product post ID",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "downloadable_files"
                ],
                "properties": {
                  "downloadable_files": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "title",
                        "type",
                        "driver",
                        "file_name",
                        "file_path",
                        "file_url"
                      ],
                      "properties": {
                        "title": {
                          "type": "string",
                          "description": "File title (max 160 chars)"
                        },
                        "type": {
                          "type": "string",
                          "description": "File type (max 100 chars)"
                        },
                        "driver": {
                          "type": "string",
                          "description": "Storage driver (e.g., local, s3)"
                        },
                        "file_name": {
                          "type": "string",
                          "description": "File name (max 185 chars)"
                        },
                        "file_path": {
                          "type": "string",
                          "description": "File path (max 185 chars)"
                        },
                        "file_url": {
                          "type": "string",
                          "description": "File URL (max 200 chars)"
                        },
                        "bucket": {
                          "type": "string",
                          "description": "Storage bucket name"
                        },
                        "file_size": {
                          "type": "string",
                          "description": "File size"
                        },
                        "serial": {
                          "type": "integer",
                          "description": "Display order serial"
                        },
                        "product_variation_id": {
                          "type": "array",
                          "items": {
                            "type": "integer"
                          },
                          "description": "Variation IDs this file is associated with"
                        },
                        "settings": {
                          "type": "object",
                          "properties": {
                            "download_limit": {
                              "type": "integer",
                              "description": "Maximum number of downloads allowed"
                            },
                            "download_expiry": {
                              "type": "integer",
                              "description": "Download expiry in days"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "postId": 123,
                "downloadable_files": [
                  {
                    "title": "Software v1.0",
                    "type": "zip",
                    "driver": "local",
                    "file_name": "software-v1.zip",
                    "file_path": "software-v1.zip",
                    "file_url": "software-v1.zip",
                    "product_variation_id": [
                      456
                    ],
                    "settings": {
                      "download_limit": 5,
                      "download_expiry": 365
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "downloadable_files": [
                    {
                      "id": 1,
                      "post_id": 123,
                      "title": "Software v1.0",
                      "type": "zip",
                      "driver": "local",
                      "file_name": "software-v1.zip",
                      "download_identifier": "a1b2c3d4-..."
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}