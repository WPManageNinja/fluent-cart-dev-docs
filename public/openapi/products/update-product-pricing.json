{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{postId}/pricing": {
      "post": {
        "operationId": "updateProductPricing",
        "summary": "POST Update Product Pricing",
        "description": "Update a product's pricing, details, variants, and other metadata.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "postId",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The product post ID",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "post_title",
                  "post_status",
                  "detail"
                ],
                "properties": {
                  "post_title": {
                    "type": "string",
                    "description": "Product title (max 200 characters)"
                  },
                  "post_status": {
                    "type": "string",
                    "enum": [
                      "draft",
                      "publish",
                      "future"
                    ],
                    "description": "Product status"
                  },
                  "post_date": {
                    "type": "string",
                    "description": "Required when post_status is future. Must be a future date (GMT)"
                  },
                  "post_excerpt": {
                    "type": "string",
                    "description": "Product short description"
                  },
                  "post_content": {
                    "type": "string",
                    "description": "Product long description (HTML allowed)"
                  },
                  "post_name": {
                    "type": "string",
                    "description": "Product URL slug"
                  },
                  "comment_status": {
                    "type": "string",
                    "description": "Comment status (max 100 chars)"
                  },
                  "detail": {
                    "type": "object",
                    "required": [
                      "fulfillment_type",
                      "variation_type"
                    ],
                    "properties": {
                      "fulfillment_type": {
                        "type": "string",
                        "enum": [
                          "physical",
                          "digital"
                        ]
                      },
                      "variation_type": {
                        "type": "string",
                        "enum": [
                          "simple",
                          "simple_variations"
                        ]
                      },
                      "manage_stock": {
                        "type": "integer",
                        "enum": [
                          0,
                          1
                        ]
                      },
                      "manage_downloadable": {
                        "type": "integer",
                        "enum": [
                          0,
                          1
                        ]
                      },
                      "default_variation_id": {
                        "type": "integer"
                      },
                      "stock_availability": {
                        "type": "string"
                      },
                      "other_info": {
                        "type": "object",
                        "properties": {
                          "group_pricing_by": {
                            "type": "string",
                            "enum": [
                              "payment_type",
                              "repeat_interval",
                              "none"
                            ]
                          },
                          "sold_individually": {
                            "type": "string",
                            "enum": [
                              "yes",
                              "no"
                            ]
                          },
                          "use_pricing_table": {
                            "type": "string"
                          },
                          "shipping_class": {
                            "type": "integer"
                          },
                          "tax_class": {
                            "type": "integer"
                          },
                          "active_editor": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "variants": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "variation_title": {
                          "type": "string"
                        },
                        "post_id": {
                          "type": "integer"
                        },
                        "item_price": {
                          "type": "number"
                        },
                        "compare_price": {
                          "type": "number"
                        },
                        "manage_cost": {
                          "type": "string"
                        },
                        "item_cost": {
                          "type": "number"
                        },
                        "serial_index": {
                          "type": "integer"
                        },
                        "sku": {
                          "type": "string"
                        },
                        "fulfillment_type": {
                          "type": "string"
                        },
                        "other_info": {
                          "type": "object"
                        }
                      }
                    }
                  },
                  "product_terms": {
                    "type": "object",
                    "description": "Taxonomy term IDs"
                  },
                  "gallery": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "metaValue": {
                    "description": "Additional metadata"
                  }
                }
              },
              "example": {
                "post_title": "Updated Product",
                "post_status": "publish",
                "detail": {
                  "fulfillment_type": "digital",
                  "variation_type": "simple"
                },
                "variants": [
                  {
                    "id": 789,
                    "post_id": 123,
                    "variation_title": "Default Plan",
                    "item_price": 1999,
                    "other_info": {
                      "payment_type": "onetime"
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "data": {
                    "ID": 123,
                    "post_title": "Developer Toolkit Pro",
                    "post_status": "publish",
                    "post_name": "developer-toolkit-pro",
                    "post_excerpt": "Professional developer tools for building modern applications.",
                    "view_url": "https://example.com/product/developer-toolkit-pro",
                    "edit_url": "https://example.com/wp-admin/admin.php?page=fluent-cart#/products/123",
                    "detail": {
                      "id": 89,
                      "post_id": 123,
                      "fulfillment_type": "digital",
                      "min_price": 4900,
                      "max_price": 19900,
                      "default_variation_id": 456,
                      "variation_type": "multi",
                      "stock_availability": "in-stock",
                      "manage_stock": 0,
                      "manage_downloadable": 1,
                      "formatted_min_price": "$49.00",
                      "formatted_max_price": "$199.00"
                    },
                    "variants": [
                      {
                        "id": 456,
                        "post_id": 123,
                        "variation_title": "Personal License",
                        "item_price": 4900,
                        "compare_price": 6900,
                        "sku": "DTK-PERSONAL",
                        "stock_status": "in-stock",
                        "payment_type": "onetime",
                        "item_status": "active",
                        "fulfillment_type": "digital"
                      }
                    ]
                  },
                  "message": "Product updated successfully"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}