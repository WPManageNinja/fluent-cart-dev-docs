{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/upgrade-path/{id}/update": {
      "post": {
        "operationId": "updateUpgradePath",
        "summary": "POST Update Upgrade Path",
        "description": "Update an existing upgrade path.",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The upgrade path ID",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "from_variant",
                  "to_variants"
                ],
                "properties": {
                  "from_variant": {
                    "type": "integer",
                    "description": "Source variation ID"
                  },
                  "to_variants": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of target variation IDs"
                  },
                  "discount_amount": {
                    "type": "number",
                    "description": "Discount amount"
                  },
                  "title": {
                    "type": "string",
                    "description": "Upgrade path title"
                  },
                  "description": {
                    "type": "string",
                    "description": "Upgrade path description"
                  },
                  "slug": {
                    "type": "string",
                    "description": "Upgrade path slug"
                  }
                },
                "example": {
                  "from_variant": 456,
                  "to_variants": [
                    458,
                    459
                  ],
                  "discount_amount": 1000
                }
              },
              "example": {
                "from_variant": 456,
                "to_variants": [
                  458,
                  459
                ],
                "discount_amount": 1000
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "from_variant": 456,
                    "to_variants": [
                      458,
                      459
                    ],
                    "discount_amount": 1000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Settings updated successfully"
                },
                "schema": {
                  "example": {
                    "message": "Settings updated successfully"
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Settings updated successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
