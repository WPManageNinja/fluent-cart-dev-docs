{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/products/{postId}/update-variant-option": {
      "post": {
        "operationId": "updateVariantOption",
        "summary": "POST Update Variant Option",
        "description": "Sync variant options for a product (used when managing product attribute variations).",
        "tags": [
          "Products"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "postId",
            "in": "path",
            "schema": {
              "type": "integer"
            },
            "description": "The product post ID",
            "required": true
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "variation_type",
                  "product_id",
                  "options"
                ],
                "properties": {
                  "variation_type": {
                    "type": "string",
                    "description": "The variation type"
                  },
                  "product_id": {
                    "type": "integer",
                    "description": "The product ID"
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "description": "Array of option objects with id and variants"
                  }
                }
              },
              "example": {
                "variation_type": "simple_variations",
                "product_id": 123,
                "options": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "example": {
                  "message": "Variant options synced successfully"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}