{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/public/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "GET List Products",
        "description": "Retrieve a paginated list of published products with optional filtering by taxonomy terms, price range, product type, and more. Only products with publish status are returned.",
        "tags": [
          "Public Shop"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Number of products per page"
          },
          {
            "name": "current_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Page number for offset-based pagination"
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Cursor token for cursor-based pagination"
          },
          {
            "name": "paginate_using",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "cursor"
              ]
            },
            "description": "Pagination strategy: cursor for cursor-based, omit for offset-based"
          },
          {
            "name": "order_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "ASC",
                "DESC"
              ],
              "default": "DESC"
            },
            "description": "Sort direction"
          },
          {
            "name": "with[]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Relations to eager load (e.g., detail)"
          },
          {
            "name": "allow_out_of_stock",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Include out-of-stock products"
          },
          {
            "name": "include_ids[]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Only return products with these IDs (max 100 IDs)"
          },
          {
            "name": "exclude_ids[]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Exclude products with these IDs (max 100 IDs)"
          },
          {
            "name": "product_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "physical",
                "digital",
                "subscription",
                "onetime",
                "simple",
                "simple_variations"
              ]
            },
            "description": "Filter by product type"
          },
          {
            "name": "on_sale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Only return products currently on sale"
          },
          {
            "name": "filters[wildcard]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Search by product title"
          },
          {
            "name": "filters[sort_by]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "name-asc",
                "name-desc",
                "price-low",
                "price-high",
                "date-newest",
                "date-oldest"
              ]
            },
            "description": "Sort preset"
          },
          {
            "name": "filters[price_range_from]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Minimum price filter in decimal (e.g., 10.00)"
          },
          {
            "name": "filters[price_range_to]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number"
            },
            "description": "Maximum price filter in decimal (e.g., 99.99)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "object",
                      "properties": {
                        "products": {
                          "type": "object",
                          "properties": {
                            "total": {
                              "type": "integer"
                            },
                            "per_page": {
                              "type": "integer"
                            },
                            "current_page": {
                              "type": "integer"
                            },
                            "last_page": {
                              "type": "integer"
                            },
                            "data": {
                              "type": "array",
                              "items": {
                                "$ref": "#/components/schemas/PublicProduct"
                              }
                            }
                          }
                        },
                        "total": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "example": {
                    "products": {
                      "products": {
                        "total": 24,
                        "per_page": 10,
                        "current_page": 1,
                        "last_page": 3,
                        "data": [
                          {
                            "ID": 42,
                            "post_title": "Premium T-Shirt",
                            "post_status": "publish",
                            "post_excerpt": "High-quality cotton t-shirt",
                            "guid": "https://example.com/?p=42",
                            "view_url": "https://example.com/product/premium-t-shirt",
                            "has_subscription": false,
                            "thumbnail": "https://example.com/wp-content/uploads/tshirt.jpg",
                            "detail": {
                              "id": 15,
                              "post_id": 42,
                              "variation_type": "simple",
                              "min_price": 2500,
                              "max_price": 2500,
                              "fulfillment_type": "physical"
                            }
                          }
                        ]
                      },
                      "total": 24
                    }
                  }
                },
                "example": {
                  "products": {
                    "products": {
                      "total": 24,
                      "per_page": 10,
                      "current_page": 1,
                      "last_page": 3,
                      "data": [
                        {
                          "ID": 42,
                          "post_title": "Premium T-Shirt",
                          "post_status": "publish",
                          "post_excerpt": "High-quality cotton t-shirt",
                          "guid": "https://example.com/?p=42",
                          "view_url": "https://example.com/product/premium-t-shirt",
                          "has_subscription": false,
                          "thumbnail": "https://example.com/wp-content/uploads/tshirt.jpg",
                          "detail": {
                            "id": 15,
                            "post_id": 42,
                            "variation_type": "simple",
                            "min_price": 2500,
                            "max_price": 2500,
                            "fulfillment_type": "physical"
                          }
                        }
                      ]
                    },
                    "total": 24
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "products": {
                        "products": {
                          "total": 24,
                          "per_page": 10,
                          "current_page": 1,
                          "last_page": 3,
                          "data": [
                            {
                              "ID": 42,
                              "post_title": "Premium T-Shirt",
                              "post_status": "publish",
                              "post_excerpt": "High-quality cotton t-shirt",
                              "guid": "https://example.com/?p=42",
                              "view_url": "https://example.com/product/premium-t-shirt",
                              "has_subscription": false,
                              "thumbnail": "https://example.com/wp-content/uploads/tshirt.jpg",
                              "detail": {
                                "id": 15,
                                "post_id": 42,
                                "variation_type": "simple",
                                "min_price": 2500,
                                "max_price": 2500,
                                "fulfillment_type": "physical"
                              }
                            }
                          ]
                        },
                        "total": 24
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PublicProduct": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer",
            "description": "Product post ID",
            "example": 42
          },
          "post_title": {
            "type": "string",
            "description": "Product title",
            "example": "Premium T-Shirt"
          },
          "post_status": {
            "type": "string",
            "description": "Post status",
            "example": "publish"
          },
          "post_excerpt": {
            "type": "string",
            "description": "Product short description",
            "example": "High-quality cotton t-shirt"
          },
          "guid": {
            "type": "string",
            "format": "uri",
            "description": "Product GUID",
            "example": "https://example.com/?p=42"
          },
          "view_url": {
            "type": "string",
            "format": "uri",
            "description": "Public product URL",
            "example": "https://example.com/product/premium-t-shirt"
          },
          "has_subscription": {
            "type": "boolean",
            "description": "Whether the product has subscription options",
            "example": false
          },
          "thumbnail": {
            "type": "string",
            "format": "uri",
            "description": "Product thumbnail URL",
            "example": "https://example.com/wp-content/uploads/tshirt.jpg"
          },
          "detail": {
            "$ref": "#/components/schemas/PublicProductDetail"
          }
        }
      },
      "PublicProductDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Product detail ID",
            "example": 15
          },
          "post_id": {
            "type": "integer",
            "description": "Associated post ID",
            "example": 42
          },
          "variation_type": {
            "type": "string",
            "description": "Variation type",
            "example": "simple"
          },
          "min_price": {
            "type": "integer",
            "description": "Minimum price in cents",
            "example": 2500
          },
          "max_price": {
            "type": "integer",
            "description": "Maximum price in cents",
            "example": 2500
          },
          "fulfillment_type": {
            "type": "string",
            "description": "Fulfillment type",
            "example": "physical"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
