{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/cart-report": {
      "get": {
        "operationId": "getCartReport",
        "summary": "GET Get Cart Report",
        "description": "Retrieve abandoned cart data showing which products are most frequently abandoned, along with their unit prices and abandonment counts. A cart is considered abandoned if it has been inactive for more than 60 seconds.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date to scope the cart data.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-06-30"
            },
            "description": "End date to scope the cart data.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Grouping key (reserved for future use).",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "abandonedItems": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "product_name": {
                            "type": "string",
                            "description": "Product name"
                          },
                          "abandoned_times": {
                            "type": "integer",
                            "description": "Number of times abandoned"
                          },
                          "unit_price": {
                            "type": "integer",
                            "description": "Unit price in cents"
                          }
                        }
                      },
                      "description": "List of abandoned cart items with frequency and pricing"
                    }
                  }
                },
                "example": {
                  "abandonedItems": [
                    {
                      "product_name": "Premium Plan",
                      "abandoned_times": 15,
                      "unit_price": 4999
                    },
                    {
                      "product_name": "Basic Plan",
                      "abandoned_times": 8,
                      "unit_price": 1999
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}