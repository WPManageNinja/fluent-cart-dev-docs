{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/fetch-report-meta": {
      "get": {
        "operationId": "getReportMeta",
        "summary": "GET Get Report Meta",
        "description": "Retrieve metadata for the reporting interface, including available currencies, the earliest order date, and store mode.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date to scope the currency lookup.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date to scope the currency lookup.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "currencies": {
                      "type": "object",
                      "description": "Available currencies with codes and signs",
                      "additionalProperties": true
                    },
                    "min_date": {
                      "type": "string",
                      "description": "Earliest order date"
                    },
                    "storeMode": {
                      "type": "string",
                      "description": "Current store mode (live or test)"
                    },
                    "first_order_date": {
                      "type": "string",
                      "description": "Date of the first order"
                    }
                  },
                  "example": {
                    "currencies": {
                      "USD": {
                        "code": "USD",
                        "sign": "$"
                      },
                      "EUR": {
                        "code": "EUR",
                        "sign": "\u20ac"
                      },
                      "GBP": {
                        "code": "GBP",
                        "sign": "\u00a3"
                      }
                    },
                    "min_date": "2024-01-15 08:30:00",
                    "storeMode": "live",
                    "first_order_date": "2024-01-15 08:30:00"
                  }
                },
                "example": {
                  "currencies": {
                    "USD": {
                      "code": "USD",
                      "sign": "$"
                    },
                    "EUR": {
                      "code": "EUR",
                      "sign": "\u20ac"
                    },
                    "GBP": {
                      "code": "GBP",
                      "sign": "\u00a3"
                    }
                  },
                  "min_date": "2024-01-15 08:30:00",
                  "storeMode": "live",
                  "first_order_date": "2024-01-15 08:30:00"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "currencies": {
                        "USD": {
                          "code": "USD",
                          "sign": "$"
                        },
                        "EUR": {
                          "code": "EUR",
                          "sign": "\u20ac"
                        },
                        "GBP": {
                          "code": "GBP",
                          "sign": "\u00a3"
                        }
                      },
                      "min_date": "2024-01-15 08:30:00",
                      "storeMode": "live",
                      "first_order_date": "2024-01-15 08:30:00"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
