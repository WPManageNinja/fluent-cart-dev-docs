{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/future-renewals": {
      "get": {
        "operationId": "getFutureRenewals",
        "summary": "GET Get Future Renewals",
        "description": "Retrieve projected future subscription renewal data.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Future renewal projection data",
                  "additionalProperties": true,
                  "example": {
                    "futureRenewals": [
                      {
                        "date": "2025-10-01",
                        "count": 15,
                        "expected_revenue": 148500
                      },
                      {
                        "date": "2025-11-01",
                        "count": 22,
                        "expected_revenue": 217800
                      },
                      {
                        "date": "2025-12-01",
                        "count": 18,
                        "expected_revenue": 178200
                      },
                      {
                        "date": "2026-01-01",
                        "count": 28,
                        "expected_revenue": 277200
                      },
                      {
                        "date": "2026-02-01",
                        "count": 12,
                        "expected_revenue": 118800
                      },
                      {
                        "date": "2026-03-01",
                        "count": 20,
                        "expected_revenue": 198000
                      }
                    ],
                    "total_expected_revenue": 1138500,
                    "total_renewals": 115
                  }
                },
                "example": {
                  "futureRenewals": [
                    {
                      "date": "2025-10-01",
                      "count": 15,
                      "expected_revenue": 148500
                    },
                    {
                      "date": "2025-11-01",
                      "count": 22,
                      "expected_revenue": 217800
                    },
                    {
                      "date": "2025-12-01",
                      "count": 18,
                      "expected_revenue": 178200
                    },
                    {
                      "date": "2026-01-01",
                      "count": 28,
                      "expected_revenue": 277200
                    },
                    {
                      "date": "2026-02-01",
                      "count": 12,
                      "expected_revenue": 118800
                    },
                    {
                      "date": "2026-03-01",
                      "count": 20,
                      "expected_revenue": 198000
                    }
                  ],
                  "total_expected_revenue": 1138500,
                  "total_renewals": 115
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "futureRenewals": [
                        {
                          "date": "2025-10-01",
                          "count": 15,
                          "expected_revenue": 148500
                        },
                        {
                          "date": "2025-11-01",
                          "count": 22,
                          "expected_revenue": 217800
                        },
                        {
                          "date": "2025-12-01",
                          "count": 18,
                          "expected_revenue": 178200
                        },
                        {
                          "date": "2026-01-01",
                          "count": 28,
                          "expected_revenue": 277200
                        },
                        {
                          "date": "2026-02-01",
                          "count": 12,
                          "expected_revenue": 118800
                        },
                        {
                          "date": "2026-03-01",
                          "count": 20,
                          "expected_revenue": 198000
                        }
                      ],
                      "total_expected_revenue": 1138500,
                      "total_renewals": 115
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
