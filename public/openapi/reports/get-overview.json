  "components": {
    "schemas": {
      "RevenuePeriod": {
        "type": "object",
        "properties": {
          "current": {
            "type": "integer",
            "description": "Current period revenue in cents",
            "example": 500000
          },
          "prev": {
            "type": "integer",
            "description": "Previous period revenue in cents",
            "example": 350000
          },
          "yoy_growth": {
            "type": "string",
            "description": "Year-over-year growth percentage",
            "example": "42.86"
          }
        }
      }
    },
