{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/revenue": {
      "get": {
        "operationId": "getRevenue",
        "summary": "GET Get Revenue Data",
        "description": "Retrieve detailed revenue data grouped by the specified interval, with optional comparison against a prior period. Includes summary totals, period-over-period fluctuations, and the applied group key.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[orderTypes]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Order type filter (e.g., one-time, subscription).",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "revenueReport": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Revenue data grouped by interval"
                    },
                    "summary": {
                      "type": "object",
                      "description": "Summary totals for the period"
                    },
                    "previousSummary": {
                      "type": "object",
                      "description": "Summary totals for the comparison period"
                    },
                    "fluctuations": {
                      "type": "object",
                      "description": "Period-over-period fluctuation data"
                    },
                    "previousMetrics": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Comparison period metrics"
                    },
                    "appliedGroupKey": {
                      "type": "string",
                      "description": "The grouping key that was applied"
                    }
                  }
                },
                "example": {
                  "revenueReport": [
                    {
                      "year": "2025",
                      "group": "2025-01",
                      "gross_revenue": 420000,
                      "net_revenue": 378000,
                      "orders": 45
                    },
                    {
                      "year": "2025",
                      "group": "2025-02",
                      "gross_revenue": 480000,
                      "net_revenue": 432000,
                      "orders": 52
                    },
                    {
                      "year": "2025",
                      "group": "2025-03",
                      "gross_revenue": 510000,
                      "net_revenue": 459000,
                      "orders": 48
                    },
                    {
                      "year": "2025",
                      "group": "2025-04",
                      "gross_revenue": 390000,
                      "net_revenue": 351000,
                      "orders": 40
                    },
                    {
                      "year": "2025",
                      "group": "2025-05",
                      "gross_revenue": 550000,
                      "net_revenue": 495000,
                      "orders": 58
                    },
                    {
                      "year": "2025",
                      "group": "2025-06",
                      "gross_revenue": 620000,
                      "net_revenue": 558000,
                      "orders": 65
                    }
                  ],
                  "summary": {
                    "gross_revenue": 2970000,
                    "net_revenue": 2673000,
                    "total_orders": 308,
                    "total_items_sold": 756,
                    "total_tax": 185000,
                    "total_shipping": 52000,
                    "total_discounts": 60000
                  },
                  "previousSummary": {
                    "gross_revenue": 2400000,
                    "net_revenue": 2160000,
                    "total_orders": 260,
                    "total_items_sold": 640
                  },
                  "fluctuations": {
                    "gross_revenue": {
                      "value": 23.75,
                      "direction": "up"
                    },
                    "net_revenue": {
                      "value": 23.75,
                      "direction": "up"
                    },
                    "total_orders": {
                      "value": 18.46,
                      "direction": "up"
                    }
                  },
                  "previousMetrics": [
                    {
                      "year": "2024",
                      "group": "2024-07",
                      "gross_revenue": 350000,
                      "net_revenue": 315000,
                      "orders": 38
                    },
                    {
                      "year": "2024",
                      "group": "2024-08",
                      "gross_revenue": 380000,
                      "net_revenue": 342000,
                      "orders": 42
                    },
                    {
                      "year": "2024",
                      "group": "2024-09",
                      "gross_revenue": 410000,
                      "net_revenue": 369000,
                      "orders": 45
                    }
                  ],
                  "appliedGroupKey": "monthly"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
