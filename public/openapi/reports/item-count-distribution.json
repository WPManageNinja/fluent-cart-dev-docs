{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/item-count-distribution": {
      "get": {
        "operationId": "getItemCountDistribution",
        "summary": "GET Get Item Count Distribution",
        "description": "Retrieve the distribution of orders by the number of items per order (e.g., how many orders have 1 item, 2 items, etc.).",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[orderTypes]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Order type filter (e.g., one-time, subscription).",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Item count distribution data"
                    }
                  },
                  "example": {
                    "data": [
                      {
                        "item_count": 1,
                        "order_count": 185,
                        "percentage": 54.1
                      },
                      {
                        "item_count": 2,
                        "order_count": 98,
                        "percentage": 28.7
                      },
                      {
                        "item_count": 3,
                        "order_count": 38,
                        "percentage": 11.1
                      },
                      {
                        "item_count": 4,
                        "order_count": 15,
                        "percentage": 4.4
                      },
                      {
                        "item_count": "5+",
                        "order_count": 6,
                        "percentage": 1.7
                      }
                    ]
                  }
                },
                "example": {
                  "data": [
                    {
                      "item_count": 1,
                      "order_count": 185,
                      "percentage": 54.1
                    },
                    {
                      "item_count": 2,
                      "order_count": 98,
                      "percentage": 28.7
                    },
                    {
                      "item_count": 3,
                      "order_count": 38,
                      "percentage": 11.1
                    },
                    {
                      "item_count": 4,
                      "order_count": 15,
                      "percentage": 4.4
                    },
                    {
                      "item_count": "5+",
                      "order_count": 6,
                      "percentage": 1.7
                    }
                  ]
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "data": [
                        {
                          "item_count": 1,
                          "order_count": 185,
                          "percentage": 54.1
                        },
                        {
                          "item_count": 2,
                          "order_count": 98,
                          "percentage": 28.7
                        },
                        {
                          "item_count": 3,
                          "order_count": 38,
                          "percentage": 11.1
                        },
                        {
                          "item_count": 4,
                          "order_count": 15,
                          "percentage": 4.4
                        },
                        {
                          "item_count": "5+",
                          "order_count": 6,
                          "percentage": 1.7
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
