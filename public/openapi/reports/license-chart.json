{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/license-chart": {
      "get": {
        "operationId": "getLicenseChart",
        "summary": "GET Get License Line Chart",
        "description": "Retrieve license creation/activation data as time-series chart data, grouped by the specified interval.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[orderStatus]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Order status filter.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code filter.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[orderTypes]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Order type filter.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "daily",
                "monthly",
                "yearly"
              ],
              "default": "daily"
            },
            "description": "Time grouping interval.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Time-series chart data for license metrics",
                  "additionalProperties": true,
                  "example": {
                    "labels": [
                      "2025-01",
                      "2025-02",
                      "2025-03",
                      "2025-04",
                      "2025-05",
                      "2025-06",
                      "2025-07",
                      "2025-08",
                      "2025-09"
                    ],
                    "datasets": [
                      {
                        "label": "Licenses Issued",
                        "data": [
                          18,
                          22,
                          28,
                          24,
                          32,
                          30,
                          35,
                          29,
                          38
                        ]
                      },
                      {
                        "label": "Activations",
                        "data": [
                          25,
                          30,
                          38,
                          35,
                          45,
                          42,
                          50,
                          40,
                          52
                        ]
                      }
                    ],
                    "summary": {
                      "total_licenses_issued": 256,
                      "total_activations": 357
                    }
                  }
                },
                "example": {
                  "labels": [
                    "2025-01",
                    "2025-02",
                    "2025-03",
                    "2025-04",
                    "2025-05",
                    "2025-06",
                    "2025-07",
                    "2025-08",
                    "2025-09"
                  ],
                  "datasets": [
                    {
                      "label": "Licenses Issued",
                      "data": [
                        18,
                        22,
                        28,
                        24,
                        32,
                        30,
                        35,
                        29,
                        38
                      ]
                    },
                    {
                      "label": "Activations",
                      "data": [
                        25,
                        30,
                        38,
                        35,
                        45,
                        42,
                        50,
                        40,
                        52
                      ]
                    }
                  ],
                  "summary": {
                    "total_licenses_issued": 256,
                    "total_activations": 357
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "labels": [
                        "2025-01",
                        "2025-02",
                        "2025-03",
                        "2025-04",
                        "2025-05",
                        "2025-06",
                        "2025-07",
                        "2025-08",
                        "2025-09"
                      ],
                      "datasets": [
                        {
                          "label": "Licenses Issued",
                          "data": [
                            18,
                            22,
                            28,
                            24,
                            32,
                            30,
                            35,
                            29,
                            38
                          ]
                        },
                        {
                          "label": "Activations",
                          "data": [
                            25,
                            30,
                            38,
                            35,
                            45,
                            42,
                            50,
                            40,
                            52
                          ]
                        }
                      ],
                      "summary": {
                        "total_licenses_issued": 256,
                        "total_activations": 357
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
