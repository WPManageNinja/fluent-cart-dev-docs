{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/order-completion-time": {
      "get": {
        "operationId": "getOrderCompletionTime",
        "summary": "GET Get Order Completion Time",
        "description": "Retrieve statistics on how long orders take to be completed (time between creation and completion).",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[orderTypes]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Order type filter (e.g., one-time, subscription).",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "description": "Order completion time statistics"
                    }
                  },
                  "example": {
                    "data": {
                      "average_hours": 2.4,
                      "median_hours": 1.2,
                      "min_hours": 0.01,
                      "max_hours": 72.5,
                      "distribution": [
                        {
                          "range": "< 1 hour",
                          "count": 145,
                          "percentage": 42.4
                        },
                        {
                          "range": "1-6 hours",
                          "count": 120,
                          "percentage": 35.1
                        },
                        {
                          "range": "6-24 hours",
                          "count": 52,
                          "percentage": 15.2
                        },
                        {
                          "range": "1-3 days",
                          "count": 20,
                          "percentage": 5.8
                        },
                        {
                          "range": "3+ days",
                          "count": 5,
                          "percentage": 1.5
                        }
                      ],
                      "total_completed": 342
                    }
                  }
                },
                "example": {
                  "data": {
                    "average_hours": 2.4,
                    "median_hours": 1.2,
                    "min_hours": 0.01,
                    "max_hours": 72.5,
                    "distribution": [
                      {
                        "range": "< 1 hour",
                        "count": 145,
                        "percentage": 42.4
                      },
                      {
                        "range": "1-6 hours",
                        "count": 120,
                        "percentage": 35.1
                      },
                      {
                        "range": "6-24 hours",
                        "count": 52,
                        "percentage": 15.2
                      },
                      {
                        "range": "1-3 days",
                        "count": 20,
                        "percentage": 5.8
                      },
                      {
                        "range": "3+ days",
                        "count": 5,
                        "percentage": 1.5
                      }
                    ],
                    "total_completed": 342
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
