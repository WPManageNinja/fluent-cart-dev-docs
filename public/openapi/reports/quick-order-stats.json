{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/quick-order-stats": {
      "get": {
        "operationId": "getQuickOrderStats",
        "summary": "GET Get Quick Order Stats",
        "description": "Retrieve quick summary statistics for orders within a specified range, with automatic comparison against the equivalent prior period.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "day_range",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "-0 days",
                "-7 days",
                "-30 days",
                "this_month",
                "all_time"
              ],
              "default": "-0 days"
            },
            "description": "Date range shortcut. Accepts relative date strings, this_month, or all_time.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stats": {
                      "type": "object",
                      "description": "Order statistics"
                    },
                    "from_date": {
                      "type": "string",
                      "description": "Start of the queried date range"
                    },
                    "to_date": {
                      "type": "string",
                      "description": "End of the queried date range"
                    }
                  },
                  "example": {
                    "stats": {
                      "total_orders": 18,
                      "total_revenue": 125000,
                      "average_order_value": 6944,
                      "total_items_sold": 42,
                      "compare_total_orders": 15,
                      "compare_total_revenue": 108000,
                      "compare_average_order_value": 7200
                    },
                    "from_date": "2025-09-01 00:00:00",
                    "to_date": "2025-09-20 23:59:59"
                  }
                },
                "example": {
                  "stats": {
                    "total_orders": 18,
                    "total_revenue": 125000,
                    "average_order_value": 6944,
                    "total_items_sold": 42,
                    "compare_total_orders": 15,
                    "compare_total_revenue": 108000,
                    "compare_average_order_value": 7200
                  },
                  "from_date": "2025-09-01 00:00:00",
                  "to_date": "2025-09-20 23:59:59"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "stats": {
                        "total_orders": 18,
                        "total_revenue": 125000,
                        "average_order_value": 6944,
                        "total_items_sold": 42,
                        "compare_total_orders": 15,
                        "compare_total_revenue": 108000,
                        "compare_average_order_value": 7200
                      },
                      "from_date": "2025-09-01 00:00:00",
                      "to_date": "2025-09-20 23:59:59"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
