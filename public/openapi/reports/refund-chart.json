{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/refund-chart": {
      "get": {
        "operationId": "getRefundChart",
        "summary": "GET Get Refund Chart",
        "description": "Retrieve refund data as time-series chart data with summary totals. Supports comparison against a prior period with fluctuation calculations.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[orderTypes]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Order type filter (e.g., one-time, subscription).",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "object",
                      "description": "Refund summary totals"
                    },
                    "previousSummary": {
                      "type": "object",
                      "description": "Comparison period summary"
                    },
                    "chartData": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Time-series refund chart data"
                    },
                    "fluctuations": {
                      "type": "object",
                      "description": "Fluctuation data"
                    },
                    "previousMetrics": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Comparison period metrics"
                    }
                  },
                  "example": {
                    "summary": {
                      "total_refunds": 8,
                      "total_refund_amount": 70000,
                      "average_refund": 8750,
                      "refund_rate": 2.3
                    },
                    "previousSummary": {
                      "total_refunds": 6,
                      "total_refund_amount": 52000,
                      "average_refund": 8667,
                      "refund_rate": 2.1
                    },
                    "chartData": [
                      {
                        "year": "2025",
                        "group": "2025-01",
                        "refund_count": 1,
                        "refund_amount": 9900
                      },
                      {
                        "year": "2025",
                        "group": "2025-02",
                        "refund_count": 2,
                        "refund_amount": 14800
                      },
                      {
                        "year": "2025",
                        "group": "2025-03",
                        "refund_count": 0,
                        "refund_amount": 0
                      },
                      {
                        "year": "2025",
                        "group": "2025-04",
                        "refund_count": 1,
                        "refund_amount": 4900
                      },
                      {
                        "year": "2025",
