{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/revenue-by-group": {
      "get": {
        "operationId": "getRevenueByGroup",
        "summary": "GET Get Revenue by Group",
        "description": "Retrieve revenue data broken down by a specific grouping dimension (e.g., payment method, billing country).",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[orderTypes]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Order type filter (e.g., one-time, subscription).",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "description": "Revenue data grouped by the specified dimension"
                    }
                  },
                  "example": {
                    "data": {
                      "by_payment_method": [
                        {
                          "label": "Stripe",
                          "value": 850000,
                          "count": 230,
                          "percentage": 68
                        },
                        {
                          "label": "PayPal",
                          "value": 320000,
                          "count": 95,
                          "percentage": 25.6
                        },
                        {
                          "label": "Cash on Delivery",
                          "value": 80000,
                          "count": 17,
                          "percentage": 6.4
                        }
                      ],
                      "by_billing_country": [
                        {
                          "label": "US",
                          "value": 680000,
                          "count": 120,
                          "percentage": 54.4
                        },
                        {
                          "label": "GB",
                          "value": 195000,
                          "count": 35,
                          "percentage": 15.6
                        },
                        {
                          "label": "DE",
                          "value": 118000,
                          "count": 22,
                          "percentage": 9.4
                        },
                        {
                          "label": "CA",
                          "value": 95000,
                          "count": 18,
                          "percentage": 7.6
                        },
                        {
                          "label": "AU",
                          "value": 62000,
                          "count": 12,
                          "percentage": 5
                        }
                      ]
                    }
                  }
                },
                "example": {
                  "data": {
                    "by_payment_method": [
                      {
                        "label": "Stripe",
                        "value": 850000,
                        "count": 230,
                        "percentage": 68
                      },
                      {
                        "label": "PayPal",
