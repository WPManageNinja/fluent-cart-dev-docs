                      },
                      {
                        "year": "2025",
                        "group": "2025-05",
                        "orders": 58,
                        "net_revenue": 4950
                      },
                      {
                        "year": "2025",
                        "group": "2025-06",
                        "orders": 65,
                        "net_revenue": 5580
                      },
                      {
                        "year": "2025",
                        "group": "2025-07",
                        "orders": 55,
