{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/sales-growth": {
      "get": {
        "operationId": "getSalesGrowth",
        "summary": "GET Get Sales Growth",
        "description": "Retrieve sales growth data over a specified period. Filters to orders with successful payment and order statuses.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date. Defaults to the earliest order date.",
            "required": false
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date. Defaults to the latest order date.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sales_data": {
                      "type": "object",
                      "description": "Sales growth data"
                    }
                  }
                },
                "example": {
                  "sales_data": {
                    "current_period": {
                      "total_revenue": 1250000,
                      "total_orders": 342,
                      "average_order_value": 3655
                    },
                    "previous_period": {
                      "total_revenue": 1050000,
                      "total_orders": 289,
                      "average_order_value": 3633
                    },
                    "growth": {
                      "revenue_growth": 19.05,
                      "orders_growth": 18.34,
                      "aov_growth": 0.61
                    },
                    "monthly": [
                      {
                        "month": "2025-01",
                        "revenue": 420000,
                        "orders": 45
                      },
                      {
                        "month": "2025-02",
                        "revenue": 480000,
                        "orders": 52
                      },
                      {
                        "month": "2025-03",
                        "revenue": 510000,
                        "orders": 48
                      },
                      {
                        "month": "2025-04",
                        "revenue": 390000,
                        "orders": 40
                      },
                      {
                        "month": "2025-05",
                        "revenue": 550000,
                        "orders": 58
                      },
                      {
                        "month": "2025-06",
                        "revenue": 620000,
                        "orders": 65
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
