                        "order_count": 6,
                        "total_spent": 72000,
                        "first_order": "2024-07-10",
                        "last_order": "2025-09-15"
                      },
                      {
                        "customer_id": 28,
                        "customer_name": "David Kim",
                        "email": "david@example.com",
                        "order_count": 5,
                        "total_spent": 58900,
                        "first_order": "2024-02-28",
                        "last_order": "2025-08-30"
                      },
                      {
                        "customer_id": 156,
                        "customer_name": "Lisa Anderson",
                        "email": "lisa@example.com",
