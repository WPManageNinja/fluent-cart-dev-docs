{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/search-repeat-customer": {
      "get": {
        "operationId": "searchRepeatCustomer",
        "summary": "GET Search Repeat Customers",
        "description": "Search and paginate through customers who have made multiple purchases.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[per_page]",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 15
            },
            "description": "Number of results per page.",
            "required": false
          },
          {
            "name": "params[current_page]",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 1
            },
            "description": "Current page number.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "repeat_customers": {
                      "type": "object",
                      "description": "Paginated repeat customer data",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "repeat_customers": {
                    "total": 50,
                    "per_page": 15,
                    "current_page": 1,
                    "data": []
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}