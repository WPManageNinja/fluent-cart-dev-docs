{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/search-repeat-customer": {
      "get": {
        "operationId": "searchRepeatCustomer",
        "summary": "GET Search Repeat Customers",
        "description": "Search and paginate through customers who have made multiple purchases.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[per_page]",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 15
            },
            "description": "Number of results per page.",
            "required": false
          },
          {
            "name": "params[current_page]",
            "in": "query",
            "schema": {
              "type": "integer",
              "example": 1
            },
            "description": "Current page number.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "repeat_customers": {
                      "type": "object",
                      "description": "Paginated repeat customer data",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "repeat_customers": {
                      "total": 183,
                      "per_page": 15,
                      "current_page": 1,
                      "data": [
                        {
                          "customer_id": 42,
                          "customer_name": "Sarah Johnson",
                          "email": "sarah@example.com",
                          "order_count": 12,
                          "total_spent": 128500,
                          "first_order": "2024-03-15",
                          "last_order": "2025-09-20"
                        },
                        {
                          "customer_id": 73,
                          "customer_name": "Mike Chen",
                          "email": "mike@example.com",
                          "order_count": 8,
                          "total_spent": 89200,
                          "first_order": "2024-05-22",
                          "last_order": "2025-09-18"
                        },
                        {
                          "customer_id": 91,
                          "customer_name": "Emily Wilson",
                          "email": "emily@example.com",
                          "order_count": 6,
                          "total_spent": 72000,
                          "first_order": "2024-07-10",
                          "last_order": "2025-09-15"
                        },
                        {
                          "customer_id": 28,
                          "customer_name": "David Kim",
                          "email": "david@example.com",
                          "order_count": 5,
                          "total_spent": 58900,
                          "first_order": "2024-02-28",
                          "last_order": "2025-08-30"
                        },
                        {
                          "customer_id": 156,
                          "customer_name": "Lisa Anderson",
                          "email": "lisa@example.com",
                          "order_count": 5,
                          "total_spent": 45000,
                          "first_order": "2024-09-05",
                          "last_order": "2025-09-12"
                        }
                      ]
                    }
                  }
                },
                "example": {
                  "repeat_customers": {
                    "total": 183,
                    "per_page": 15,
                    "current_page": 1,
                    "data": [
                      {
                        "customer_id": 42,
                        "customer_name": "Sarah Johnson",
                        "email": "sarah@example.com",
                        "order_count": 12,
                        "total_spent": 128500,
                        "first_order": "2024-03-15",
                        "last_order": "2025-09-20"
                      },
                      {
                        "customer_id": 73,
