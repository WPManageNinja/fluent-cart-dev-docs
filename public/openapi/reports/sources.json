{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/sources": {
      "get": {
        "operationId": "getSourceReport",
        "summary": "GET Get Source Report",
        "description": "Retrieve order source/attribution data showing where orders originated from. Supports comparison against a prior period with fluctuation calculations.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[orderTypes]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Order type filter (e.g., one-time, subscription).",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sourceReportData": {
                      "type": "object",
                      "description": "Source attribution data"
                    },
                    "fluctuations": {
                      "type": "object",
                      "description": "Fluctuation data"
                    }
                  },
                  "example": {
                    "sourceReportData": {
                      "sources": [
                        {
                          "source": "direct",
                          "orders": 150,
                          "revenue": 720000,
                          "percentage": 43.9
                        },
                        {
                          "source": "google",
                          "orders": 95,
                          "revenue": 450000,
                          "percentage": 27.8
                        },
                        {
                          "source": "referral",
                          "orders": 55,
                          "revenue": 280000,
                          "percentage": 16.1
                        },
                        {
                          "source": "social",
                          "orders": 42,
                          "revenue": 180000,
                          "percentage": 12.3
                        }
                      ],
                      "total_orders": 342,
                      "total_revenue": 1630000
                    },
                    "fluctuations": {
                      "direct": {
                        "value": 12.5,
                        "direction": "up"
                      },
                      "google": {
                        "value": 8.2,
                        "direction": "up"
                      },
                      "referral": {
                        "value": 22.4,
                        "direction": "up"
                      },
                      "social": {
                        "value": -5.1,
                        "direction": "down"
                      }
                    }
                  }
                },
                "example": {
                  "sourceReportData": {
                    "sources": [
                      {
                        "source": "direct",
                        "orders": 150,
                        "revenue": 720000,
                        "percentage": 43.9
                      },
                      {
                        "source": "google",
                        "orders": 95,
                        "revenue": 450000,
                        "percentage": 27.8
                      },
                      {
                        "source": "referral",
                        "orders": 55,
                        "revenue": 280000,
                        "percentage": 16.1
                      },
                      {
                        "source": "social",
                        "orders": 42,
                        "revenue": 180000,
                        "percentage": 12.3
                      }
                    ],
                    "total_orders": 342,
                    "total_revenue": 1630000
                  },
                  "fluctuations": {
                    "direct": {
                      "value": 12.5,
                      "direction": "up"
                    },
                    "google": {
                      "value": 8.2,
                      "direction": "up"
                    },
                    "referral": {
                      "value": 22.4,
                      "direction": "up"
                    },
                    "social": {
                      "value": -5.1,
                      "direction": "down"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
