{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/subscription-chart": {
      "get": {
        "operationId": "getSubscriptionChart",
        "summary": "GET Get Subscription Chart",
        "description": "Retrieve subscription data as time-series chart data, including total subscription counts and future installment projections. Supports comparison against a prior period.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          },
          {
            "name": "params[paymentStatus]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Payment status filter.",
            "required": false
          },
          {
            "name": "params[subscriptionType]",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "subscription"
            },
            "description": "Subscription type filter. Defaults to subscription.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "currentMetrics": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Current period subscription metrics"
                    },
                    "compareMetrics": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Comparison period metrics"
                    },
                    "summary": {
                      "type": "object",
                      "description": "Summary with future installments and total subscriptions"
                    },
                    "fluctuations": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "Fluctuation data"
                    }
                  }
                },
                "example": {
                  "currentMetrics": [
                    {
                      "year": "2025",
                      "group": "2025-01",
                      "subscriptions": 12,
                      "mrr": 118800
                    },
                    {
                      "year": "2025",
                      "group": "2025-02",
                      "subscriptions": 15,
                      "mrr": 148500
                    },
                    {
                      "year": "2025",
                      "group": "2025-03",
                      "subscriptions": 18,
                      "mrr": 178200
                    },
                    {
                      "year": "2025",
                      "group": "2025-04",
                      "subscriptions": 14,
                      "mrr": 138600
                    },
                    {
                      "year": "2025",
                      "group": "2025-05",
                      "subscriptions": 22,
                      "mrr": 217800
                    },
                    {
                      "year": "2025",
                      "group": "2025-06",
                      "subscriptions": 19,
                      "mrr": 188100
                    },
                    {
                      "year": "2025",
                      "group": "2025-07",
                      "subscriptions": 25,
                      "mrr": 247500
                    },
                    {
                      "year": "2025",
                      "group": "2025-08",
                      "subscriptions": 20,
                      "mrr": 198000
                    },
                    {
                      "year": "2025",
                      "group": "2025-09",
                      "subscriptions": 28,
                      "mrr": 277200
                    }
                  ],
                  "compareMetrics": [
                    {
                      "year": "2024",
                      "group": "2024-01",
                      "subscriptions": 8,
                      "mrr": 79200
                    },
                    {
                      "year": "2024",
                      "group": "2024-02",
                      "subscriptions": 10,
                      "mrr": 99000
                    },
                    {
                      "year": "2024",
                      "group": "2024-03",
                      "subscriptions": 12,
                      "mrr": 118800
                    }
                  ],
                  "summary": {
                    "future_installments": 1138500,
                    "total_subscriptions": 183,
                    "active_subscriptions": 89,
                    "canceled_subscriptions": 25,
                    "mrr": 277200
                  },
                  "fluctuations": [
                    {
                      "key": "total_subscriptions",
                      "value": 28.5,
                      "direction": "up"
                    },
                    {
                      "key": "mrr",
                      "value": 35.2,
                      "direction": "up"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
