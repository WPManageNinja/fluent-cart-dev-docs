{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/reports/subscription-retention": {
      "get": {
        "operationId": "getSubscriptionRetention",
        "summary": "GET Get Subscription Retention",
        "description": "Retrieve subscription retention data showing the percentage of subscribers who remain active over successive billing periods.",
        "tags": [
          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "params[startDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-01-01"
            },
            "description": "Start date for the report period.",
            "required": false
          },
          {
            "name": "params[endDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2025-12-31"
            },
            "description": "End date for the report period.",
            "required": false
          },
          {
            "name": "params[groupKey]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "default",
                "monthly",
                "yearly",
                "billing_country",
                "shipping_country",
                "payment_method",
                "payment_status"
              ]
            },
            "description": "Grouping interval for data aggregation.",
            "required": false
          },
          {
            "name": "params[currency]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "USD"
            },
            "description": "Currency code to filter by.",
            "required": false
          },
          {
            "name": "params[filterMode]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "live",
                "test"
              ]
            },
            "description": "Payment mode filter.",
            "required": false
          },
          {
            "name": "params[variation_ids]",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "integer"
              }
            },
            "description": "Array of product variation IDs to filter by.",
            "required": false
          },
          {
            "name": "params[compareType]",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "previous_period",
                "previous_month",
                "previous_quarter",
                "previous_year",
                "custom"
              ]
            },
            "description": "Comparison period type.",
            "required": false
          },
          {
            "name": "params[compareDate]",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "2024-01-01"
            },
            "description": "Custom comparison start date. Required when compareType is custom.",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "retention_data": {
                      "type": "object",
                      "description": "Subscription retention data by billing period"
                    }
                  },
                  "example": {
                    "retention_data": {
                      "labels": [
                        "Period 1",
                        "Period 2",
                        "Period 3",
                        "Period 4",
                        "Period 5",
                        "Period 6",
                        "Period 7",
                        "Period 8",
                        "Period 9",
                        "Period 10",
                        "Period 11",
                        "Period 12"
                      ],
                      "retention_rates": [
                        100,
                        92,
                        87,
                        83,
                        80,
                        78,
                        76,
                        74,
                        73,
                        72,
                        71,
                        70
                      ],
                      "subscriber_counts": [
                        183,
                        168,
                        159,
                        152,
                        146,
                        143,
                        139,
                        135,
                        134,
                        132,
                        130,
                        128
                      ],
                      "churn_rates": [
                        0,
                        8,
                        5.4,
                        4.6,
                        3.6,
                        2.5,
                        2.6,
                        2.6,
                        1.4,
                        1.4,
                        1.4,
                        1.4
                      ],
                      "total_initial_subscribers": 183,
                      "current_active": 128,
                      "overall_retention_rate": 70
                    }
                  }
                },
