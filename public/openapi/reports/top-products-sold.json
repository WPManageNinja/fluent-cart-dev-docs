                        "average_price": 2959
                      },
                      {
                        "product_id": 130,
                        "title": "WordPress starter theme",
                        "total_sold": 76,
                        "total_revenue": 152000,
                        "average_price": 2000
                      },
                      {
                        "product_id": 128,
                        "title": "Cloud Hosting Add-on",
                        "total_sold": 65,
                        "total_revenue": 97500,
                        "average_price": 1500
                      },
                      {
                        "product_id": 135,
                        "title": "Premium Support Package",
                        "total_sold": 42,
                        "total_revenue": 626000,
                        "average_price": 14905
                      }
                    ]
                  }
                },
                "example": {
                  "top_products_sold": [
                    {
                      "product_id": 123,
                      "title": "Developer Toolkit Pro",
                      "total_sold": 142,
                      "total_revenue": 680000,
                      "average_price": 4789
                    },
                    {
                      "product_id": 125,
                      "title": "API Testing Suite",
