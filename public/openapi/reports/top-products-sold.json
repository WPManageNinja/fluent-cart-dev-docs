          "Reports"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "top_products_sold": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      },
                      "description": "List of top-selling products"
                    }
                  },
                  "example": {
                    "top_products_sold": [
                      {
                        "product_id": 123,
                        "title": "Developer Toolkit Pro",
                        "total_sold": 142,
                        "total_revenue": 680000,
                        "average_price": 4789
                      },
                      {
