{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/roles/{key}": {
      "get": {
        "operationId": "getRole",
        "summary": "GET Get Role",
        "description": "Retrieve details for a specific role by its key. This endpoint is currently a placeholder and returns no data. It is reserved for future use.",
        "tags": [
          "Roles"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The role key (e.g., manager, worker, accountant)."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response (currently returns no data)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "role": {
                    "key": "fct_manager",
                    "display_name": "FluentCart Manager",
                    "capabilities": {
                      "fct_manage_orders": true,
                      "fct_manage_products": true,
                      "fct_manage_customers": true,
                      "fct_view_reports": true,
                      "fct_manage_settings": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
