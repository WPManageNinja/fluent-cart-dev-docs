{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/permissions": {
      "post": {
        "operationId": "savePermissions",
        "summary": "POST Save Permissions",
        "description": "Update which WordPress roles have access to FluentCart.",
        "tags": [
          "Roles & Permissions"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "capability"
                ],
                "properties": {
                  "capability": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of WordPress role keys that should have FluentCart access",
                    "example": [
                      "editor",
                      "author"
                    ]
                  }
                },
                "example": {
                  "capability": [
                    "editor",
                    "author"
                  ]
                }
              },
              "example": {
                "capability": [
                  "editor",
                  "author"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Permissions updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Successfully updated the role(s)."
                    }
                  },
                  "example": {
                    "message": "Successfully updated the role(s)."
                  }
                },
                "example": {
                  "message": "Successfully updated the role(s)."
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - User doesn't have manage_options capability",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Sorry, You can not update permissions. Only administrators can update permissions"
                        }
                      }
                    }
                  },
                  "example": {
                    "success": false,
                    "data": {
                      "message": "Sorry, You can not update permissions. Only administrators can update permissions"
                    }
                  }
                },
                "example": {
                  "success": false,
                  "data": {
                    "message": "Sorry, You can not update permissions. Only administrators can update permissions"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SavePermissionsRequest": {
        "type": "object",
        "required": [
          "capability"
        ],
        "properties": {
          "capability": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of WordPress role keys that should have FluentCart access",
            "example": [
              "editor",
              "author"
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
