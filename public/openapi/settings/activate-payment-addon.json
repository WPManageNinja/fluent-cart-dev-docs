{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/payment-methods/activate-addon": {
      "post": {
        "operationId": "activatePaymentAddon",
        "summary": "POST Activate Payment Addon",
        "description": "Activate an already-installed payment gateway addon plugin.",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "plugin_file"
                ],
                "properties": {
                  "plugin_file": {
                    "type": "string",
                    "description": "The plugin file path (e.g., `fluent-cart-pro/fluent-cart-pro.php`).",
                    "example": "fluent-cart-pro/fluent-cart-pro.php"
                  }
                }
              },
              "example": {
                "plugin_file": "fluent-cart-pro/fluent-cart-pro.php"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Payment addon activated successfully!"
                    }
                  }
                },
                "example": {
                  "message": "Payment addon activated successfully!"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}