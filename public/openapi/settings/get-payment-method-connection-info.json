{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/payment-methods/connect/info": {
      "get": {
        "operationId": "getPaymentMethodConnectionInfo",
        "summary": "GET Get Payment Method Connection Info",
        "description": "Retrieve connection information (OAuth URLs, account status) for a connectable payment gateway.",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "method",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "paypal"
            },
            "description": "The payment method key (e.g., `stripe`, `paypal`)."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connect_config": {
                      "type": "object",
                      "properties": {
                        "test_redirect": {
                          "type": "string",
                          "example": "https://example.com/wp-admin/?fluent-cart=..."
                        },
                        "live_redirect": {
                          "type": "string",
                          "example": "https://example.com/wp-admin/?fluent-cart=..."
                        },
                        "disconnect_note": {
                          "type": "string",
                          "example": "Disconnecting will prevent..."
                        }
                      }
                    },
                    "test_account": {
                      "type": "object",
                      "description": "Test account information",
                      "additionalProperties": true
                    },
                    "live_account": {
                      "type": "object",
                      "description": "Live account information",
                      "additionalProperties": true
                    },
                    "settings": {
                      "type": "object",
                      "description": "Current payment method settings",
                      "additionalProperties": true
                    }
                  }
                },
                "example": {
                  "connect_config": {
                    "test_redirect": "https://example.com/wp-admin/?fluent-cart=paypal-connect&mode=test",
                    "live_redirect": "https://example.com/wp-admin/?fluent-cart=paypal-connect&mode=live",
                    "disconnect_note": "Disconnecting will prevent PayPal from processing payments. Existing subscriptions will not be affected until their next renewal."
                  },
                  "test_account": {
                    "merchant_id": "TESTMERCHANT123",
                    "email": "seller-test@example.com",
                    "connected": true,
                    "webhook_id": "WH-TEST-1234567890"
                  },
                  "live_account": {
                    "merchant_id": "LIVEMERCHANT456",
                    "email": "payments@techstore.com",
                    "connected": true,
                    "webhook_id": "WH-LIVE-0987654321"
                  },
                  "settings": {
                    "is_active": "yes",
                    "payment_mode": "live",
                    "checkout_label": "Pay with PayPal",
                    "checkout_logo": "https://example.com/wp-content/plugins/fluent-cart/assets/images/paypal.svg"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
