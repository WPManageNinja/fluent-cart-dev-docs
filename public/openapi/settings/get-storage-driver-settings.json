{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/storage-drivers/{driver}": {
      "get": {
        "operationId": "getStorageDriverSettings",
        "summary": "GET Get Storage Driver Settings",
        "description": "Retrieve the configuration settings and field schema for a specific storage driver.",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "driver",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "s3"
            },
            "description": "The storage driver key (e.g., `local`, `s3`, `bunny`)."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "settings": {
                      "type": "object",
                      "description": "Driver configuration settings",
                      "additionalProperties": true
                    },
                    "fields": {
                      "type": "object",
                      "description": "Settings field schema definitions",
                      "additionalProperties": true
                    }
                  },
                  "example": {
                    "settings": {
                      "access_key": "AKIAIOSFODNN7EXAMPLE",
                      "secret_key": "****",
                      "bucket": "techstore-downloads",
                      "region": "us-east-1",
                      "is_active": true,
                      "base_url": "https://techstore-downloads.s3.amazonaws.com"
                    },
                    "fields": {
                      "s3_config": {
                        "title": "S3 Configuration",
                        "type": "section",
                        "schema": {
                          "access_key": {
                            "label": "Access Key ID",
                            "type": "text",
                            "required": true
                          },
                          "secret_key": {
                            "label": "Secret Access Key",
                            "type": "password",
                            "required": true
                          },
                          "bucket": {
                            "label": "Bucket Name",
                            "type": "text",
                            "required": true
                          },
                          "region": {
                            "label": "Region",
                            "type": "select",
                            "required": true
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "settings": {
                    "access_key": "AKIAIOSFODNN7EXAMPLE",
                    "secret_key": "****",
                    "bucket": "techstore-downloads",
                    "region": "us-east-1",
                    "is_active": true,
                    "base_url": "https://techstore-downloads.s3.amazonaws.com"
                  },
                  "fields": {
                    "s3_config": {
                      "title": "S3 Configuration",
                      "type": "section",
                      "schema": {
                        "access_key": {
                          "label": "Access Key ID",
                          "type": "text",
                          "required": true
                        },
                        "secret_key": {
                          "label": "Secret Access Key",
                          "type": "password",
                          "required": true
                        },
                        "bucket": {
                          "label": "Bucket Name",
                          "type": "text",
                          "required": true
                        },
                        "region": {
                          "label": "Region",
                          "type": "select",
                          "required": true
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
