{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/modules/plugin-addons/install": {
      "post": {
        "operationId": "installPluginAddon",
        "summary": "POST Install Plugin Addon",
        "description": "Install a registered plugin addon from its configured source (WordPress.org, GitHub, or CDN).",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "plugin_slug"
                ],
                "properties": {
                  "plugin_slug": {
                    "type": "string",
                    "description": "The slug of the addon to install. Must match a registered addon slug.",
                    "example": "fluent-cart-elementor-blocks"
                  },
                  "source_type": {
                    "type": "string",
                    "description": "Source type: `wordpress`, `github`, or `cdn`. Defaults to the addon's registered source.",
                    "enum": [
                      "wordpress",
                      "github",
                      "cdn"
                    ],
                    "example": "cdn"
                  },
                  "source_link": {
                    "type": "string",
                    "description": "URL to the addon source. Defaults to the addon's registered source link.",
                    "example": "https://addons-cdn.fluentcart.com/fluent-cart-elementor-blocks.zip"
                  },
                  "asset_path": {
                    "type": "string",
                    "description": "GitHub release asset path (defaults to `zipball_url`).",
                    "example": "zipball_url"
                  }
                }
              },
              "example": {
                "plugin_slug": "fluent-cart-elementor-blocks"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Addon installed successfully"
                    },
                    "plugin_file": {
                      "type": "string",
                      "example": "fluent-cart-elementor-blocks/fluent-cart-elementor-blocks.php"
                    }
                  }
                },
                "example": {
                  "message": "Addon installed successfully",
                  "plugin_file": "fluent-cart-elementor-blocks/fluent-cart-elementor-blocks.php"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}