{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/payment-methods/reorder": {
      "post": {
        "operationId": "reorderPaymentMethods",
        "summary": "POST Reorder Payment Methods",
        "description": "Set the display order of payment methods on the checkout page.",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "order"
                ],
                "properties": {
                  "order": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Ordered array of payment method keys.",
                    "example": [
                      "stripe",
                      "paypal",
                      "cod"
                    ]
                  }
                },
                "example": {
                  "order": [
                    "stripe",
                    "paypal",
                    "cod"
                  ]
                }
              },
              "example": {
                "order": [
                  "stripe",
                  "paypal",
                  "cod"
                ]
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "order": [
                      "stripe",
                      "paypal",
                      "cod"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Payment methods order saved successfully"
                    },
                    "order": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "example": [
                        "stripe",
                        "paypal",
                        "cod"
                      ]
                    }
                  },
                  "example": {
                    "message": "Payment methods order saved successfully",
                    "order": [
                      "stripe",
                      "paypal",
                      "cod"
                    ]
                  }
                },
                "example": {
                  "message": "Payment methods order saved successfully",
                  "order": [
                    "stripe",
                    "paypal",
                    "cod"
                  ]
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Payment methods order saved successfully",
                      "order": [
                        "stripe",
                        "paypal",
                        "cod"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
