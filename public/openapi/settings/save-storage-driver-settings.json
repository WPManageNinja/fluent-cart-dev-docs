{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/storage-drivers": {
      "post": {
        "operationId": "saveStorageDriverSettings",
        "summary": "POST Save Storage Driver Settings",
        "description": "Create or update settings for a specific file storage driver.",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "driver",
                  "settings"
                ],
                "properties": {
                  "driver": {
                    "type": "string",
                    "description": "The storage driver key (e.g., `local`, `s3`, `bunny`).",
                    "example": "s3"
                  },
                  "settings": {
                    "type": "object",
                    "description": "Driver-specific configuration settings. Fields vary by driver.",
                    "additionalProperties": true,
                    "example": {
                      "access_key": "AKIA...",
                      "secret_key": "wJalr...",
                      "bucket": "my-store-files",
                      "region": "us-east-1"
                    }
                  }
                }
              },
              "example": {
                "driver": "s3",
                "settings": {
                  "access_key": "AKIA...",
                  "secret_key": "wJalr...",
                  "bucket": "my-store-files",
                  "region": "us-east-1"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Settings saved successfully"
                    },
                    "data": {
                      "type": "object",
                      "description": "Saved driver settings",
                      "additionalProperties": true
                    }
                  }
                },
                "example": {
                  "message": "Settings saved successfully",
                  "data": {
                    "access_key": "AKIAIOSFODNN7EXAMPLE",
                    "secret_key": "****",
                    "bucket": "techstore-downloads",
                    "region": "us-east-1",
                    "is_active": true,
                    "base_url": "https://techstore-downloads.s3.amazonaws.com"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords — use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
