{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/settings/storage-drivers/verify-info": {
      "post": {
        "operationId": "verifyStorageDriverConnection",
        "summary": "POST Verify Storage Driver Connection",
        "description": "Test the connection to a storage driver using the provided credentials without saving them.",
        "tags": [
          "Settings"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "driver",
                  "settings"
                ],
                "properties": {
                  "driver": {
                    "type": "string",
                    "description": "The storage driver key (e.g., `s3`, `bunny`).",
                    "example": "s3"
                  },
                  "settings": {
                    "type": "object",
                    "description": "Driver-specific credentials and configuration to verify. Fields vary by driver.",
                    "additionalProperties": true,
                    "example": {
                      "access_key": "AKIA...",
                      "secret_key": "wJalr...",
                      "bucket": "my-store-files",
                      "region": "us-east-1"
                    }
                  }
                },
                "example": {
                  "driver": "s3",
                  "settings": {
                    "access_key": "AKIA...",
                    "secret_key": "wJalr...",
                    "bucket": "my-store-files",
                    "region": "us-east-1"
                  }
                }
              },
              "example": {
                "driver": "s3",
                "settings": {
                  "access_key": "AKIA...",
                  "secret_key": "wJalr...",
                  "bucket": "my-store-files",
                  "region": "us-east-1"
                }
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "driver": "s3",
                    "settings": {
                      "access_key": "AKIA...",
                      "secret_key": "wJalr...",
                      "bucket": "my-store-files",
                      "region": "us-east-1"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Connection verified successfully"
                    }
                  },
                  "example": {
                    "message": "Connection verified successfully"
                  }
                },
                "example": {
                  "message": "Connection verified successfully"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Connection verified successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
