{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/shipping/classes/{id}": {
      "get": {
        "operationId": "getShippingClass",
        "summary": "GET Get Shipping Class",
        "description": "Retrieve a single shipping class by ID.",
        "tags": [
          "Shipping"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The shipping class ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns the shipping class.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "shipping_class": {
                      "$ref": "#/components/schemas/ShippingClass"
                    }
                  },
                  "example": {
                    "shipping_class": {
                      "id": 1,
                      "name": "Heavy Items",
                      "cost": 15.0,
                      "type": "fixed",
                      "per_item": 1,
                      "created_at": "2025-01-20 09:00:00",
                      "updated_at": "2025-01-20 09:00:00"
                    }
                  }
                },
                "example": {
                  "shipping_class": {
                    "id": 1,
                    "name": "Heavy Items",
                    "cost": 15.0,
                    "type": "fixed",
                    "per_item": 1,
                    "created_at": "2025-01-20 09:00:00",
                    "updated_at": "2025-01-20 09:00:00"
                  }
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "shipping_class": {
                        "id": 1,
                        "name": "Heavy Items",
                        "cost": 15.0,
                        "type": "fixed",
                        "per_item": 1,
                        "created_at": "2025-01-20 09:00:00",
                        "updated_at": "2025-01-20 09:00:00"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ShippingClass": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique class identifier",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "Class display name",
            "example": "Heavy Items"
          },
          "cost": {
            "type": "number",
            "format": "float",
            "description": "Cost value",
            "example": 15.0
          },
          "type": {
            "type": "string",
            "enum": [
              "fixed",
              "percentage"
            ],
            "description": "Cost type",
            "example": "fixed"
          },
          "per_item": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "1 = per item, 0 = per order",
            "example": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp (UTC)"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp (UTC)"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
