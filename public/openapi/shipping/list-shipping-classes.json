{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/shipping/classes": {
      "get": {
        "operationId": "listShippingClasses",
        "summary": "GET List Shipping Classes",
        "description": "Retrieve a paginated list of shipping classes with filtering and sorting capabilities.",
        "tags": [
          "Shipping"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search classes by name",
            "required": false
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 200
            },
            "description": "Number of results per page (default: 10, max: 200)",
            "required": false
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Column to sort by (default: id)",
            "required": false
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "description": "Sort direction: asc or desc (default: desc)",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ]
            },
            "description": "Filter type: simple or advanced",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of shipping classes.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "shipping_classes": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "current_page": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/ShippingClass"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "shipping_classes": {
                    "total": 3,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 1,
                    "data": [
                      {
                        "id": 1,
                        "name": "Heavy Items",
                        "cost": 15.0,
                        "type": "fixed",
                        "per_item": 1,
                        "created_at": "2025-01-20 09:00:00",
                        "updated_at": "2025-01-20 09:00:00"
                      },
                      {
                        "id": 2,
                        "name": "Fragile Items",
                        "cost": 10.0,
                        "type": "percentage",
                        "per_item": 0,
                        "created_at": "2025-01-21 10:00:00",
                        "updated_at": "2025-01-21 10:00:00"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ShippingClass": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique class identifier",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "Class display name",
            "example": "Heavy Items"
          },
          "cost": {
            "type": "number",
            "format": "float",
            "description": "Cost value (flat amount or percentage)",
            "example": 15.0
          },
          "type": {
            "type": "string",
            "enum": [
              "fixed",
              "percentage"
            ],
            "description": "Cost type: fixed or percentage",
            "example": "fixed"
          },
          "per_item": {
            "type": "integer",
            "enum": [
              0,
              1
            ],
            "description": "1 = cost applied per item, 0 = cost applied per order",
            "example": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp (UTC)"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp (UTC)"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}