{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/shipping/methods": {
      "put": {
        "operationId": "updateShippingMethod",
        "summary": "PUT Update Shipping Method",
        "description": "Update an existing shipping method. The method ID is passed in the request body.",
        "tags": [
          "Shipping"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "method_id",
                  "zone_id",
                  "title",
                  "type"
                ],
                "properties": {
                  "method_id": {
                    "type": "integer",
                    "description": "ID of the shipping method to update"
                  },
                  "zone_id": {
                    "type": "integer",
                    "description": "ID of the parent shipping zone"
                  },
                  "title": {
                    "type": "string",
                    "maxLength": 192,
                    "description": "Method display title (max 192 characters)"
                  },
                  "type": {
                    "type": "string",
                    "maxLength": 192,
                    "description": "Shipping method type (e.g., flat_rate, free_shipping, local_pickup)"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Shipping cost in cents (e.g., 500 for $5.00)"
                  },
                  "is_enabled": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Enable/disable the method: 1 (enabled) or 0 (disabled)"
                  },
                  "states": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of state/province codes to restrict this method to. Empty array means all states."
                  },
                  "settings": {
                    "type": "object",
                    "properties": {
                      "configure_rate": {
                        "type": "string",
                        "description": "Rate configuration type"
                      },
                      "class_aggregation": {
                        "type": "string",
                        "description": "How shipping classes are aggregated"
                      }
                    },
                    "description": "Additional settings for the method"
                  },
                  "meta": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "Additional metadata key-value pairs (string values only)"
                  }
                },
                "example": {
                  "method_id": 10,
                  "zone_id": 1,
                  "title": "Express Shipping",
                  "type": "flat_rate",
                  "amount": "1200",
                  "is_enabled": 1,
                  "states": [
                    "CA",
                    "NY",
                    "TX",
                    "FL"
                  ]
                }
              },
              "example": {
                "method_id": 10,
                "zone_id": 1,
                "title": "Express Shipping",
                "type": "flat_rate",
                "amount": "1200",
                "is_enabled": 1,
                "states": [
                  "CA",
                  "NY",
                  "TX",
                  "FL"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipping method updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "message": "Shipping method has been updated successfully"
                  }
                },
                "example": {
                  "message": "Shipping method has been updated successfully"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
