{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/orders/{order}/subscriptions/{subscription}/cancel": {
      "put": {
        "operationId": "cancelSubscription",
        "summary": "PUT Cancel Subscription",
        "description": "Cancel a subscription both locally and with the remote payment gateway.",
        "tags": [
          "Subscriptions"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "order",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The parent order ID"
          },
          {
            "name": "subscription",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The subscription ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "cancel_reason"
                ],
                "properties": {
                  "cancel_reason": {
                    "type": "string",
                    "description": "Reason for cancellation. Sanitized with sanitize_text_field.",
                    "example": "Customer requested cancellation"
                  }
                },
                "example": {
                  "cancel_reason": "Customer requested cancellation"
                }
              },
              "example": {
                "cancel_reason": "Customer requested cancellation"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "subscription": {
                      "$ref": "#/components/schemas/Subscription"
                    }
                  },
                  "example": {
                    "message": "Subscription has been cancelled successfully!",
                    "subscription": {
                      "id": 15,
                      "status": "canceled"
                    }
                  }
                },
                "example": {
                  "message": "Subscription has been cancelled successfully!",
                  "subscription": {
                    "id": 15,
                    "status": "canceled"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing cancel reason or remote failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "example": {
                    "message": "Please select cancel reason!"
                  }
                },
                "example": {
                  "message": "Please select cancel reason!"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Subscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Subscription ID",
            "example": 15
          },
          "status": {
            "type": "string",
            "description": "Subscription status",
            "example": "canceled"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
