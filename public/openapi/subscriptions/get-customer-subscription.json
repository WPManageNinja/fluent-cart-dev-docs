  "components": {
    "schemas": {
      "CustomerSubscriptionDetail": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Unique subscription identifier",
            "example": "a3f7c1b2-9e4d-4a8b-b5c6-d7e8f9012345"
          },
          "status": {
            "type": "string",
            "description": "Current status: active, trialing, canceled, paused, failing, expiring, expired, completed, past_due",
            "example": "active"
          },
          "overridden_status": {
            "type": "string",
            "nullable": true,
            "description": "Overridden status if manually set"
          },
          "vendor_subscription_id": {
            "type": "string",
            "description": "Remote gateway subscription ID",
            "example": "sub_1QxR3nH"
          },
          "next_billing_date": {
            "type": "string",
            "format": "date-time",
            "description": "Next billing date in GMT",
            "example": "2026-09-20 14:25:00"
          },
          "billing_info": {
            "type": "object",
            "description": "Billing interval and amount details",
            "properties": {
              "interval": {
                "type": "string",
                "example": "yearly"
              },
              "interval_count": {
                "type": "integer",
                "example": 1
              },
              "amount": {
                "type": "integer",
                "example": 9900
              },
              "currency": {
                "type": "string",
                "example": "USD"
              }
            }
          },
          "current_payment_method": {
            "type": "string",
            "description": "Current payment method slug",
            "example": "stripe"
          },
          "payment_method": {
            "type": "string",
            "description": "Original payment method slug",
            "example": "stripe"
          },
          "payment_info": {
            "type": "object",
            "description": "Payment method details (card brand, last4, etc.)",
            "example": {
              "card_last_4": "4242",
              "card_brand": "visa"
            }
          },
          "bill_times": {
            "type": "integer",
            "description": "Total number of billing cycles (0 = unlimited)",
            "example": 0
          },
          "bill_count": {
            "type": "integer",
            "description": "Number of completed billing cycles",
            "example": 1
          },
          "variation_id": {
            "type": "integer",
            "description": "Product variation ID",
            "example": 457
          },
          "product_id": {
            "type": "integer",
            "description": "Product ID",
            "example": 123
          },
          "config": {
            "type": "object",
            "description": "Subscription configuration",
            "example": {
              "cancel_at_period_end": false,
              "prorate": true
            }
          },
          "reactivate_url": {
            "type": "string",
            "description": "URL for reactivating a canceled subscription",
            "example": "https://example.com/?fluent-cart=reactivate&hash=a3f7c1b2-9e4d-4a8b-b5c6-d7e8f9012345"
          },
          "title": {
            "type": "string",
            "description": "Product title",
            "example": "Developer Toolkit Pro"
          },
          "subtitle": {
            "type": "string",
            "description": "Variation title (if applicable)",
            "example": "Business Annual"
          },
          "can_upgrade": {
            "type": "boolean",
            "description": "Whether the subscription is eligible for plan upgrade",
            "example": true
          },
          "can_switch_payment_method": {
            "type": "boolean",
            "description": "Whether the payment method can be switched to a different gateway",
            "example": true
          },
          "switchable_payment_methods": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of available payment method slugs to switch to",
            "example": [
              "stripe",
              "paypal"
            ]
          },
          "can_update_payment_method": {
            "type": "boolean",
            "description": "Whether the payment method can be updated within the same gateway",
            "example": true
          },
          "order": {
            "type": "object",
            "properties": {
              "uuid": {
                "type": "string",
                "description": "Parent order UUID",
                "example": "e7b3a1d4-5f2c-48e9-a6b1-c3d4e5f67890"
              }
            }
          },
          "billing_addresses": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Billing addresses associated with the subscription",
            "example": [
              {
                "first_name": "Sarah",
                "last_name": "Johnson",
                "address_line_1": "742 Evergreen Terrace",
                "address_line_2": "Suite 200",
                "city": "Portland",
                "state": "OR",
                "zip": "97201",
                "country": "US"
              }
            ]
          },
          "recurring_amount": {
            "type": "integer",
            "description": "Recurring payment amount in cents",
            "example": 9900
          },
          "can_early_pay": {
            "type": "boolean",
            "description": "Whether early installment payment is available",
            "example": false
          },
          "remaining_installments": {
            "type": "integer",
            "description": "Number of remaining installments (0 if unlimited)",
            "example": 0
          },
          "transactions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            },
            "description": "All transactions related to this subscription and its renewal orders"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 34
          },
          "order_id": {
            "type": "integer",
            "example": 42
          },
          "vendor_charge_id": {
            "type": "string",
            "example": "ch_3QxR4nIbK"
          },
          "amount": {
            "type": "integer",
            "description": "Amount in cents",
            "example": 9900
          },
          "status": {
            "type": "string",
            "example": "completed"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2025-09-20 14:25:30"
          },
          "order": {
            "type": "object",
            "description": "Related order details",
            "example": {
              "id": 42,
              "uuid": "e7b3a1d4-5f2c-48e9-a6b1-c3d4e5f67890",
              "status": "completed",
              "total": 10692
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
