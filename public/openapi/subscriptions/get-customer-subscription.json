                      "payment_info": {
                        "card_last_4": "4242",
                        "card_brand": "visa"
                      },
                      "bill_times": 0,
                      "bill_count": 1,
                      "variation_id": 457,
                      "product_id": 123,
                      "config": {
                        "cancel_at_period_end": false,
