{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/subscriptions/{subscription_uuid}/setup-intent-attempts": {
      "get": {
        "operationId": "getSetupIntentAttempts",
        "summary": "GET Get Setup Intent Remaining Attempts",
        "description": "Check how many Stripe SetupIntent attempts remain for the customer. Used to enforce rate limiting on payment method update attempts. Only works when the subscription's current_payment_method is stripe.",
        "tags": [
          "Subscriptions"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "subscription_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The subscription UUID (alphanumeric with dashes)"
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the number of remaining setup intent attempts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "remaining": {
                      "type": "integer",
                      "description": "Number of remaining setup intent attempts"
                    }
                  },
                  "example": {
                    "remaining": 5
                  }
                },
                "example": {
                  "remaining": 5
                }
              }
            }
          },
          "400": {
            "description": "Payment method not supported (non-Stripe subscription)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error",
                  "example": {
                    "message": "Payment method not supported"
                  }
                },
                "example": {
                  "message": "Payment method not supported"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
