{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/subscriptions/{subscriptionOrderId}": {
      "get": {
        "operationId": "getSubscription",
        "summary": "GET Get Subscription Details",
        "description": "Retrieve the full details of a single subscription including customer addresses, labels, activities, and related orders.",
        "tags": [
          "Subscriptions"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "subscriptionOrderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "The subscription ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns the subscription with eager-loaded relations including labels, activities, customer addresses, and related orders.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscription": {
                      "$ref": "#/components/schemas/SubscriptionDetail"
                    },
                    "selected_labels": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "description": "Array of label IDs applied to the subscription"
                    }
                  }
                },
                "example": {
                  "subscription": {
                    "id": 1,
                    "uuid": "abc123-def456",
                    "status": "active",
                    "item_name": "Pro Plan",
                    "parent_order_id": 10,
                    "customer_id": 5,
                    "product_id": 3,
                    "variation_id": 7,
                    "vendor_subscription_id": "sub_1234567890",
                    "vendor_customer_id": "cus_abc123",
                    "current_payment_method": "stripe",
                    "billing_interval": "monthly",
                    "recurring_amount": 2999,
                    "bill_times": 0,
                    "bill_count": 6,
                    "next_billing_date": "2025-02-15 00:00:00",
                    "labels": [],
                    "activities": [],
                    "customer": {
                      "id": 5,
                      "shipping_address": {},
                      "billing_address": {}
                    },
                    "related_orders": [
                      {
                        "id": 10,
                        "order_items": [
                          {
                            "id": 1,
                            "order_id": 10,
                            "post_title": "Pro Plan",
                            "title": "Pro Plan",
                            "quantity": 1,
                            "payment_type": "subscription",
                            "line_meta": {}
                          }
                        ]
                      }
                    ]
                  },
                  "selected_labels": [
                    1,
                    3,
                    5
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Subscription not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Subscription not found",
                  "action_text": "Back to Subscription list",
                  "action_url": "/subscriptions"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SubscriptionDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Subscription"
          },
          {
            "type": "object",
            "properties": {
              "labels": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "Labels associated with the subscription"
              },
              "activities": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "Activity log with user info"
              },
              "customer": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "example": 5
                  },
                  "shipping_address": {
                    "type": "object",
                    "description": "Customer's primary shipping address"
                  },
                  "billing_address": {
                    "type": "object",
                    "description": "Customer's primary billing address"
                  }
                },
                "description": "Customer with addresses"
              },
              "related_orders": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RelatedOrder"
                },
                "description": "The parent order and all renewal orders with order items"
              }
            }
          }
        ]
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Subscription ID",
            "example": 1
          },
          "uuid": {
            "type": "string",
            "description": "Subscription UUID",
            "example": "abc123-def456"
          },
          "status": {
            "type": "string",
            "description": "Subscription status",
            "example": "active"
          },
          "item_name": {
            "type": "string",
            "description": "Item name",
            "example": "Pro Plan"
          },
          "parent_order_id": {
            "type": "integer",
            "description": "Parent order ID",
            "example": 10
          },
          "customer_id": {
            "type": "integer",
            "description": "Customer ID",
            "example": 5
          },
          "product_id": {
            "type": "integer",
            "description": "Product ID",
            "example": 3
          },
          "variation_id": {
            "type": "integer",
            "description": "Variation ID",
            "example": 7
          },
          "vendor_subscription_id": {
            "type": "string",
            "description": "Vendor subscription ID",
            "example": "sub_1234567890"
          },
          "vendor_customer_id": {
            "type": "string",
            "description": "Vendor customer ID",
            "example": "cus_abc123"
          },
          "current_payment_method": {
            "type": "string",
            "description": "Current payment method",
            "example": "stripe"
          },
          "billing_interval": {
            "type": "string",
            "description": "Billing interval",
            "example": "monthly"
          },
          "recurring_amount": {
            "type": "integer",
            "description": "Recurring amount in cents",
            "example": 2999
          },
          "bill_times": {
            "type": "integer",
            "description": "Number of times to bill (0 = unlimited)",
            "example": 0
          },
          "bill_count": {
            "type": "integer",
            "description": "Number of completed billing cycles",
            "example": 6
          },
          "next_billing_date": {
            "type": "string",
            "format": "date-time",
            "description": "Next billing date in GMT",
            "example": "2025-02-15 00:00:00"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-01-15 10:30:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-01-15 10:35:00"
          }
        }
      },
      "RelatedOrder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 10
          },
          "order_items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "example": 1
                },
                "order_id": {
                  "type": "integer",
                  "example": 10
                },
                "post_title": {
                  "type": "string",
                  "example": "Pro Plan"
                },
                "title": {
                  "type": "string",
                  "example": "Pro Plan"
                },
                "quantity": {
                  "type": "integer",
                  "example": 1
                },
                "payment_type": {
                  "type": "string",
                  "example": "subscription"
                },
                "line_meta": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "action_text": {
            "type": "string"
          },
          "action_url": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}