  "components": {
    "schemas": {
      "SubscriptionDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Subscription"
          },
          {
            "type": "object",
            "properties": {
              "labels": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "Labels associated with the subscription"
              },
              "activities": {
                "type": "array",
                "items": {
                  "type": "object"
                },
                "description": "Activity log with user info"
              },
              "customer": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "example": 12
                  },
                  "shipping_address": {
                    "type": "object",
                    "description": "Customer's primary shipping address"
                  },
                  "billing_address": {
                    "type": "object",
                    "description": "Customer's primary billing address"
                  }
                },
                "description": "Customer with addresses"
              },
              "related_orders": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RelatedOrder"
                },
                "description": "The parent order and all renewal orders with order items"
              }
            }
          }
        ]
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Subscription ID",
            "example": 15
          },
          "uuid": {
            "type": "string",
            "description": "Subscription UUID",
            "example": "a3f7c1b2-9e4d-4a8b-b5c6-d7e8f9012345"
          },
          "status": {
            "type": "string",
            "description": "Subscription status",
            "example": "active"
          },
          "item_name": {
            "type": "string",
            "description": "Item name",
            "example": "Developer Toolkit Pro - Business Annual"
          },
          "parent_order_id": {
            "type": "integer",
            "description": "Parent order ID",
            "example": 42
          },
          "customer_id": {
            "type": "integer",
            "description": "Customer ID",
            "example": 12
          },
          "product_id": {
            "type": "integer",
            "description": "Product ID",
            "example": 123
          },
          "variation_id": {
            "type": "integer",
            "description": "Variation ID",
            "example": 457
          },
          "vendor_subscription_id": {
            "type": "string",
            "description": "Vendor subscription ID",
            "example": "sub_1QxR3nH"
          },
          "vendor_customer_id": {
            "type": "string",
            "description": "Vendor customer ID",
            "example": "cus_Qx7K9mN3pR"
          },
          "current_payment_method": {
            "type": "string",
            "description": "Current payment method",
            "example": "stripe"
          },
          "billing_interval": {
            "type": "string",
            "description": "Billing interval",
            "example": "yearly"
          },
          "recurring_amount": {
            "type": "integer",
            "description": "Recurring amount in cents",
            "example": 9900
          },
          "bill_times": {
            "type": "integer",
            "description": "Number of times to bill (0 = unlimited)",
            "example": 0
          },
          "bill_count": {
            "type": "integer",
            "description": "Number of completed billing cycles",
            "example": 1
          },
          "next_billing_date": {
            "type": "string",
            "format": "date-time",
            "description": "Next billing date in GMT",
            "example": "2026-09-20 14:25:00"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-09-20 14:25:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-09-20 14:25:30"
          }
        }
      },
      "RelatedOrder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 42
          },
          "order_items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "example": 58
                },
                "order_id": {
                  "type": "integer",
                  "example": 42
                },
                "post_title": {
                  "type": "string",
                  "example": "Developer Toolkit Pro"
                },
                "title": {
                  "type": "string",
                  "example": "Developer Toolkit Pro - Business Annual"
                },
                "quantity": {
                  "type": "integer",
                  "example": 1
                },
                "payment_type": {
                  "type": "string",
                  "example": "subscription"
                },
                "line_meta": {
                  "type": "object",
                  "description": "Line item metadata including billing details",
                  "example": {
                    "billing_interval": "yearly",
                    "recurring_amount": 9900,
                    "signup_fee": 0,
                    "trial_days": 0
                  }
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "action_text": {
            "type": "string"
          },
          "action_url": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
