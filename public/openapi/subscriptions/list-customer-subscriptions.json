{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/subscriptions": {
      "get": {
        "operationId": "listCustomerSubscriptions",
        "summary": "GET List Customer Subscriptions",
        "description": "Retrieve a paginated list of subscriptions belonging to the currently logged-in customer. Subscriptions with pending or intended status are excluded.",
        "tags": [
          "Subscriptions"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for pagination (default: 1)",
            "example": 1
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1
            },
            "description": "Number of records per page (default: 10)",
            "example": 10
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of customer subscriptions. If the user is not logged in, returns an empty result set.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "subscriptions": {
                      "$ref": "#/components/schemas/CustomerSubscriptionPagination"
                    }
                  }
                },
                "example": {
                  "message": "Success",
                  "subscriptions": {
                    "data": [
                      {
                        "uuid": "abc123-def456",
                        "status": "active",
                        "item_name": "Pro Plan",
                        "billing_interval": "monthly",
                        "recurring_amount": 2999,
                        "next_billing_date": "2025-02-15 00:00:00",
                        "bill_times": 0,
                        "bill_count": 6
                      }
                    ],
                    "total": 5,
                    "per_page": 10,
                    "current_page": 1,
                    "last_page": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CustomerSubscription": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "description": "Subscription UUID",
            "example": "abc123-def456"
          },
          "status": {
            "type": "string",
            "description": "Subscription status",
            "example": "active"
          },
          "item_name": {
            "type": "string",
            "description": "Item name",
            "example": "Pro Plan"
          },
          "billing_interval": {
            "type": "string",
            "description": "Billing interval",
            "example": "monthly"
          },
          "recurring_amount": {
            "type": "integer",
            "description": "Recurring amount in cents",
            "example": 2999
          },
          "next_billing_date": {
            "type": "string",
            "format": "date-time",
            "description": "Next billing date in GMT",
            "example": "2025-02-15 00:00:00"
          },
          "bill_times": {
            "type": "integer",
            "description": "Number of times to bill (0 = unlimited)",
            "example": 0
          },
          "bill_count": {
            "type": "integer",
            "description": "Number of completed billing cycles",
            "example": 6
          }
        }
      },
      "CustomerSubscriptionPagination": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomerSubscription"
            }
          },
          "total": {
            "type": "integer",
            "example": 5
          },
          "per_page": {
            "type": "integer",
            "example": 10
          },
          "current_page": {
            "type": "integer",
            "example": 1
          },
          "last_page": {
            "type": "integer",
            "example": 1
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}