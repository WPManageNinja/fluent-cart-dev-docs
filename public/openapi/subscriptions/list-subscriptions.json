{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/subscriptions": {
      "get": {
        "operationId": "listSubscriptions",
        "summary": "GET List Subscriptions",
        "description": "Retrieve a paginated list of subscriptions with optional filtering, sorting, and search.",
        "tags": [
          "Subscriptions"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            },
            "description": "Page number for pagination",
            "example": 1
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 200
            },
            "description": "Number of records per page (default: 10, max: 200)",
            "example": 10
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search term. Searches status, subscription ID (#123), customer email (user@example.com), parent order ID, item name, vendor subscription/customer/plan IDs, payment method, billing interval, and bill count. Also supports operator syntax (e.g., ID = 5).",
            "required": false
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "id"
            },
            "description": "Column to sort by (default: id). Must be a fillable column on the Subscription model.",
            "example": "id"
          },
          {
            "name": "sort_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            },
            "description": "Sort direction: asc or desc (default: desc)",
            "example": "desc"
          },
          {
            "name": "active_view",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "pending",
                "intended",
                "paused",
                "trialing",
                "canceled",
                "failing",
                "expiring",
                "expired"
              ]
            },
            "description": "Tab filter for subscription status.",
            "required": false
          },
          {
            "name": "filter_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ],
              "default": "simple"
            },
            "description": "Filter mode: simple (default) or advanced.",
            "required": false
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "json"
            },
            "description": "JSON-encoded array of advanced filter groups (requires Pro). Supports filtering by subscription, transaction, product, and license properties.",
            "required": false
          },
          {
            "name": "with",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Eager-load relations. Supports relation names and {relation}Count for counts.",
            "required": false
          },
          {
            "name": "select",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of columns to select.",
            "required": false
          },
          {
            "name": "include_ids",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated IDs that must always be included in results.",
            "required": false
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Limit number of records (used with non-paginated queries).",
            "required": false
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Offset for records.",
            "required": false
          },
          {
            "name": "user_tz",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "User timezone for date filtering (e.g., America/New_York).",
            "required": false,
            "example": "America/New_York"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns a paginated list of subscriptions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Pagination"
                    }
                  }
                },
                "example": {
                  "data": {
                    "current_page": 1,
                    "data": [
                      {
                        "id": 15,
                        "uuid": "a3f7c1b2-9e4d-4a8b-b5c6-d7e8f9012345",
                        "status": "active",
                        "item_name": "Developer Toolkit Pro - Business Annual",
                        "parent_order_id": 42,
                        "customer_id": 12,
                        "product_id": 123,
                        "variation_id": 457,
                        "vendor_subscription_id": "sub_1QxR3nH",
                        "vendor_customer_id": "cus_Qx7K9mN3pR",
                        "vendor_plan_id": "price_1Px8KLM",
                        "current_payment_method": "stripe",
                        "billing_interval": "yearly",
                        "recurring_amount": 9900,
                        "bill_times": 0,
                        "bill_count": 1,
                        "next_billing_date": "2026-09-20 14:25:00",
                        "created_at": "2025-09-20 14:25:00",
                        "updated_at": "2025-09-20 14:25:30"
                      },
                      {
                        "id": 16,
                        "uuid": "b4e8d2c3-0f5e-5b9c-c6d7-e8f9a0123456",
                        "status": "trialing",
                        "item_name": "CloudSync Starter - Monthly",
                        "parent_order_id": 45,
                        "customer_id": 18,
                        "product_id": 130,
                        "variation_id": 462,
                        "vendor_subscription_id": "sub_2RyS4oI",
                        "vendor_customer_id": "cus_Ry8L0nO4qS",
                        "vendor_plan_id": "price_2Qy9LMN",
                        "current_payment_method": "stripe",
                        "billing_interval": "monthly",
                        "recurring_amount": 1900,
                        "bill_times": 12,
                        "bill_count": 0,
                        "next_billing_date": "2026-04-15 09:00:00",
                        "created_at": "2026-03-01 09:00:00",
                        "updated_at": "2026-03-01 09:00:15"
                      }
                    ],
                    "per_page": 10,
                    "total": 50,
                    "last_page": 5
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Subscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Subscription ID",
            "example": 15
          },
          "uuid": {
            "type": "string",
            "description": "Subscription UUID",
            "example": "a3f7c1b2-9e4d-4a8b-b5c6-d7e8f9012345"
          },
          "status": {
            "type": "string",
            "description": "Subscription status",
            "example": "active"
          },
          "item_name": {
            "type": "string",
            "description": "Item name",
            "example": "Developer Toolkit Pro - Business Annual"
          },
          "parent_order_id": {
            "type": "integer",
            "description": "Parent order ID",
            "example": 42
          },
          "customer_id": {
            "type": "integer",
            "description": "Customer ID",
            "example": 12
          },
          "product_id": {
            "type": "integer",
            "description": "Product ID",
            "example": 123
          },
          "variation_id": {
            "type": "integer",
            "description": "Variation ID",
            "example": 457
          },
          "vendor_subscription_id": {
            "type": "string",
            "description": "Vendor subscription ID",
            "example": "sub_1QxR3nH"
          },
          "vendor_customer_id": {
            "type": "string",
            "description": "Vendor customer ID",
            "example": "cus_Qx7K9mN3pR"
          },
          "vendor_plan_id": {
            "type": "string",
            "nullable": true,
            "description": "Vendor plan ID",
            "example": "price_1Px8KLM"
          },
          "current_payment_method": {
            "type": "string",
            "description": "Current payment method",
            "example": "stripe"
          },
          "billing_interval": {
            "type": "string",
            "description": "Billing interval (e.g., monthly, yearly)",
            "example": "yearly"
          },
          "recurring_amount": {
            "type": "integer",
            "description": "Recurring amount in cents",
            "example": 9900
          },
          "bill_times": {
            "type": "integer",
            "description": "Number of times to bill (0 = unlimited)",
            "example": 0
          },
          "bill_count": {
            "type": "integer",
            "description": "Number of completed billing cycles",
            "example": 1
          },
          "next_billing_date": {
            "type": "string",
            "format": "date-time",
            "description": "Next billing date in GMT",
            "example": "2026-09-20 14:25:00"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-09-20 14:25:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-09-20 14:25:30"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer",
            "example": 1
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subscription"
            }
          },
          "per_page": {
            "type": "integer",
            "example": 10
          },
          "total": {
            "type": "integer",
            "example": 50
          },
          "last_page": {
            "type": "integer",
            "example": 5
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}