{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/customer-profile/subscriptions/{subscription_uuid}/update-payment-method": {
      "post": {
        "operationId": "updatePaymentMethod",
        "summary": "POST Update Payment Method",
        "description": "Update the payment method (e.g., replace the card on file) for an existing subscription within the same payment gateway.",
        "tags": [
          "Subscriptions"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "subscription_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The subscription UUID (alphanumeric with dashes)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "data"
                ],
                "properties": {
                  "data": {
                    "type": "object",
                    "required": [
                      "method"
                    ],
                    "properties": {
                      "method": {
                        "type": "string",
                        "description": "Payment gateway slug (e.g., stripe, paypal)",
                        "example": "stripe"
                      },
                      "payment_method_id": {
                        "type": "string",
                        "description": "Gateway-specific payment method identifier",
                        "example": "pm_1Px8KLMnOpQr"
                      }
                    },
                    "description": "Payment method data object. Additional fields depend on the specific payment gateway implementation."
                  }
                }
              },
              "example": {
                "data": {
                  "method": "stripe",
                  "payment_method_id": "pm_1Px8KLMnOpQr"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment method updated successfully. Response depends on the gateway's cardUpdate implementation.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "message": "Payment method updated successfully"
                }
              }
            }
          },
          "422": {
            "description": "Could not update payment method",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "message": "Could not update payment method"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}