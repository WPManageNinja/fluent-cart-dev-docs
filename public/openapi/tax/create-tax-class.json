{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/tax/classes": {
      "post": {
        "operationId": "createTaxClass",
        "summary": "POST Create Tax Class",
        "description": "Create a new tax class. A unique slug is auto-generated from the title.",
        "tags": [
          "Tax"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Tax class title (max 192 characters)",
                    "example": "Digital Goods"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of the tax class",
                    "example": "Tax class for digital products"
                  },
                  "categories": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of product category IDs associated with this tax class",
                    "example": [
                      12,
                      15
                    ]
                  },
                  "priority": {
                    "type": "integer",
                    "description": "Sort priority (higher values appear first, default: 0)",
                    "default": 0,
                    "example": 7
                  }
                }
              },
              "example": {
                "title": "Digital Goods",
                "description": "Tax class for digital products",
                "categories": [
                  12,
                  15
                ],
                "priority": 7
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tax class created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Tax class has been created successfully"
                    }
                  }
                },
                "example": {
                  "message": "Tax class has been created successfully"
                }
              }
            }
          },
          "422": {
            "description": "Validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errors": {
                      "type": "object",
                      "properties": {
                        "title": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "errors": {
                    "title": [
                      "Tax class title is required."
                    ]
                  },
                  "message": "Validation failed"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}