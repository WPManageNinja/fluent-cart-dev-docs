{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/tax/country/{country_code}": {
      "delete": {
        "operationId": "deleteCountryRates",
        "summary": "DELETE Delete All Rates for a Country",
        "description": "Delete all tax rates for a specific country.",
        "tags": [
          "Tax"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "country_code",
            "in": "path",
            "description": "ISO 3166-1 alpha-2 country code (e.g., US, DE)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "FR"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Country rates deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Country has been deleted successfully"
                    }
                  }
                },
                "example": {
                  "message": "Country has been deleted successfully"
                }
              }
            }
          },
          "400": {
            "description": "Failed to delete country rates.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Failed to delete country"
                    }
                  }
                },
                "example": {
                  "message": "Failed to delete country"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}