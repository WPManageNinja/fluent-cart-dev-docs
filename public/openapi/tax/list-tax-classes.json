{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/tax/classes": {
      "get": {
        "operationId": "listTaxClasses",
        "summary": "GET List Tax Classes",
        "description": "Retrieve all tax classes, sorted by priority (highest first), then by newest first when priority is equal.",
        "tags": [
          "Tax"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns all tax classes.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tax_classes": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TaxClass"
                      }
                    }
                  }
                },
                "example": {
                  "tax_classes": [
                    {
                      "id": 1,
                      "title": "Standard",
                      "slug": "standard",
                      "description": "Standard tax rate for most products",
                      "meta": {
                        "categories": [5, 12, 18],
                        "priority": 10
                      },
                      "categories": [5, 12, 18],
                      "created_at": "2025-01-15 10:00:00",
                      "updated_at": "2025-01-15 10:00:00"
                    },
                    {
                      "id": 2,
                      "title": "Reduced",
                      "slug": "reduced",
                      "description": "Reduced tax rate for essential goods",
                      "meta": {
                        "categories": [8, 22],
                        "priority": 5
                      },
                      "categories": [8, 22],
                      "created_at": "2025-01-15 10:15:00",
                      "updated_at": "2025-01-15 10:15:00"
                    },
                    {
                      "id": 3,
                      "title": "Zero",
                      "slug": "zero",
                      "description": "Zero tax rate for exempt products",
                      "meta": {
                        "categories": [30],
                        "priority": 2
                      },
                      "categories": [30],
                      "created_at": "2025-01-15 10:30:00",
                      "updated_at": "2025-01-15 10:30:00"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaxClass": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Tax class ID",
            "example": 1
          },
          "title": {
            "type": "string",
            "description": "Tax class title",
            "example": "Standard"
          },
          "slug": {
            "type": "string",
            "description": "Tax class slug",
            "example": "standard"
          },
          "description": {
            "type": "string",
            "description": "Tax class description",
            "example": "Standard tax rate for most products"
          },
          "meta": {
            "type": "object",
            "description": "Tax class metadata",
            "properties": {
              "categories": {
                "type": "array",
                "items": {
                  "type": "integer"
                },
                "description": "Product category IDs",
                "example": [5, 12, 18]
              },
              "priority": {
                "type": "integer",
                "description": "Display priority",
                "example": 10
              }
            }
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Product category IDs",
            "example": [5, 12, 18]
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-01-01 00:00:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-01-01 00:00:00"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}