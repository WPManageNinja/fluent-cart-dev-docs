{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/taxes": {
      "get": {
        "operationId": "listTaxRecords",
        "summary": "GET List Tax Records",
        "description": "Retrieve a paginated list of order tax rate records with optional filtering, sorting, and search.",
        "tags": [
          "Tax"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of records per page (default: 10, max: 200)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 200,
              "example": 20
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search term. If numeric, searches by id or order_id. Also searches related tax rate country, state, postcode, and name fields. Supports operator syntax (e.g., id = 5, order_id > 100).",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Column to sort by (default: id)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "id",
              "example": "id"
            }
          },
          {
            "name": "sort_type",
            "in": "query",
            "description": "Sort direction: asc or desc (default: desc)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          },
          {
            "name": "active_view",
            "in": "query",
            "description": "Tab filter. One of: filed (records with filed_at set), not_filed (records without filed_at).",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "filed",
                "not_filed"
              ]
            }
          },
          {
            "name": "filter_type",
            "in": "query",
            "description": "Filter mode: simple (default) or advanced",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "simple",
                "advanced"
              ],
              "default": "simple"
            }
          },
          {
            "name": "advanced_filters",
            "in": "query",
            "description": "JSON-encoded array of advanced filter groups. Supports filtering by country, region, tax name, and filed status.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "with",
            "in": "query",
            "description": "Eager-load relations (e.g., order, tax_rate)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "select",
            "in": "query",
            "description": "Comma-separated list of columns to select",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include_ids",
            "in": "query",
            "description": "Comma-separated IDs that must always be included in results",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_tz",
            "in": "query",
            "description": "User timezone for date filtering (e.g., America/New_York)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "America/New_York"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Returns paginated tax records.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "taxes": {
                      "type": "object",
                      "properties": {
                        "current_page": {
                          "type": "integer"
                        },
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/OrderTaxRate"
                          }
                        },
                        "per_page": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        },
                        "last_page": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "taxes": {
                    "current_page": 1,
                    "data": [
                      {
                        "id": 1,
                        "order_id": 42,
                        "tax_rate_id": 5,
                        "shipping_tax": 150,
                        "order_tax": 1000,
                        "total_tax": 1150,
                        "meta": {
                          "rates": [
                            {
                              "rate_id": 5,
                              "name": "CA State Tax",
                              "rate": "8.2500",
                              "tax_amount": 825,
                              "shipping_tax_amount": 150
                            }
                          ],
                          "tax_country": "US",
                          "store_vat_number": "12-3456789"
                        },
                        "filed_at": null,
                        "created_at": "2025-06-01 12:00:00",
                        "updated_at": "2025-06-01 12:00:00"
                      }
                    ],
                    "per_page": 10,
                    "total": 50,
                    "last_page": 5
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrderTaxRate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Order tax rate record ID",
            "example": 1
          },
          "order_id": {
            "type": "integer",
            "description": "Associated order ID",
            "example": 42
          },
          "tax_rate_id": {
            "type": "integer",
            "description": "Associated tax rate ID",
            "example": 5
          },
          "shipping_tax": {
            "type": "integer",
            "description": "Shipping tax amount in cents",
            "example": 150
          },
          "order_tax": {
            "type": "integer",
            "description": "Order tax amount in cents",
            "example": 1000
          },
          "total_tax": {
            "type": "integer",
            "description": "Total tax amount in cents",
            "example": 1150
          },
          "meta": {
            "type": "object",
            "description": "Tax record metadata",
            "properties": {
              "rates": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "tax_country": {
                "type": "string",
                "example": "US"
              },
              "store_vat_number": {
                "type": "string",
                "example": "12-3456789"
              }
            }
          },
          "filed_at": {
            "type": "string",
            "nullable": true,
            "description": "Timestamp when the record was marked as filed",
            "example": null
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-06-01 12:00:00"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-06-01 12:00:00"
          }
        }
      }
    },
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}