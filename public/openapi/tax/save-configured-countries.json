{
  "openapi": "3.0.4",
  "info": {
    "title": "FluentCart API",
    "description": "Complete REST API documentation for FluentCart e-commerce platform",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{website}/wp-json/fluent-cart/v2",
      "description": "Your WordPress website",
      "variables": {
        "website": {
          "default": "YourWebsite.com",
          "description": "Your WordPress website domain (without https://)"
        }
      }
    }
  ],
  "security": [
    {
      "ApplicationPasswords": []
    }
  ],
  "paths": {
    "/tax/configuration/countries": {
      "post": {
        "operationId": "saveConfiguredCountries",
        "summary": "POST Save Configured Countries",
        "description": "Generate tax classes and import tax rates for the specified countries from the built-in rates data. Countries that already have rates in the database are skipped.",
        "tags": [
          "Tax"
        ],
        "security": [
          {
            "ApplicationPasswords": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "countries"
                ],
                "properties": {
                  "countries": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of ISO 3166-1 alpha-2 country codes to configure",
                    "example": [
                      "DE",
                      "FR",
                      "IT",
                      "ES"
                    ]
                  }
                },
                "example": {
                  "countries": [
                    "DE",
                    "FR",
                    "IT",
                    "ES"
                  ]
                }
              },
              "example": {
                "countries": [
                  "DE",
                  "FR",
                  "IT",
                  "ES"
                ]
              },
              "examples": {
                "default": {
                  "summary": "Example request",
                  "value": {
                    "countries": [
                      "DE",
                      "FR",
                      "IT",
                      "ES"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Countries saved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Countries saved successfully"
                    }
                  },
                  "example": {
                    "message": "Countries saved successfully"
                  }
                },
                "example": {
                  "message": "Countries saved successfully"
                },
                "examples": {
                  "default": {
                    "summary": "Successful response",
                    "value": {
                      "message": "Countries saved successfully"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "ApplicationPasswords": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "WordPress Application Passwords \u2014 use Basic auth with your WordPress username and an application password in the format: username:application_password"
      }
    }
  }
}
